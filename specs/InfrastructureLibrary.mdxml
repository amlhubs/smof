							</xmi:Extension>
							<ownedComment xmi:type='uml:Comment' xmi:id='Core-Constructs-ValueSpecification-isNull-_ownedComment.0' body='The query isNull() returns true when it can be computed that the value is null.'>
								<annotatedElement xmi:idref='Core-Constructs-ValueSpecification-isNull'/>
							</ownedComment>
							<ownedRule xmi:type='uml:Constraint' xmi:id='Core-Constructs-ValueSpecification-isNull-spec' name='spec' visibility='public'>
								<constrainedElement xmi:idref='Core-Constructs-ValueSpecification-isNull'/>
								<specification xmi:type='uml:OpaqueExpression' xmi:id='Core-Constructs-ValueSpecification-isNull-spec-_specification' visibility='public'>
									<body>result = false</body>
									<language>OCL</language>
								</specification>
							</ownedRule>
							<ownedParameter xmi:type='uml:Parameter' xmi:id='Core-Constructs-ValueSpecification-isNull-result' name='result' visibility='public' direction='return' effect='create'>
								<type xmi:type='uml:PrimitiveType' href='http://schema.omg.org/spec/UML/2.3/uml.xml#Boolean'>
									<xmi:Extension extender='MagicDraw UML 16.8'>
										<referenceExtension referentPath='PrimitiveTypes::Boolean' referentType='PrimitiveType'/>
									</xmi:Extension>
								</type>
							</ownedParameter>
						</ownedOperation>
						<ownedOperation xmi:type='uml:Operation' xmi:id='Core-Constructs-ValueSpecification-realValue' name='realValue' visibility='public' isQuery='true' bodyCondition='Core-Constructs-ValueSpecification-realValue-spec'>
							<xmi:Extension extender='MagicDraw UML 16.8'>
								<modelExtension/>
							</xmi:Extension>
							<ownedComment xmi:type='uml:Comment' xmi:id='Core-Constructs-ValueSpecification-realValue-_ownedComment.0' body='The query realValue() gives a single Real value when one can be computed.'>
								<annotatedElement xmi:idref='Core-Constructs-ValueSpecification-realValue'/>
							</ownedComment>
							<ownedRule xmi:type='uml:Constraint' xmi:id='Core-Constructs-ValueSpecification-realValue-spec' name='spec' visibility='public'>
								<constrainedElement xmi:idref='Core-Constructs-ValueSpecification-realValue'/>
								<specification xmi:type='uml:OpaqueExpression' xmi:id='Core-Constructs-ValueSpecification-realValue-spec-_specification' visibility='public'>
									<body>result = Set{}</body>
									<language>OCL</language>
								</specification>
							</ownedRule>
							<ownedParameter xmi:type='uml:Parameter' xmi:id='Core-Constructs-ValueSpecification-realValue-result' name='result' visibility='public' direction='return' effect='create'>
