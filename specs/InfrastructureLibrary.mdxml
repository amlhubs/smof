							<ownedComment xmi:type='uml:Comment' xmi:id='Core-Basic-Type-package-_ownedComment.0' body='Specifies the owning package of this classifier, if any.'>
								<annotatedElement xmi:idref='Core-Basic-Type-package'/>
							</ownedComment>
							<lowerValue xmi:type='uml:LiteralInteger' xmi:id='Core-Basic-Type-package-_lowerValue' visibility='public'/>
						</ownedAttribute>
					</packagedElement>
