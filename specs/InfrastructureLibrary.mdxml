						<memberEnd xmi:idref='Core-Basic-Comment-annotatedElement'/>
						<memberEnd xmi:idref='Core-Basic-A_annotatedElement_comment-comment'/>
						<ownedEnd xmi:type='uml:Property' xmi:id='Core-Basic-A_annotatedElement_comment-comment' name='comment' visibility='public' type='Core-Basic-Comment' association='Core-Basic-A_annotatedElement_comment'>
							<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='Core-Basic-A_annotatedElement_comment-comment-_upperValue' visibility='public' value='*'/>
