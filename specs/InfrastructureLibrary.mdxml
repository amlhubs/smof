						<ownedComment xmi:type='uml:Comment' xmi:id='Core-Basic-TypedElement-_ownedComment.0' body='A typed element is a kind of named element that represents an element with a type.'>
							<annotatedElement xmi:idref='Core-Basic-TypedElement'/>
						</ownedComment>
						<generalization xmi:type='uml:Generalization' xmi:id='Core-Basic-TypedElement-_generalization.0' general='Core-Basic-NamedElement'/>
						<ownedAttribute xmi:type='uml:Property' xmi:id='Core-Basic-TypedElement-type' name='type' visibility='public' type='Core-Basic-Type' association='Core-Basic-A_type_typedElement'>
							<ownedComment xmi:type='uml:Comment' xmi:id='Core-Basic-TypedElement-type-_ownedComment.0' body='The type of the TypedElement.'>
								<annotatedElement xmi:idref='Core-Basic-TypedElement-type'/>
