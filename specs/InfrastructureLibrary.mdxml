								<ownedComment xmi:type='uml:Comment' xmi:id='Core-Abstractions-Generalizations-Generalization-specific-_ownedComment.0' body='References the specializing classifier in the Generalization relationship.'>
									<annotatedElement xmi:idref='Core-Abstractions-Generalizations-Generalization-specific'/>
								</ownedComment>
							</ownedAttribute>
						</packagedElement>
						<packagedElement xmi:type='uml:Association' xmi:id='Core-Abstractions-Generalizations-A_generalization_specific' name='A_generalization_specific' visibility='public'>
							<memberEnd xmi:idref='Core-Abstractions-Generalizations-Classifier-generalization'/>
							<memberEnd xmi:idref='Core-Abstractions-Generalizations-Generalization-specific'/>
						</packagedElement>
						<packagedElement xmi:type='uml:Association' xmi:id='Core-Abstractions-Generalizations-A_general_generalization' name='A_general_generalization' visibility='public'>
							<memberEnd xmi:idref='Core-Abstractions-Generalizations-Generalization-general'/>
							<memberEnd xmi:idref='Core-Abstractions-Generalizations-A_general_generalization-generalization'/>
