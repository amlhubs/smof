						<ownedAttribute xmi:type='uml:Property' xmi:id='Core-Basic-Operation-ownedParameter' name='ownedParameter' visibility='public' isOrdered='true' aggregation='composite' type='Core-Basic-Parameter' association='Core-Basic-A_ownedParameter_operation'>
							<ownedComment xmi:type='uml:Comment' xmi:id='Core-Basic-Operation-ownedParameter-_ownedComment.0' body='The parameters to the operation.'>
