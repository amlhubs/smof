								<modelExtension/>
							</xmi:Extension>
							<ownedComment xmi:type='uml:Comment' xmi:id='Core-Constructs-Package-visibleMembers-_ownedComment.0' body='The query visibleMembers() defines which members of a Package can be accessed outside it.'>
								<annotatedElement xmi:idref='Core-Constructs-Package-visibleMembers'/>
