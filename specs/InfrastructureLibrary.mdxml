							</xmi:Extension>
						</importedPackage>
					</packageImport>
					<packagedElement xmi:type='uml:Class' xmi:id='Core-Basic-Type' name='Type' visibility='public' isAbstract='true'>
						<ownedComment xmi:type='uml:Comment' xmi:id='Core-Basic-Type-_ownedComment.0' body='A type is a named element that is used as the type for a typed element. A type can be contained in a package.'>
							<annotatedElement xmi:idref='Core-Basic-Type'/>
						</ownedComment>
						<generalization xmi:type='uml:Generalization' xmi:id='Core-Basic-Type-_generalization.0' general='Core-Basic-NamedElement'/>
