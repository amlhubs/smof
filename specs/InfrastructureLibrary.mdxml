						</ownedAttribute>
						<ownedAttribute xmi:type='uml:Property' xmi:id='Core-Constructs-Operation-ownedParameter' name='ownedParameter' visibility='public' isOrdered='true' aggregation='composite' type='Core-Constructs-Parameter' association='Core-Constructs-A_ownedParameter_operation'>
							<redefinedProperty xmi:idref='Core-Constructs-BehavioralFeature-ownedParameter'/>
							<ownedComment xmi:type='uml:Comment' xmi:id='Core-Constructs-Operation-ownedParameter-_ownedComment.0' body='Specifies the ordered set of formal parameters of this BehavioralFeature.'>
								<annotatedElement xmi:idref='Core-Constructs-Operation-ownedParameter'/>
							</ownedComment>
							<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='Core-Constructs-Operation-ownedParameter-_upperValue' visibility='public' value='*'/>
							<lowerValue xmi:type='uml:LiteralInteger' xmi:id='Core-Constructs-Operation-ownedParameter-_lowerValue' visibility='public'/>
						</ownedAttribute>
						<ownedAttribute xmi:type='uml:Property' xmi:id='Core-Constructs-Operation-postcondition' name='postcondition' visibility='public' aggregation='composite' type='Core-Constructs-Constraint' association='Core-Constructs-A_postcondition_postContext'>
							<subsettedProperty xmi:idref='Core-Constructs-Namespace-ownedRule'/>
							<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='Core-Constructs-Operation-postcondition-_upperValue' visibility='public' value='*'/>
							<lowerValue xmi:type='uml:LiteralInteger' xmi:id='Core-Constructs-Operation-postcondition-_lowerValue' visibility='public'/>
						</ownedAttribute>
						<ownedAttribute xmi:type='uml:Property' xmi:id='Core-Constructs-Operation-precondition' name='precondition' visibility='public' aggregation='composite' type='Core-Constructs-Constraint' association='Core-Constructs-A_precondition_preContext'>
							<subsettedProperty xmi:idref='Core-Constructs-Namespace-ownedRule'/>
							<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='Core-Constructs-Operation-precondition-_upperValue' visibility='public' value='*'/>
							<lowerValue xmi:type='uml:LiteralInteger' xmi:id='Core-Constructs-Operation-precondition-_lowerValue' visibility='public'/>
						</ownedAttribute>
						<ownedAttribute xmi:type='uml:Property' xmi:id='Core-Constructs-Operation-raisedException' name='raisedException' visibility='public' type='Core-Constructs-Type' association='Core-Constructs-A_raisedException_operation'>
							<redefinedProperty xmi:idref='Core-Constructs-BehavioralFeature-raisedException'/>
							<ownedComment xmi:type='uml:Comment' xmi:id='Core-Constructs-Operation-raisedException-_ownedComment.0' body='References the Types representing exceptions that may be raised during an invocation of this operation.'>
								<annotatedElement xmi:idref='Core-Constructs-Operation-raisedException'/>
							</ownedComment>
							<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='Core-Constructs-Operation-raisedException-_upperValue' visibility='public' value='*'/>
							<lowerValue xmi:type='uml:LiteralInteger' xmi:id='Core-Constructs-Operation-raisedException-_lowerValue' visibility='public'/>
						</ownedAttribute>
						<ownedAttribute xmi:type='uml:Property' xmi:id='Core-Constructs-Operation-redefinedOperation' name='redefinedOperation' visibility='public' type='Core-Constructs-Operation' association='Core-Constructs-A_redefinedOperation_operation'>
							<subsettedProperty xmi:idref='Core-Constructs-RedefinableElement-redefinedElement'/>
							<ownedComment xmi:type='uml:Comment' xmi:id='Core-Constructs-Operation-redefinedOperation-_ownedComment.0' body='References the Operations that are redefined by this Operation.'>
								<annotatedElement xmi:idref='Core-Constructs-Operation-redefinedOperation'/>
							</ownedComment>
							<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='Core-Constructs-Operation-redefinedOperation-_upperValue' visibility='public' value='*'/>
							<lowerValue xmi:type='uml:LiteralInteger' xmi:id='Core-Constructs-Operation-redefinedOperation-_lowerValue' visibility='public'/>
						</ownedAttribute>
