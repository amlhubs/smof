								<annotatedElement xmi:idref='Core-Constructs-Operation-datatype'/>
							</ownedComment>
							<lowerValue xmi:type='uml:LiteralInteger' xmi:id='Core-Constructs-Operation-datatype-_lowerValue' visibility='public'/>
						</ownedAttribute>
