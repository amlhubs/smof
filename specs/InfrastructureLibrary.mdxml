						<packagedElement xmi:type='uml:Class' xmi:id='Core-Abstractions-Ownerships-Element' name='Element' visibility='public' isAbstract='true'>
							<xmi:Extension extender='MagicDraw UML 16.8'>
								<modelExtension/>
							</xmi:Extension>
							<ownedComment xmi:type='uml:Comment' xmi:id='Core-Abstractions-Ownerships-Element-_ownedComment.0' body='An element is a constituent of a model. As such, it has the capability of owning other elements.'>
								<annotatedElement xmi:idref='Core-Abstractions-Ownerships-Element'/>
							</ownedComment>
							<ownedRule xmi:type='uml:Constraint' xmi:id='Core-Abstractions-Ownerships-Element-has_owner' name='has_owner' visibility='public'>
								<constrainedElement xmi:idref='Core-Abstractions-Ownerships-Element'/>
								<ownedComment xmi:type='uml:Comment' xmi:id='Core-Abstractions-Ownerships-Element-has_owner-_ownedComment.0' body='Elements that must be owned must have an owner.'>
									<annotatedElement xmi:idref='Core-Abstractions-Ownerships-Element-has_owner'/>
								</ownedComment>
								<specification xmi:type='uml:OpaqueExpression' xmi:id='Core-Abstractions-Ownerships-Element-has_owner-_specification' visibility='public'>
									<body>self.mustBeOwned() implies owner-&gt;notEmpty()</body>
									<language>OCL</language>
								</specification>
							</ownedRule>
							<ownedRule xmi:type='uml:Constraint' xmi:id='Core-Abstractions-Ownerships-Element-not_own_self' name='not_own_self' visibility='public'>
								<constrainedElement xmi:idref='Core-Abstractions-Ownerships-Element'/>
								<ownedComment xmi:type='uml:Comment' xmi:id='Core-Abstractions-Ownerships-Element-not_own_self-_ownedComment.0' body='An element may not directly or indirectly own itself.'>
									<annotatedElement xmi:idref='Core-Abstractions-Ownerships-Element-not_own_self'/>
								</ownedComment>
								<specification xmi:type='uml:OpaqueExpression' xmi:id='Core-Abstractions-Ownerships-Element-not_own_self-_specification' visibility='public'>
									<body>not self.allOwnedElements()-&gt;includes(self)</body>
									<language>OCL</language>
								</specification>
							</ownedRule>
							<ownedAttribute xmi:type='uml:Property' xmi:id='Core-Abstractions-Ownerships-Element-ownedComment' name='ownedComment' visibility='public' aggregation='composite' type='Core-Abstractions-Comments-Comment' association='Core-Abstractions-Ownerships-A_ownedComment_owningElement'>
