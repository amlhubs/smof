					<packagedElement xmi:type='uml:Class' xmi:id='Core-Basic-Operation' name='Operation' visibility='public'>
						<ownedComment xmi:type='uml:Comment' xmi:id='Core-Basic-Operation-_ownedComment.0' body='An operation is owned by a class and may be invoked in the context of objects that are instances of that class. It is a typed element and a multiplicity element.'>
