						<ownedComment xmi:type='uml:Comment' xmi:id='Core-Basic-Parameter-_ownedComment.0' body='A parameter is a typed element that represents a parameter of an operation.'>
							<annotatedElement xmi:idref='Core-Basic-Parameter'/>
						</ownedComment>
						<generalization xmi:type='uml:Generalization' xmi:id='Core-Basic-Parameter-_generalization.0' general='Core-Basic-MultiplicityElement'/>
