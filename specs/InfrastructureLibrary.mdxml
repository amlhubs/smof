				<packagedElement xmi:type='uml:Package' xmi:id='Core-Constructs' name='Constructs' visibility='public'>
					<packageImport xmi:type='uml:PackageImport' xmi:id='Core-Constructs-_packageImport.0'>
						<importedPackage xmi:type='uml:Package' href='PrimitiveTypes.mdxml#_0Package_PrimitiveTypes'>
							<xmi:Extension extender='MagicDraw UML 16.8'>
								<referenceExtension referentPath='PrimitiveTypes' referentType='Package'/>
							</xmi:Extension>
						</importedPackage>
					</packageImport>
					<packagedElement xmi:type='uml:Class' xmi:id='Core-Constructs-Package' name='Package' visibility='public'>
						<xmi:Extension extender='MagicDraw UML 16.8'>
							<modelExtension/>
						</xmi:Extension>
						<ownedComment xmi:type='uml:Comment' xmi:id='Core-Constructs-Package-_ownedComment.0' body='A package is used to group elements, and provides a namespace for the grouped elements.'>
							<annotatedElement xmi:idref='Core-Constructs-Package'/>
						</ownedComment>
						<ownedRule xmi:type='uml:Constraint' xmi:id='Core-Constructs-Package-elements_public_or_private' name='elements_public_or_private' visibility='public'>
							<constrainedElement xmi:idref='Core-Constructs-Package'/>
							<ownedComment xmi:type='uml:Comment' xmi:id='Core-Constructs-Package-elements_public_or_private-_ownedComment.0' body='If an element that is owned by a package has visibility, it is public or private.'>
								<annotatedElement xmi:idref='Core-Constructs-Package-elements_public_or_private'/>
							</ownedComment>
							<specification xmi:type='uml:OpaqueExpression' xmi:id='Core-Constructs-Package-elements_public_or_private-_specification' visibility='public'>
								<body>self.ownedElements-&gt;forAll(e | e.visibility-&gt;notEmpty() implies e.visbility = #public or e.visibility = #private)</body>
								<language>OCL</language>
							</specification>
						</ownedRule>
						<generalization xmi:type='uml:Generalization' xmi:id='Core-Constructs-Package-_generalization.0' general='Core-Constructs-Namespace'/>
						<generalization xmi:type='uml:Generalization' xmi:id='Core-Constructs-Package-_generalization.1' general='Core-Constructs-PackageableElement'/>
						<ownedAttribute xmi:type='uml:Property' xmi:id='Core-Constructs-Package-URI' name='URI' visibility='public'>
							<type xmi:type='uml:PrimitiveType' href='http://schema.omg.org/spec/UML/2.3/uml.xml#String'>
								<xmi:Extension extender='MagicDraw UML 16.8'>
									<referenceExtension referentPath='PrimitiveTypes::String' referentType='PrimitiveType'/>
								</xmi:Extension>
							</type>
							<ownedComment xmi:type='uml:Comment' xmi:id='Core-Constructs-Package-URI-_ownedComment.0' body='Provides an identifier for the package that can be used for many purposes. A URI is the universally unique identification of the package following the IETF URI specification, RFC 2396 http://www.ietf.org/rfc/rfc2396.txt and it must comply with those syntax rules.'>
								<annotatedElement xmi:idref='Core-Constructs-Package-URI'/>
							</ownedComment>
							<lowerValue xmi:type='uml:LiteralInteger' xmi:id='Core-Constructs-Package-URI-_lowerValue' visibility='public'/>
						</ownedAttribute>
						<ownedAttribute xmi:type='uml:Property' xmi:id='Core-Constructs-Package-nestedPackage' name='nestedPackage' visibility='public' isDerived='true' aggregation='composite' type='Core-Constructs-Package' association='Core-Constructs-A_nestedPackage_nestingPackage'>
							<xmi:Extension extender='MagicDraw UML 16.8'>
								<modelExtension/>
							</xmi:Extension>
							<subsettedProperty xmi:idref='Core-Constructs-Package-packagedElement'/>
