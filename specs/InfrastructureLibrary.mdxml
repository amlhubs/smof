						<ownedComment xmi:type='uml:Comment' xmi:id='Core-Basic-Element-_ownedComment.0' body='An element is a constituent of a model.'>
							<annotatedElement xmi:idref='Core-Basic-Element'/>
						</ownedComment>
						<ownedAttribute xmi:type='uml:Property' xmi:id='Core-Basic-Element-ownedComment' name='ownedComment' visibility='public' aggregation='composite' type='Core-Basic-Comment' association='Core-Basic-A_ownedComment_owningElement'>
