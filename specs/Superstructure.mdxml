						<ownedEnd xmi:type='uml:Property' xmi:id='StateMachines-BehaviorStateMachines-A_redefinitionContext_transition-transition' name='transition' visibility='public' type='StateMachines-BehaviorStateMachines-Transition' association='StateMachines-BehaviorStateMachines-A_redefinitionContext_transition'>
							<redefinedProperty xmi:idref='Classes-Kernel-A_redefinitionContext_redefinableElement-redefinableElement'/>
