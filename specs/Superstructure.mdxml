					<packagedElement xmi:type='uml:Class' xmi:id='Activities-StructuredActivities-SequenceNode' name='SequenceNode' visibility='public'>
						<ownedComment xmi:type='uml:Comment' xmi:id='Activities-StructuredActivities-SequenceNode-_ownedComment.0' body='A sequence node is a structured activity node that executes its actions in order.'>
