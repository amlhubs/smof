							</ownedComment>
							<specification xmi:type='uml:OpaqueExpression' xmi:id='Actions-CompleteActions-ReclassifyObjectAction-multiplicity-_specification' visibility='public'>
								<body>self.argument.multiplicity.is(1,1)</body>
