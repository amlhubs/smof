						</xmi:Extension>
						<ownedComment xmi:type='uml:Comment' xmi:id='Deployments-Nodes-Property-_ownedComment.0' body='A property has the capability of being a deployment target in a deployment relationship. This enables modeling the deployment to hierarchical nodes that have properties functioning as internal parts.'>
							<annotatedElement xmi:idref='Deployments-Nodes-Property'/>
						</ownedComment>
						<ownedRule xmi:type='uml:Constraint' xmi:id='Deployments-Nodes-Property-deployment_target' name='deployment_target' visibility='public'>
							<constrainedElement xmi:idref='Deployments-Nodes-Property'/>
							<ownedComment xmi:type='uml:Comment' xmi:id='Deployments-Nodes-Property-deployment_target-_ownedComment.0' body='A Property can be a DeploymentTarget if it is a kind of Node and functions as a part in the internal structure of an encompassing Node.'>
								<annotatedElement xmi:idref='Deployments-Nodes-Property-deployment_target'/>
							</ownedComment>
							<specification xmi:type='uml:OpaqueExpression' xmi:id='Deployments-Nodes-Property-deployment_target-_specification' visibility='public'>
								<body>true</body>
								<language>OCL</language>
							</specification>
						</ownedRule>
						<generalization xmi:type='uml:Generalization' xmi:id='Deployments-Nodes-Property-_generalization.0' general='Deployments-Nodes-DeploymentTarget'/>
