									<referenceExtension referentPath='PrimitiveTypes::Boolean' referentType='PrimitiveType'/>
								</xmi:Extension>
							</type>
							<ownedComment xmi:type='uml:Comment' xmi:id='Activities-IntermediateActivities-ActivityPartition-isExternal-_ownedComment.0' body='Tells whether the partition represents an entity to which the partitioning structure does not apply.'>
								<annotatedElement xmi:idref='Activities-IntermediateActivities-ActivityPartition-isExternal'/>
							</ownedComment>
							<defaultValue xmi:type='uml:LiteralBoolean' xmi:id='Activities-IntermediateActivities-ActivityPartition-isExternal-_defaultValue' visibility='public'/>
						</ownedAttribute>
