					<packagedElement xmi:type='uml:Class' xmi:id='Activities-BasicActivities-ActivityGroup' name='ActivityGroup' visibility='public' isAbstract='true'>
						<xmi:Extension extender='MagicDraw UML 16.8'>
							<modelExtension/>
