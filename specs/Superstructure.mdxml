					<packagedElement xmi:type='uml:Class' xmi:id='AuxiliaryConstructs-Templates-ParameterableElement' name='ParameterableElement' visibility='public' isAbstract='true'>
						<ownedComment xmi:type='uml:Comment' xmi:id='AuxiliaryConstructs-Templates-ParameterableElement-_ownedComment.0' body='A parameterable element is an element that can be exposed as a formal template parameter for a template, or specified as an actual parameter in a binding of a template.'>
							<annotatedElement xmi:idref='AuxiliaryConstructs-Templates-ParameterableElement'/>
						</ownedComment>
						<generalization xmi:type='uml:Generalization' xmi:id='AuxiliaryConstructs-Templates-ParameterableElement-_generalization.0' general='Classes-Kernel-Element'/>
