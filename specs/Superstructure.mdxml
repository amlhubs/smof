							<ownedComment xmi:type='uml:Comment' xmi:id='Deployments-Nodes-InstanceSpecification-deployment_artifact-_ownedComment.0' body='An InstanceSpecification can be a DeployedArtifact if it is the instance specification of an Artifact.'>
								<annotatedElement xmi:idref='Deployments-Nodes-InstanceSpecification-deployment_artifact'/>
							</ownedComment>
							<specification xmi:type='uml:OpaqueExpression' xmi:id='Deployments-Nodes-InstanceSpecification-deployment_artifact-_specification' visibility='public'>
								<body>true</body>
