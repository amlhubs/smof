							<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='Actions-BasicActions-InvocationAction-argument-_upperValue' visibility='public' value='*'/>
							<lowerValue xmi:type='uml:LiteralInteger' xmi:id='Actions-BasicActions-InvocationAction-argument-_lowerValue' visibility='public'/>
						</ownedAttribute>
					</packagedElement>
					<packagedElement xmi:type='uml:Class' xmi:id='Actions-BasicActions-Action' name='Action' visibility='public' isAbstract='true'>
						<ownedComment xmi:type='uml:Comment' xmi:id='Actions-BasicActions-Action-_ownedComment.0' body='An action is a named element that is the fundamental unit of executable functionality. The execution of an action represents some transformation or processing in the modeled system, be it a computer system or otherwise.'>
							<annotatedElement xmi:idref='Actions-BasicActions-Action'/>
						</ownedComment>
						<generalization xmi:type='uml:Generalization' xmi:id='Actions-BasicActions-Action-_generalization.0' general='Classes-Kernel-NamedElement'/>
						<ownedAttribute xmi:type='uml:Property' xmi:id='Actions-BasicActions-Action-context' name='context' visibility='public' isReadOnly='true' isDerived='true' type='Classes-Kernel-Classifier' association='Actions-BasicActions-A_context_action'>
							<xmi:Extension extender='MagicDraw UML 16.8'>
								<modelExtension/>
							</xmi:Extension>
							<ownedComment xmi:type='uml:Comment' xmi:id='Actions-BasicActions-Action-context-_ownedComment.0' body='The classifier that owns the behavior of which this action is a part.'>
								<annotatedElement xmi:idref='Actions-BasicActions-Action-context'/>
							</ownedComment>
							<lowerValue xmi:type='uml:LiteralInteger' xmi:id='Actions-BasicActions-Action-context-_lowerValue' visibility='public'/>
						</ownedAttribute>
						<ownedAttribute xmi:type='uml:Property' xmi:id='Actions-BasicActions-Action-input' name='input' visibility='public' isOrdered='true' isReadOnly='true' isDerived='true' isDerivedUnion='true' aggregation='composite' type='Actions-BasicActions-InputPin' association='Actions-BasicActions-A_input_action'>
							<subsettedProperty xmi:idref='Classes-Kernel-Element-ownedElement'/>
							<ownedComment xmi:type='uml:Comment' xmi:id='Actions-BasicActions-Action-input-_ownedComment.0' body='The ordered set of input pins connected to the Action. These are among the total set of inputs.'>
								<annotatedElement xmi:idref='Actions-BasicActions-Action-input'/>
							</ownedComment>
							<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='Actions-BasicActions-Action-input-_upperValue' visibility='public' value='*'/>
							<lowerValue xmi:type='uml:LiteralInteger' xmi:id='Actions-BasicActions-Action-input-_lowerValue' visibility='public'/>
						</ownedAttribute>
						<ownedAttribute xmi:type='uml:Property' xmi:id='Actions-BasicActions-Action-output' name='output' visibility='public' isOrdered='true' isReadOnly='true' isDerived='true' isDerivedUnion='true' aggregation='composite' type='Actions-BasicActions-OutputPin' association='Actions-BasicActions-A_output_action'>
							<subsettedProperty xmi:idref='Classes-Kernel-Element-ownedElement'/>
							<ownedComment xmi:type='uml:Comment' xmi:id='Actions-BasicActions-Action-output-_ownedComment.0' body='The ordered set of output pins connected to the Action. The action places its results onto pins in this set.'>
								<annotatedElement xmi:idref='Actions-BasicActions-Action-output'/>
							</ownedComment>
							<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='Actions-BasicActions-Action-output-_upperValue' visibility='public' value='*'/>
							<lowerValue xmi:type='uml:LiteralInteger' xmi:id='Actions-BasicActions-Action-output-_lowerValue' visibility='public'/>
						</ownedAttribute>
						<ownedOperation xmi:type='uml:Operation' xmi:id='Actions-BasicActions-Action-context.1' name='context' visibility='public' isQuery='true' bodyCondition='Actions-BasicActions-Action-context.1-spec'>
							<xmi:Extension extender='MagicDraw UML 16.8'>
								<modelExtension/>
							</xmi:Extension>
							<ownedComment xmi:type='uml:Comment' xmi:id='Actions-BasicActions-Action-context.1-_ownedComment.0' body='Missing derivation for Action::/context : Classifier'>
								<annotatedElement xmi:idref='Actions-BasicActions-Action-context.1'/>
							</ownedComment>
							<ownedRule xmi:type='uml:Constraint' xmi:id='Actions-BasicActions-Action-context.1-spec' name='spec' visibility='public'>
								<constrainedElement xmi:idref='Actions-BasicActions-Action-context.1'/>
								<constrainedElement xmi:idref='Actions-BasicActions-Action-context'/>
								<specification xmi:type='uml:OpaqueExpression' xmi:id='Actions-BasicActions-Action-context.1-spec-_specification' visibility='public'>
									<body>true</body>
