							<modelExtension/>
						</xmi:Extension>
						<ownedComment xmi:type='uml:Comment' xmi:id='Deployments-Nodes-CommunicationPath-_ownedComment.0' body='A communication path is an association between two deployment targets, through which they are able to exchange signals and messages.'>
							<annotatedElement xmi:idref='Deployments-Nodes-CommunicationPath'/>
