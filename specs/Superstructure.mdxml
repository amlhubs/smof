							<lowerValue xmi:type='uml:LiteralInteger' xmi:id='Classes-Kernel-Package-packagedElement-_lowerValue' visibility='public'/>
						</ownedAttribute>
						<ownedOperation xmi:type='uml:Operation' xmi:id='Classes-Kernel-Package-makesVisible' name='makesVisible' visibility='public' isQuery='true' bodyCondition='Classes-Kernel-Package-makesVisible-spec'>
							<xmi:Extension extender='MagicDraw UML 16.8'>
								<modelExtension/>
							</xmi:Extension>
							<precondition xmi:idref='Classes-Kernel-Package-makesVisible-pre'/>
							<ownedComment xmi:type='uml:Comment' xmi:id='Classes-Kernel-Package-makesVisible-_ownedComment.0' body='The query makesVisible() defines whether a Package makes an element visible outside itself. Elements with no visibility and elements with public visibility are made visible.'>
								<annotatedElement xmi:idref='Classes-Kernel-Package-makesVisible'/>
							</ownedComment>
							<ownedRule xmi:type='uml:Constraint' xmi:id='Classes-Kernel-Package-makesVisible-pre' name='pre' visibility='public'>
								<constrainedElement xmi:idref='Classes-Kernel-Package-makesVisible'/>
								<specification xmi:type='uml:OpaqueExpression' xmi:id='Classes-Kernel-Package-makesVisible-pre-_specification' visibility='public'>
									<body>self.member-&gt;includes(el)</body>
									<language>OCL</language>
								</specification>
							</ownedRule>
							<ownedRule xmi:type='uml:Constraint' xmi:id='Classes-Kernel-Package-makesVisible-spec' name='spec' visibility='public'>
								<constrainedElement xmi:idref='Classes-Kernel-Package-makesVisible'/>
								<specification xmi:type='uml:OpaqueExpression' xmi:id='Classes-Kernel-Package-makesVisible-spec-_specification' visibility='public'>
									<body>result = (ownedMember-&gt;includes(el)) or
(elementImport-&gt;select(ei|ei.importedElement = #public)-&gt;collect(ei|ei.importedElement)-&gt;includes(el)) or
(packageImport-&gt;select(pi|pi.visibility = #public)-&gt;collect(pi|pi.importedPackage.member-&gt;includes(el))-&gt;notEmpty())</body>
									<language>OCL</language>
								</specification>
							</ownedRule>
							<ownedParameter xmi:type='uml:Parameter' xmi:id='Classes-Kernel-Package-makesVisible-result' name='result' visibility='public' direction='return' effect='create'>
								<type xmi:type='uml:PrimitiveType' href='http://schema.omg.org/spec/UML/2.3/uml.xml#Boolean'>
									<xmi:Extension extender='MagicDraw UML 16.8'>
										<referenceExtension referentPath='PrimitiveTypes::Boolean' referentType='PrimitiveType'/>
									</xmi:Extension>
								</type>
							</ownedParameter>
							<ownedParameter xmi:type='uml:Parameter' xmi:id='Classes-Kernel-Package-makesVisible-el' name='el' visibility='public' effect='create' type='Classes-Kernel-NamedElement'/>
						</ownedOperation>
						<ownedOperation xmi:type='uml:Operation' xmi:id='Classes-Kernel-Package-mustBeOwned' name='mustBeOwned' visibility='public' isQuery='true' bodyCondition='Classes-Kernel-Package-mustBeOwned-spec'>
							<xmi:Extension extender='MagicDraw UML 16.8'>
								<modelExtension/>
							</xmi:Extension>
							<redefinedOperation xmi:idref='Classes-Kernel-Element-mustBeOwned'/>
							<ownedComment xmi:type='uml:Comment' xmi:id='Classes-Kernel-Package-mustBeOwned-_ownedComment.0' body='The query mustBeOwned() indicates whether elements of this type must have an owner.'>
								<annotatedElement xmi:idref='Classes-Kernel-Package-mustBeOwned'/>
							</ownedComment>
							<ownedRule xmi:type='uml:Constraint' xmi:id='Classes-Kernel-Package-mustBeOwned-spec' name='spec' visibility='public'>
								<constrainedElement xmi:idref='Classes-Kernel-Package-mustBeOwned'/>
								<specification xmi:type='uml:OpaqueExpression' xmi:id='Classes-Kernel-Package-mustBeOwned-spec-_specification' visibility='public'>
									<body>result = false</body>
									<language>OCL</language>
								</specification>
							</ownedRule>
							<ownedParameter xmi:type='uml:Parameter' xmi:id='Classes-Kernel-Package-mustBeOwned-result' name='result' visibility='public' direction='return' effect='create'>
								<type xmi:type='uml:PrimitiveType' href='http://schema.omg.org/spec/UML/2.3/uml.xml#Boolean'>
									<xmi:Extension extender='MagicDraw UML 16.8'>
										<referenceExtension referentPath='PrimitiveTypes::Boolean' referentType='PrimitiveType'/>
									</xmi:Extension>
								</type>
							</ownedParameter>
						</ownedOperation>
						<ownedOperation xmi:type='uml:Operation' xmi:id='Classes-Kernel-Package-nestedPackage.1' name='nestedPackage' visibility='public' isQuery='true' bodyCondition='Classes-Kernel-Package-nestedPackage.1-spec'>
							<xmi:Extension extender='MagicDraw UML 16.8'>
								<modelExtension/>
							</xmi:Extension>
							<ownedComment xmi:type='uml:Comment' xmi:id='Classes-Kernel-Package-nestedPackage.1-_ownedComment.0' body='Missing derivation for Package::/nestedPackage : Package'>
								<annotatedElement xmi:idref='Classes-Kernel-Package-nestedPackage.1'/>
