								<xmi:Extension extender='MagicDraw UML 16.8'>
									<referenceExtension referentPath='PrimitiveTypes::UnlimitedNatural' referentType='PrimitiveType'/>
								</xmi:Extension>
							</type>
							<ownedComment xmi:type='uml:Comment' xmi:id='Classes-Kernel-Operation-upper-_ownedComment.0' body='Specifies the upper multiplicity of the return parameter, if present.'>
								<annotatedElement xmi:idref='Classes-Kernel-Operation-upper'/>
							</ownedComment>
