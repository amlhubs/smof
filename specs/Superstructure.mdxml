							<subsettedProperty xmi:idref='Classes-Kernel-Element-owner'/>
							<lowerValue xmi:type='uml:LiteralInteger' xmi:id='StateMachines-BehaviorStateMachines-A_trigger_transition-transition-_lowerValue' visibility='public'/>
						</ownedEnd>
					</packagedElement>
					<packagedElement xmi:type='uml:Association' xmi:id='StateMachines-BehaviorStateMachines-A_connectionPoint_stateMachine' name='A_connectionPoint_stateMachine' visibility='public'>
						<memberEnd xmi:idref='StateMachines-BehaviorStateMachines-Pseudostate-stateMachine'/>
						<memberEnd xmi:idref='StateMachines-BehaviorStateMachines-StateMachine-connectionPoint'/>
					</packagedElement>
					<packagedElement xmi:type='uml:Association' xmi:id='StateMachines-BehaviorStateMachines-A_redefinedTransition_transition' name='A_redefinedTransition_transition' visibility='public'>
						<memberEnd xmi:idref='StateMachines-BehaviorStateMachines-A_redefinedTransition_transition-transition'/>
						<memberEnd xmi:idref='StateMachines-BehaviorStateMachines-Transition-redefinedTransition'/>
