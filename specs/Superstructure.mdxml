							<redefinedProperty xmi:idref='Classes-Kernel-BehavioralFeature-raisedException'/>
							<ownedComment xmi:type='uml:Comment' xmi:id='Classes-Kernel-Operation-raisedException-_ownedComment.0' body='References the Types representing exceptions that may be raised during an invocation of this operation.'>
								<annotatedElement xmi:idref='Classes-Kernel-Operation-raisedException'/>
							</ownedComment>
							<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='Classes-Kernel-Operation-raisedException-_upperValue' visibility='public' value='*'/>
							<lowerValue xmi:type='uml:LiteralInteger' xmi:id='Classes-Kernel-Operation-raisedException-_lowerValue' visibility='public'/>
						</ownedAttribute>
