						<ownedComment xmi:type='uml:Comment' xmi:id='Deployments-Nodes-Device-_ownedComment.0' body='A device is a physical computational resource with processing capability upon which artifacts may be deployed for execution. Devices may be complex (i.e., they may consist of other devices).'>
							<annotatedElement xmi:idref='Deployments-Nodes-Device'/>
						</ownedComment>
						<generalization xmi:type='uml:Generalization' xmi:id='Deployments-Nodes-Device-_generalization.0' general='Deployments-Nodes-Node'/>
