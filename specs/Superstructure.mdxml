					<packagedElement xmi:type='uml:Class' xmi:id='Activities-BasicActivities-ControlFlow' name='ControlFlow' visibility='public'>
						<xmi:Extension extender='MagicDraw UML 16.8'>
							<modelExtension/>
						</xmi:Extension>
						<ownedComment xmi:type='uml:Comment' xmi:id='Activities-BasicActivities-ControlFlow-_ownedComment.0' body='A control flow is an edge that starts an activity node after the previous one is finished.'>
							<annotatedElement xmi:idref='Activities-BasicActivities-ControlFlow'/>
						</ownedComment>
						<ownedRule xmi:type='uml:Constraint' xmi:id='Activities-BasicActivities-ControlFlow-object_nodes' name='object_nodes' visibility='public'>
							<constrainedElement xmi:idref='Activities-BasicActivities-ControlFlow'/>
							<ownedComment xmi:type='uml:Comment' xmi:id='Activities-BasicActivities-ControlFlow-object_nodes-_ownedComment.0' body='Control flows may not have object nodes at either end, except for object nodes with control type.'>
								<annotatedElement xmi:idref='Activities-BasicActivities-ControlFlow-object_nodes'/>
							</ownedComment>
							<specification xmi:type='uml:OpaqueExpression' xmi:id='Activities-BasicActivities-ControlFlow-object_nodes-_specification' visibility='public'>
								<body>true</body>
								<language>OCL</language>
							</specification>
						</ownedRule>
						<generalization xmi:type='uml:Generalization' xmi:id='Activities-BasicActivities-ControlFlow-_generalization.0' general='Activities-BasicActivities-ActivityEdge'/>
					</packagedElement>
					<packagedElement xmi:type='uml:Class' xmi:id='Activities-BasicActivities-ValuePin' name='ValuePin' visibility='public'>
						<xmi:Extension extender='MagicDraw UML 16.8'>
