					<packagedElement xmi:type='uml:Class' xmi:id='Actions-BasicActions-InvocationAction' name='InvocationAction' visibility='public' isAbstract='true'>
						<ownedComment xmi:type='uml:Comment' xmi:id='Actions-BasicActions-InvocationAction-_ownedComment.0' body='InvocationAction is an abstract class for the various actions that invoke behavior.'>
							<annotatedElement xmi:idref='Actions-BasicActions-InvocationAction'/>
						</ownedComment>
						<generalization xmi:type='uml:Generalization' xmi:id='Actions-BasicActions-InvocationAction-_generalization.0' general='Actions-BasicActions-Action'/>
						<ownedAttribute xmi:type='uml:Property' xmi:id='Actions-BasicActions-InvocationAction-argument' name='argument' visibility='public' isOrdered='true' aggregation='composite' type='Actions-BasicActions-InputPin' association='Actions-BasicActions-A_argument_invocationAction'>
							<subsettedProperty xmi:idref='Actions-BasicActions-Action-input'/>
							<ownedComment xmi:type='uml:Comment' xmi:id='Actions-BasicActions-InvocationAction-argument-_ownedComment.0' body='Specification of the ordered set of argument values that appears during execution.'>
								<annotatedElement xmi:idref='Actions-BasicActions-InvocationAction-argument'/>
