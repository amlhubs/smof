						<memberEnd xmi:idref='CompositeStructures-Collaborations-A_representation_classifier-classifier'/>
						<generalization xmi:type='uml:Generalization' xmi:id='CompositeStructures-Collaborations-A_representation_classifier-_generalization.0' general='CompositeStructures-Collaborations-A_collaborationUse_classifier'/>
						<ownedEnd xmi:type='uml:Property' xmi:id='CompositeStructures-Collaborations-A_representation_classifier-classifier' name='classifier' visibility='public' type='CompositeStructures-Collaborations-Classifier' association='CompositeStructures-Collaborations-A_representation_classifier'>
							<redefinedProperty xmi:idref='CompositeStructures-Collaborations-A_collaborationUse_classifier-classifier'/>
