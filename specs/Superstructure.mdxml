							<ownedComment xmi:type='uml:Comment' xmi:id='Classes-Kernel-Type-package-_ownedComment.0' body='Specifies the owning package of this classifier, if any.'>
								<annotatedElement xmi:idref='Classes-Kernel-Type-package'/>
							</ownedComment>
							<lowerValue xmi:type='uml:LiteralInteger' xmi:id='Classes-Kernel-Type-package-_lowerValue' visibility='public'/>
						</ownedAttribute>
						<ownedOperation xmi:type='uml:Operation' xmi:id='Classes-Kernel-Type-conformsTo' name='conformsTo' visibility='public' isQuery='true' bodyCondition='Classes-Kernel-Type-conformsTo-spec'>
							<xmi:Extension extender='MagicDraw UML 16.8'>
								<modelExtension/>
							</xmi:Extension>
							<ownedComment xmi:type='uml:Comment' xmi:id='Classes-Kernel-Type-conformsTo-_ownedComment.0' body='The query conformsTo() gives true for a type that conforms to another. By default, two types do not conform to each other. This query is intended to be redefined for specific conformance situations.'>
								<annotatedElement xmi:idref='Classes-Kernel-Type-conformsTo'/>
							</ownedComment>
							<ownedRule xmi:type='uml:Constraint' xmi:id='Classes-Kernel-Type-conformsTo-spec' name='spec' visibility='public'>
