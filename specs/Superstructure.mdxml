							</ownedComment>
							<specification xmi:type='uml:OpaqueExpression' xmi:id='Activities-BasicActivities-ObjectFlow-same_upper_bounds-_specification' visibility='public'>
								<body>true</body>
								<language>OCL</language>
							</specification>
