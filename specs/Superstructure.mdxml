						<generalization xmi:type='uml:Generalization' xmi:id='Classes-Kernel-BehavioralFeature-_generalization.1' general='Classes-Kernel-Namespace'/>
						<ownedAttribute xmi:type='uml:Property' xmi:id='Classes-Kernel-BehavioralFeature-ownedParameter' name='ownedParameter' visibility='public' isOrdered='true' aggregation='composite' type='Classes-Kernel-Parameter' association='Classes-Kernel-A_ownedParameter_ownerFormalParam'>
