						<memberEnd xmi:idref='AuxiliaryConstructs-Templates-ParameterableElement-templateParameter'/>
					</packagedElement>
					<packagedElement xmi:type='uml:Association' xmi:id='AuxiliaryConstructs-Templates-A_operation_templateParameter_parameteredElement' name='A_operation_templateParameter_parameteredElement' visibility='public'>
						<memberEnd xmi:idref='AuxiliaryConstructs-Templates-Operation-templateParameter'/>
						<memberEnd xmi:idref='AuxiliaryConstructs-Templates-OperationTemplateParameter-parameteredElement'/>
					</packagedElement>
					<packagedElement xmi:type='uml:Class' xmi:id='AuxiliaryConstructs-Templates-TemplateableElement' name='TemplateableElement' visibility='public' isAbstract='true'>
						<ownedComment xmi:type='uml:Comment' xmi:id='AuxiliaryConstructs-Templates-TemplateableElement-_ownedComment.0' body='A templateable element is an element that can optionally be defined as a template and bound to other templates.'>
							<annotatedElement xmi:idref='AuxiliaryConstructs-Templates-TemplateableElement'/>
						</ownedComment>
						<generalization xmi:type='uml:Generalization' xmi:id='AuxiliaryConstructs-Templates-TemplateableElement-_generalization.0' general='Classes-Kernel-Element'/>
						<ownedAttribute xmi:type='uml:Property' xmi:id='AuxiliaryConstructs-Templates-TemplateableElement-ownedTemplateSignature' name='ownedTemplateSignature' visibility='public' aggregation='composite' type='AuxiliaryConstructs-Templates-TemplateSignature' association='AuxiliaryConstructs-Templates-A_ownedTemplateSignature_template'>
							<subsettedProperty xmi:idref='Classes-Kernel-Element-ownedElement'/>
							<ownedComment xmi:type='uml:Comment' xmi:id='AuxiliaryConstructs-Templates-TemplateableElement-ownedTemplateSignature-_ownedComment.0' body='The optional template signature specifying the formal template parameters.'>
								<annotatedElement xmi:idref='AuxiliaryConstructs-Templates-TemplateableElement-ownedTemplateSignature'/>
							</ownedComment>
							<lowerValue xmi:type='uml:LiteralInteger' xmi:id='AuxiliaryConstructs-Templates-TemplateableElement-ownedTemplateSignature-_lowerValue' visibility='public'/>
						</ownedAttribute>
						<ownedAttribute xmi:type='uml:Property' xmi:id='AuxiliaryConstructs-Templates-TemplateableElement-templateBinding' name='templateBinding' visibility='public' aggregation='composite' type='AuxiliaryConstructs-Templates-TemplateBinding' association='AuxiliaryConstructs-Templates-A_templateBinding_boundElement'>
							<subsettedProperty xmi:idref='Classes-Kernel-Element-ownedElement'/>
							<subsettedProperty xmi:idref='Classes-Kernel-A_source_directedRelationship-directedRelationship'/>
							<ownedComment xmi:type='uml:Comment' xmi:id='AuxiliaryConstructs-Templates-TemplateableElement-templateBinding-_ownedComment.0' body='The optional bindings from this element to templates.'>
								<annotatedElement xmi:idref='AuxiliaryConstructs-Templates-TemplateableElement-templateBinding'/>
							</ownedComment>
							<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='AuxiliaryConstructs-Templates-TemplateableElement-templateBinding-_upperValue' visibility='public' value='*'/>
							<lowerValue xmi:type='uml:LiteralInteger' xmi:id='AuxiliaryConstructs-Templates-TemplateableElement-templateBinding-_lowerValue' visibility='public'/>
						</ownedAttribute>
						<ownedOperation xmi:type='uml:Operation' xmi:id='AuxiliaryConstructs-Templates-TemplateableElement-isTemplate' name='isTemplate' visibility='public' isQuery='true' bodyCondition='AuxiliaryConstructs-Templates-TemplateableElement-isTemplate-spec'>
							<xmi:Extension extender='MagicDraw UML 16.8'>
								<modelExtension/>
							</xmi:Extension>
							<ownedComment xmi:type='uml:Comment' xmi:id='AuxiliaryConstructs-Templates-TemplateableElement-isTemplate-_ownedComment.0' body='The query isTemplate() returns whether this templateable element is actually a template.'>
								<annotatedElement xmi:idref='AuxiliaryConstructs-Templates-TemplateableElement-isTemplate'/>
							</ownedComment>
							<ownedRule xmi:type='uml:Constraint' xmi:id='AuxiliaryConstructs-Templates-TemplateableElement-isTemplate-spec' name='spec' visibility='public'>
								<constrainedElement xmi:idref='AuxiliaryConstructs-Templates-TemplateableElement-isTemplate'/>
								<specification xmi:type='uml:OpaqueExpression' xmi:id='AuxiliaryConstructs-Templates-TemplateableElement-isTemplate-spec-_specification' visibility='public'>
									<body>result = ownedTemplateSignature-&gt;notEmpty()</body>
									<language>OCL</language>
								</specification>
							</ownedRule>
							<ownedParameter xmi:type='uml:Parameter' xmi:id='AuxiliaryConstructs-Templates-TemplateableElement-isTemplate-result' name='result' visibility='public' direction='return' effect='create'>
								<type xmi:type='uml:PrimitiveType' href='http://schema.omg.org/spec/UML/2.3/uml.xml#Boolean'>
									<xmi:Extension extender='MagicDraw UML 16.8'>
										<referenceExtension referentPath='PrimitiveTypes::Boolean' referentType='PrimitiveType'/>
									</xmi:Extension>
								</type>
							</ownedParameter>
						</ownedOperation>
						<ownedOperation xmi:type='uml:Operation' xmi:id='AuxiliaryConstructs-Templates-TemplateableElement-parameterableElements' name='parameterableElements' visibility='public' isQuery='true' bodyCondition='AuxiliaryConstructs-Templates-TemplateableElement-parameterableElements-spec'>
							<xmi:Extension extender='MagicDraw UML 16.8'>
								<modelExtension/>
							</xmi:Extension>
							<ownedComment xmi:type='uml:Comment' xmi:id='AuxiliaryConstructs-Templates-TemplateableElement-parameterableElements-_ownedComment.0' body='The query parameterableElements() returns the set of elements that may be used as the parametered elements for a template parameter of this templateable element. By default, this set includes all the owned elements. Subclasses may override this operation if they choose to restrict the set of parameterable elements.'>
								<annotatedElement xmi:idref='AuxiliaryConstructs-Templates-TemplateableElement-parameterableElements'/>
							</ownedComment>
							<ownedRule xmi:type='uml:Constraint' xmi:id='AuxiliaryConstructs-Templates-TemplateableElement-parameterableElements-spec' name='spec' visibility='public'>
								<constrainedElement xmi:idref='AuxiliaryConstructs-Templates-TemplateableElement-parameterableElements'/>
								<specification xmi:type='uml:OpaqueExpression' xmi:id='AuxiliaryConstructs-Templates-TemplateableElement-parameterableElements-spec-_specification' visibility='public'>
									<body>result = allOwnedElements-&gt;select(oclIsKindOf(ParameterableElement))</body>
									<language>OCL</language>
								</specification>
							</ownedRule>
							<ownedParameter xmi:type='uml:Parameter' xmi:id='AuxiliaryConstructs-Templates-TemplateableElement-parameterableElements-result' name='result' visibility='public' direction='return' effect='create' type='AuxiliaryConstructs-Templates-ParameterableElement'>
								<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='AuxiliaryConstructs-Templates-TemplateableElement-parameterableElements-result-_upperValue' visibility='public' value='*'/>
								<lowerValue xmi:type='uml:LiteralInteger' xmi:id='AuxiliaryConstructs-Templates-TemplateableElement-parameterableElements-result-_lowerValue' visibility='public'/>
							</ownedParameter>
						</ownedOperation>
					</packagedElement>
					<packagedElement xmi:type='uml:Association' xmi:id='AuxiliaryConstructs-Templates-A_ownedActual_templateParameterSubstitution' name='A_ownedActual_templateParameterSubstitution' visibility='public'>
						<memberEnd xmi:idref='AuxiliaryConstructs-Templates-A_ownedActual_templateParameterSubstitution-templateParameterSubstitution'/>
						<memberEnd xmi:idref='AuxiliaryConstructs-Templates-TemplateParameterSubstitution-ownedActual'/>
						<generalization xmi:type='uml:Generalization' xmi:id='AuxiliaryConstructs-Templates-A_ownedActual_templateParameterSubstitution-_generalization.0' general='AuxiliaryConstructs-Templates-A_actual_templateParameterSubstitution'/>
						<ownedEnd xmi:type='uml:Property' xmi:id='AuxiliaryConstructs-Templates-A_ownedActual_templateParameterSubstitution-templateParameterSubstitution' name='templateParameterSubstitution' visibility='public' type='AuxiliaryConstructs-Templates-TemplateParameterSubstitution' association='AuxiliaryConstructs-Templates-A_ownedActual_templateParameterSubstitution'>
							<redefinedProperty xmi:idref='AuxiliaryConstructs-Templates-A_actual_templateParameterSubstitution-templateParameterSubstitution'/>
							<subsettedProperty xmi:idref='Classes-Kernel-Element-owner'/>
							<lowerValue xmi:type='uml:LiteralInteger' xmi:id='AuxiliaryConstructs-Templates-A_ownedActual_templateParameterSubstitution-templateParameterSubstitution-_lowerValue' visibility='public'/>
						</ownedEnd>
					</packagedElement>
					<packagedElement xmi:type='uml:Class' xmi:id='AuxiliaryConstructs-Templates-Package' name='Package' visibility='public'>
						<ownedComment xmi:type='uml:Comment' xmi:id='AuxiliaryConstructs-Templates-Package-_ownedComment.0' body='Package specializes TemplateableElement and PackageableElement specializes ParameterableElement to specify that a package can be used as a template and a PackageableElement as a template parameter.'>
							<annotatedElement xmi:idref='AuxiliaryConstructs-Templates-Package'/>
						</ownedComment>
						<generalization xmi:type='uml:Generalization' xmi:id='AuxiliaryConstructs-Templates-Package-_generalization.0' general='AuxiliaryConstructs-Templates-TemplateableElement'/>
					</packagedElement>
					<packagedElement xmi:type='uml:Class' xmi:id='AuxiliaryConstructs-Templates-ValueSpecification' name='ValueSpecification' visibility='public' isAbstract='true'>
						<ownedComment xmi:type='uml:Comment' xmi:id='AuxiliaryConstructs-Templates-ValueSpecification-_ownedComment.0' body='ValueSpecification specializes ParameterableElement to specify that a value specification can be exposed as a formal template parameter, and provided as an actual parameter in a binding of a template.'>
							<annotatedElement xmi:idref='AuxiliaryConstructs-Templates-ValueSpecification'/>
						</ownedComment>
						<generalization xmi:type='uml:Generalization' xmi:id='AuxiliaryConstructs-Templates-ValueSpecification-_generalization.0' general='AuxiliaryConstructs-Templates-ParameterableElement'/>
						<ownedOperation xmi:type='uml:Operation' xmi:id='AuxiliaryConstructs-Templates-ValueSpecification-isCompatibleWith' name='isCompatibleWith' visibility='public' isQuery='true' bodyCondition='AuxiliaryConstructs-Templates-ValueSpecification-isCompatibleWith-spec'>
							<xmi:Extension extender='MagicDraw UML 16.8'>
								<modelExtension/>
							</xmi:Extension>
							<redefinedOperation xmi:idref='AuxiliaryConstructs-Templates-ParameterableElement-isCompatibleWith'/>
							<ownedComment xmi:type='uml:Comment' xmi:id='AuxiliaryConstructs-Templates-ValueSpecification-isCompatibleWith-_ownedComment.0' body='The query isCompatibleWith() determines if this parameterable element is compatible with the specified parameterable element. By default parameterable element P is compatible with parameterable element Q if the kind of P is the same or a subtype as the kind of Q. In addition, for ValueSpecification, the type must be conformant with the type of the specified parameterable element.'>
								<annotatedElement xmi:idref='AuxiliaryConstructs-Templates-ValueSpecification-isCompatibleWith'/>
							</ownedComment>
							<ownedRule xmi:type='uml:Constraint' xmi:id='AuxiliaryConstructs-Templates-ValueSpecification-isCompatibleWith-spec' name='spec' visibility='public'>
								<constrainedElement xmi:idref='AuxiliaryConstructs-Templates-ValueSpecification-isCompatibleWith'/>
								<specification xmi:type='uml:OpaqueExpression' xmi:id='AuxiliaryConstructs-Templates-ValueSpecification-isCompatibleWith-spec-_specification' visibility='public'>
									<body>result = p-&gt;oclIsKindOf(self.oclType) and self.type.conformsTo(p.oclAsType(TypedElement).type)</body>
									<language>OCL</language>
								</specification>
							</ownedRule>
							<ownedParameter xmi:type='uml:Parameter' xmi:id='AuxiliaryConstructs-Templates-ValueSpecification-isCompatibleWith-result' name='result' visibility='public' direction='return' effect='create'>
								<type xmi:type='uml:PrimitiveType' href='http://schema.omg.org/spec/UML/2.3/uml.xml#Boolean'>
									<xmi:Extension extender='MagicDraw UML 16.8'>
										<referenceExtension referentPath='PrimitiveTypes::Boolean' referentType='PrimitiveType'/>
									</xmi:Extension>
								</type>
							</ownedParameter>
							<ownedParameter xmi:type='uml:Parameter' xmi:id='AuxiliaryConstructs-Templates-ValueSpecification-isCompatibleWith-p' name='p' visibility='public' effect='create' type='AuxiliaryConstructs-Templates-ParameterableElement'/>
						</ownedOperation>
					</packagedElement>
					<packagedElement xmi:type='uml:Class' xmi:id='AuxiliaryConstructs-Templates-TemplateSignature' name='TemplateSignature' visibility='public'>
						<xmi:Extension extender='MagicDraw UML 16.8'>
							<modelExtension/>
						</xmi:Extension>
						<ownedComment xmi:type='uml:Comment' xmi:id='AuxiliaryConstructs-Templates-TemplateSignature-_ownedComment.0' body='A template signature bundles the set of formal template parameters for a templated element.'>
							<annotatedElement xmi:idref='AuxiliaryConstructs-Templates-TemplateSignature'/>
						</ownedComment>
						<ownedRule xmi:type='uml:Constraint' xmi:id='AuxiliaryConstructs-Templates-TemplateSignature-own_elements' name='own_elements' visibility='public'>
							<constrainedElement xmi:idref='AuxiliaryConstructs-Templates-TemplateSignature'/>
							<ownedComment xmi:type='uml:Comment' xmi:id='AuxiliaryConstructs-Templates-TemplateSignature-own_elements-_ownedComment.0' body='Parameters must own the elements they parameter or those elements must be owned by the element being templated.'>
								<annotatedElement xmi:idref='AuxiliaryConstructs-Templates-TemplateSignature-own_elements'/>
							</ownedComment>
							<specification xmi:type='uml:OpaqueExpression' xmi:id='AuxiliaryConstructs-Templates-TemplateSignature-own_elements-_specification' visibility='public'>
								<body>templatedElement.ownedElement-&gt;includesAll(parameter.parameteredElement - parameter.ownedParameteredElement)</body>
								<language>OCL</language>
							</specification>
						</ownedRule>
						<generalization xmi:type='uml:Generalization' xmi:id='AuxiliaryConstructs-Templates-TemplateSignature-_generalization.0' general='Classes-Kernel-Element'/>
						<ownedAttribute xmi:type='uml:Property' xmi:id='AuxiliaryConstructs-Templates-TemplateSignature-ownedParameter' name='ownedParameter' visibility='public' isOrdered='true' aggregation='composite' type='AuxiliaryConstructs-Templates-TemplateParameter' association='AuxiliaryConstructs-Templates-A_ownedParameter_signature'>
							<subsettedProperty xmi:idref='Classes-Kernel-Element-ownedElement'/>
							<subsettedProperty xmi:idref='AuxiliaryConstructs-Templates-TemplateSignature-parameter'/>
							<ownedComment xmi:type='uml:Comment' xmi:id='AuxiliaryConstructs-Templates-TemplateSignature-ownedParameter-_ownedComment.0' body='The formal template parameters that are owned by this template signature.'>
								<annotatedElement xmi:idref='AuxiliaryConstructs-Templates-TemplateSignature-ownedParameter'/>
							</ownedComment>
							<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='AuxiliaryConstructs-Templates-TemplateSignature-ownedParameter-_upperValue' visibility='public' value='*'/>
							<lowerValue xmi:type='uml:LiteralInteger' xmi:id='AuxiliaryConstructs-Templates-TemplateSignature-ownedParameter-_lowerValue' visibility='public'/>
						</ownedAttribute>
						<ownedAttribute xmi:type='uml:Property' xmi:id='AuxiliaryConstructs-Templates-TemplateSignature-parameter' name='parameter' visibility='public' isOrdered='true' type='AuxiliaryConstructs-Templates-TemplateParameter' association='AuxiliaryConstructs-Templates-A_parameter_templateSignature'>
							<ownedComment xmi:type='uml:Comment' xmi:id='AuxiliaryConstructs-Templates-TemplateSignature-parameter-_ownedComment.0' body='The ordered set of all formal template parameters for this template signature.'>
								<annotatedElement xmi:idref='AuxiliaryConstructs-Templates-TemplateSignature-parameter'/>
							</ownedComment>
							<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='AuxiliaryConstructs-Templates-TemplateSignature-parameter-_upperValue' visibility='public' value='*'/>
						</ownedAttribute>
						<ownedAttribute xmi:type='uml:Property' xmi:id='AuxiliaryConstructs-Templates-TemplateSignature-template' name='template' visibility='public' type='AuxiliaryConstructs-Templates-TemplateableElement' association='AuxiliaryConstructs-Templates-A_ownedTemplateSignature_template'>
							<subsettedProperty xmi:idref='Classes-Kernel-Element-owner'/>
							<ownedComment xmi:type='uml:Comment' xmi:id='AuxiliaryConstructs-Templates-TemplateSignature-template-_ownedComment.0' body='The element that owns this template signature.'>
								<annotatedElement xmi:idref='AuxiliaryConstructs-Templates-TemplateSignature-template'/>
							</ownedComment>
						</ownedAttribute>
					</packagedElement>
					<packagedElement xmi:type='uml:Association' xmi:id='AuxiliaryConstructs-Templates-A_ownedParameter_signature' name='A_ownedParameter_signature' visibility='public'>
						<memberEnd xmi:idref='AuxiliaryConstructs-Templates-TemplateParameter-signature'/>
						<memberEnd xmi:idref='AuxiliaryConstructs-Templates-TemplateSignature-ownedParameter'/>
					</packagedElement>
					<packagedElement xmi:type='uml:Class' xmi:id='AuxiliaryConstructs-Templates-StringExpression' name='StringExpression' visibility='public'>
						<xmi:Extension extender='MagicDraw UML 16.8'>
							<modelExtension/>
						</xmi:Extension>
						<ownedComment xmi:type='uml:Comment' xmi:id='AuxiliaryConstructs-Templates-StringExpression-_ownedComment.0' body='An expression that specifies a string value that is derived by concatenating a set of sub string expressions, some of which might be template parameters.'>
							<annotatedElement xmi:idref='AuxiliaryConstructs-Templates-StringExpression'/>
						</ownedComment>
						<ownedRule xmi:type='uml:Constraint' xmi:id='AuxiliaryConstructs-Templates-StringExpression-operands' name='operands' visibility='public'>
							<constrainedElement xmi:idref='AuxiliaryConstructs-Templates-StringExpression'/>
							<ownedComment xmi:type='uml:Comment' xmi:id='AuxiliaryConstructs-Templates-StringExpression-operands-_ownedComment.0' body='All the operands of a StringExpression must be LiteralStrings'>
								<annotatedElement xmi:idref='AuxiliaryConstructs-Templates-StringExpression-operands'/>
							</ownedComment>
							<specification xmi:type='uml:OpaqueExpression' xmi:id='AuxiliaryConstructs-Templates-StringExpression-operands-_specification' visibility='public'>
								<body>operand-&gt;forAll (op | op.oclIsKindOf (LiteralString))</body>
								<language>OCL</language>
							</specification>
						</ownedRule>
						<ownedRule xmi:type='uml:Constraint' xmi:id='AuxiliaryConstructs-Templates-StringExpression-subexpressions' name='subexpressions' visibility='public'>
							<constrainedElement xmi:idref='AuxiliaryConstructs-Templates-StringExpression'/>
							<ownedComment xmi:type='uml:Comment' xmi:id='AuxiliaryConstructs-Templates-StringExpression-subexpressions-_ownedComment.0' body='If a StringExpression has sub-expressions, it cannot have operands and vice versa (this avoids the problem of having to define a collating sequence between operands and subexpressions).'>
								<annotatedElement xmi:idref='AuxiliaryConstructs-Templates-StringExpression-subexpressions'/>
							</ownedComment>
							<specification xmi:type='uml:OpaqueExpression' xmi:id='AuxiliaryConstructs-Templates-StringExpression-subexpressions-_specification' visibility='public'>
								<body>if subExpression-&gt;notEmpty() then operand-&gt;isEmpty() else operand-&gt;notEmpty()</body>
								<language>OCL</language>
							</specification>
						</ownedRule>
						<generalization xmi:type='uml:Generalization' xmi:id='AuxiliaryConstructs-Templates-StringExpression-_generalization.0' general='Classes-Kernel-Expression'/>
						<generalization xmi:type='uml:Generalization' xmi:id='AuxiliaryConstructs-Templates-StringExpression-_generalization.1' general='AuxiliaryConstructs-Templates-TemplateableElement'/>
						<ownedAttribute xmi:type='uml:Property' xmi:id='AuxiliaryConstructs-Templates-StringExpression-owningExpression' name='owningExpression' visibility='public' type='AuxiliaryConstructs-Templates-StringExpression' association='AuxiliaryConstructs-Templates-A_subExpression_owningExpression'>
							<subsettedProperty xmi:idref='Classes-Kernel-Element-owner'/>
							<ownedComment xmi:type='uml:Comment' xmi:id='AuxiliaryConstructs-Templates-StringExpression-owningExpression-_ownedComment.0' body='The string expression of which this expression is a substring.'>
								<annotatedElement xmi:idref='AuxiliaryConstructs-Templates-StringExpression-owningExpression'/>
							</ownedComment>
							<lowerValue xmi:type='uml:LiteralInteger' xmi:id='AuxiliaryConstructs-Templates-StringExpression-owningExpression-_lowerValue' visibility='public'/>
						</ownedAttribute>
						<ownedAttribute xmi:type='uml:Property' xmi:id='AuxiliaryConstructs-Templates-StringExpression-subExpression' name='subExpression' visibility='public' aggregation='composite' type='AuxiliaryConstructs-Templates-StringExpression' association='AuxiliaryConstructs-Templates-A_subExpression_owningExpression'>
							<subsettedProperty xmi:idref='Classes-Kernel-Element-ownedElement'/>
							<ownedComment xmi:type='uml:Comment' xmi:id='AuxiliaryConstructs-Templates-StringExpression-subExpression-_ownedComment.0' body='The StringExpressions that constitute this StringExpression.'>
								<annotatedElement xmi:idref='AuxiliaryConstructs-Templates-StringExpression-subExpression'/>
							</ownedComment>
							<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='AuxiliaryConstructs-Templates-StringExpression-subExpression-_upperValue' visibility='public' value='*'/>
							<lowerValue xmi:type='uml:LiteralInteger' xmi:id='AuxiliaryConstructs-Templates-StringExpression-subExpression-_lowerValue' visibility='public'/>
						</ownedAttribute>
						<ownedOperation xmi:type='uml:Operation' xmi:id='AuxiliaryConstructs-Templates-StringExpression-stringValue' name='stringValue' visibility='public' isQuery='true' bodyCondition='AuxiliaryConstructs-Templates-StringExpression-stringValue-spec'>
							<xmi:Extension extender='MagicDraw UML 16.8'>
								<modelExtension/>
							</xmi:Extension>
							<redefinedOperation xmi:idref='Classes-Kernel-ValueSpecification-stringValue'/>
							<ownedComment xmi:type='uml:Comment' xmi:id='AuxiliaryConstructs-Templates-StringExpression-stringValue-_ownedComment.0' body='The query stringValue() returns the string that concatenates, in order, all the component string literals of all the subexpressions that are part of the StringExpression.'>
								<annotatedElement xmi:idref='AuxiliaryConstructs-Templates-StringExpression-stringValue'/>
							</ownedComment>
							<ownedRule xmi:type='uml:Constraint' xmi:id='AuxiliaryConstructs-Templates-StringExpression-stringValue-spec' name='spec' visibility='public'>
								<constrainedElement xmi:idref='AuxiliaryConstructs-Templates-StringExpression-stringValue'/>
								<specification xmi:type='uml:OpaqueExpression' xmi:id='AuxiliaryConstructs-Templates-StringExpression-stringValue-spec-_specification' visibility='public'>
									<body>result = if subExpression-&gt;notEmpty()
then subExpression-&gt;iterate(se; stringValue = | stringValue.concat(se.stringValue()))
else operand-&gt;iterate()(op; stringValue =  | stringValue.concat(op.value))</body>
									<language>OCL</language>
								</specification>
							</ownedRule>
							<ownedParameter xmi:type='uml:Parameter' xmi:id='AuxiliaryConstructs-Templates-StringExpression-stringValue-result' name='result' visibility='public' direction='return' effect='create'>
								<type xmi:type='uml:PrimitiveType' href='http://schema.omg.org/spec/UML/2.3/uml.xml#String'>
									<xmi:Extension extender='MagicDraw UML 16.8'>
										<referenceExtension referentPath='PrimitiveTypes::String' referentType='PrimitiveType'/>
									</xmi:Extension>
								</type>
							</ownedParameter>
						</ownedOperation>
					</packagedElement>
					<packagedElement xmi:type='uml:Association' xmi:id='AuxiliaryConstructs-Templates-A_nameExpression_namedElement' name='A_nameExpression_namedElement' visibility='public'>
						<memberEnd xmi:idref='AuxiliaryConstructs-Templates-NamedElement-nameExpression'/>
						<memberEnd xmi:idref='AuxiliaryConstructs-Templates-A_nameExpression_namedElement-namedElement'/>
						<ownedEnd xmi:type='uml:Property' xmi:id='AuxiliaryConstructs-Templates-A_nameExpression_namedElement-namedElement' name='namedElement' visibility='public' type='AuxiliaryConstructs-Templates-NamedElement' association='AuxiliaryConstructs-Templates-A_nameExpression_namedElement'>
							<subsettedProperty xmi:idref='Classes-Kernel-Element-owner'/>
							<lowerValue xmi:type='uml:LiteralInteger' xmi:id='AuxiliaryConstructs-Templates-A_nameExpression_namedElement-namedElement-_lowerValue' visibility='public'/>
						</ownedEnd>
					</packagedElement>
					<packagedElement xmi:type='uml:Association' xmi:id='AuxiliaryConstructs-Templates-A_subExpression_owningExpression' name='A_subExpression_owningExpression' visibility='public'>
						<memberEnd xmi:idref='AuxiliaryConstructs-Templates-StringExpression-owningExpression'/>
						<memberEnd xmi:idref='AuxiliaryConstructs-Templates-StringExpression-subExpression'/>
					</packagedElement>
					<packagedElement xmi:type='uml:Association' xmi:id='AuxiliaryConstructs-Templates-A_ownedParameteredElement_owningTemplateParameter' name='A_ownedParameteredElement_owningTemplateParameter' visibility='public'>
						<memberEnd xmi:idref='AuxiliaryConstructs-Templates-TemplateParameter-ownedParameteredElement'/>
						<memberEnd xmi:idref='AuxiliaryConstructs-Templates-ParameterableElement-owningTemplateParameter'/>
					</packagedElement>
					<packagedElement xmi:type='uml:Association' xmi:id='AuxiliaryConstructs-Templates-A_connectableElement_templateParameter_parameteredElement' name='A_connectableElement_templateParameter_parameteredElement' visibility='public'>
						<memberEnd xmi:idref='AuxiliaryConstructs-Templates-ConnectableElement-templateParameter'/>
						<memberEnd xmi:idref='AuxiliaryConstructs-Templates-ConnectableElementTemplateParameter-parameteredElement'/>
					</packagedElement>
					<packagedElement xmi:type='uml:Class' xmi:id='AuxiliaryConstructs-Templates-TemplateBinding' name='TemplateBinding' visibility='public'>
						<xmi:Extension extender='MagicDraw UML 16.8'>
							<modelExtension/>
						</xmi:Extension>
						<ownedComment xmi:type='uml:Comment' xmi:id='AuxiliaryConstructs-Templates-TemplateBinding-_ownedComment.0' body='A template binding represents a relationship between a templateable element and a template. A template binding specifies the substitutions of actual parameters for the formal parameters of the template.'>
							<annotatedElement xmi:idref='AuxiliaryConstructs-Templates-TemplateBinding'/>
						</ownedComment>
						<ownedRule xmi:type='uml:Constraint' xmi:id='AuxiliaryConstructs-Templates-TemplateBinding-parameter_substitution_formal' name='parameter_substitution_formal' visibility='public'>
							<constrainedElement xmi:idref='AuxiliaryConstructs-Templates-TemplateBinding'/>
							<ownedComment xmi:type='uml:Comment' xmi:id='AuxiliaryConstructs-Templates-TemplateBinding-parameter_substitution_formal-_ownedComment.0' body='Each parameter substitution must refer to a formal template parameter of the target template signature.'>
								<annotatedElement xmi:idref='AuxiliaryConstructs-Templates-TemplateBinding-parameter_substitution_formal'/>
							</ownedComment>
							<specification xmi:type='uml:OpaqueExpression' xmi:id='AuxiliaryConstructs-Templates-TemplateBinding-parameter_substitution_formal-_specification' visibility='public'>
								<body>parameterSubstitution-&gt;forAll(b | template.parameter-&gt;includes(b.formal))</body>
								<language>OCL</language>
							</specification>
						</ownedRule>
						<ownedRule xmi:type='uml:Constraint' xmi:id='AuxiliaryConstructs-Templates-TemplateBinding-one_parameter_substitution' name='one_parameter_substitution' visibility='public'>
							<constrainedElement xmi:idref='AuxiliaryConstructs-Templates-TemplateBinding'/>
							<ownedComment xmi:type='uml:Comment' xmi:id='AuxiliaryConstructs-Templates-TemplateBinding-one_parameter_substitution-_ownedComment.0' body='A binding contains at most one parameter substitution for each formal template parameter of the target template signature.'>
								<annotatedElement xmi:idref='AuxiliaryConstructs-Templates-TemplateBinding-one_parameter_substitution'/>
							</ownedComment>
							<specification xmi:type='uml:OpaqueExpression' xmi:id='AuxiliaryConstructs-Templates-TemplateBinding-one_parameter_substitution-_specification' visibility='public'>
								<body>template.parameter-&gt;forAll(p | parameterSubstitution-&gt;select(b | b.formal = p)-&gt;size() &lt;= 1)</body>
								<language>OCL</language>
							</specification>
						</ownedRule>
						<generalization xmi:type='uml:Generalization' xmi:id='AuxiliaryConstructs-Templates-TemplateBinding-_generalization.0' general='Classes-Kernel-DirectedRelationship'/>
						<ownedAttribute xmi:type='uml:Property' xmi:id='AuxiliaryConstructs-Templates-TemplateBinding-boundElement' name='boundElement' visibility='public' type='AuxiliaryConstructs-Templates-TemplateableElement' association='AuxiliaryConstructs-Templates-A_templateBinding_boundElement'>
							<subsettedProperty xmi:idref='Classes-Kernel-DirectedRelationship-source'/>
							<subsettedProperty xmi:idref='Classes-Kernel-Element-owner'/>
							<ownedComment xmi:type='uml:Comment' xmi:id='AuxiliaryConstructs-Templates-TemplateBinding-boundElement-_ownedComment.0' body='The element that is bound by this binding.'>
								<annotatedElement xmi:idref='AuxiliaryConstructs-Templates-TemplateBinding-boundElement'/>
							</ownedComment>
						</ownedAttribute>
						<ownedAttribute xmi:type='uml:Property' xmi:id='AuxiliaryConstructs-Templates-TemplateBinding-parameterSubstitution' name='parameterSubstitution' visibility='public' aggregation='composite' type='AuxiliaryConstructs-Templates-TemplateParameterSubstitution' association='AuxiliaryConstructs-Templates-A_parameterSubstitution_templateBinding'>
							<subsettedProperty xmi:idref='Classes-Kernel-Element-ownedElement'/>
							<ownedComment xmi:type='uml:Comment' xmi:id='AuxiliaryConstructs-Templates-TemplateBinding-parameterSubstitution-_ownedComment.0' body='The parameter substitutions owned by this template binding.'>
								<annotatedElement xmi:idref='AuxiliaryConstructs-Templates-TemplateBinding-parameterSubstitution'/>
							</ownedComment>
							<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='AuxiliaryConstructs-Templates-TemplateBinding-parameterSubstitution-_upperValue' visibility='public' value='*'/>
							<lowerValue xmi:type='uml:LiteralInteger' xmi:id='AuxiliaryConstructs-Templates-TemplateBinding-parameterSubstitution-_lowerValue' visibility='public'/>
						</ownedAttribute>
						<ownedAttribute xmi:type='uml:Property' xmi:id='AuxiliaryConstructs-Templates-TemplateBinding-signature' name='signature' visibility='public' type='AuxiliaryConstructs-Templates-TemplateSignature' association='AuxiliaryConstructs-Templates-A_signature_templateBinding'>
							<subsettedProperty xmi:idref='Classes-Kernel-DirectedRelationship-target'/>
							<ownedComment xmi:type='uml:Comment' xmi:id='AuxiliaryConstructs-Templates-TemplateBinding-signature-_ownedComment.0' body='The template signature for the template that is the target of the binding.'>
								<annotatedElement xmi:idref='AuxiliaryConstructs-Templates-TemplateBinding-signature'/>
							</ownedComment>
						</ownedAttribute>
					</packagedElement>
					<packagedElement xmi:type='uml:Association' xmi:id='AuxiliaryConstructs-Templates-A_inheritedParameter_redefinableTemplateSignature' name='A_inheritedParameter_redefinableTemplateSignature' visibility='public' isDerived='true'>
						<memberEnd xmi:idref='AuxiliaryConstructs-Templates-A_inheritedParameter_redefinableTemplateSignature-redefinableTemplateSignature'/>
						<memberEnd xmi:idref='AuxiliaryConstructs-Templates-RedefinableTemplateSignature-inheritedParameter'/>
						<ownedEnd xmi:type='uml:Property' xmi:id='AuxiliaryConstructs-Templates-A_inheritedParameter_redefinableTemplateSignature-redefinableTemplateSignature' name='redefinableTemplateSignature' visibility='public' type='AuxiliaryConstructs-Templates-RedefinableTemplateSignature' association='AuxiliaryConstructs-Templates-A_inheritedParameter_redefinableTemplateSignature'>
							<subsettedProperty xmi:idref='AuxiliaryConstructs-Templates-A_parameter_templateSignature-templateSignature'/>
							<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='AuxiliaryConstructs-Templates-A_inheritedParameter_redefinableTemplateSignature-redefinableTemplateSignature-_upperValue' visibility='public' value='*'/>
							<lowerValue xmi:type='uml:LiteralInteger' xmi:id='AuxiliaryConstructs-Templates-A_inheritedParameter_redefinableTemplateSignature-redefinableTemplateSignature-_lowerValue' visibility='public'/>
						</ownedEnd>
					</packagedElement>
					<packagedElement xmi:type='uml:Class' xmi:id='AuxiliaryConstructs-Templates-Property' name='Property' visibility='public'>
						<xmi:Extension extender='MagicDraw UML 16.8'>
							<modelExtension/>
						</xmi:Extension>
						<ownedComment xmi:type='uml:Comment' xmi:id='AuxiliaryConstructs-Templates-Property-_ownedComment.0' body='Property specializes ParameterableElement to specify that a property can be exposed as a formal template parameter, and provided as an actual parameter in a binding of a template.'>
							<annotatedElement xmi:idref='AuxiliaryConstructs-Templates-Property'/>
						</ownedComment>
						<ownedRule xmi:type='uml:Constraint' xmi:id='AuxiliaryConstructs-Templates-Property-binding_to_attribute' name='binding_to_attribute' visibility='public'>
							<constrainedElement xmi:idref='AuxiliaryConstructs-Templates-Property'/>
							<ownedComment xmi:type='uml:Comment' xmi:id='AuxiliaryConstructs-Templates-Property-binding_to_attribute-_ownedComment.0' body='A binding of a property template parameter representing an attribute must be to an attribute.'>
								<annotatedElement xmi:idref='AuxiliaryConstructs-Templates-Property-binding_to_attribute'/>
							</ownedComment>
							<specification xmi:type='uml:OpaqueExpression' xmi:id='AuxiliaryConstructs-Templates-Property-binding_to_attribute-_specification' visibility='public'>
								<body>(isAttribute(self) and (templateParameterSubstitution-&gt;notEmpty())
  implies (templateParameterSubstitution-&gt;forAll(ts | isAttribute(ts.formal)))</body>
								<language>OCL</language>
							</specification>
						</ownedRule>
						<generalization xmi:type='uml:Generalization' xmi:id='AuxiliaryConstructs-Templates-Property-_generalization.0' general='AuxiliaryConstructs-Templates-ParameterableElement'/>
						<ownedOperation xmi:type='uml:Operation' xmi:id='AuxiliaryConstructs-Templates-Property-isCompatibleWith' name='isCompatibleWith' visibility='public' isQuery='true' bodyCondition='AuxiliaryConstructs-Templates-Property-isCompatibleWith-spec'>
							<xmi:Extension extender='MagicDraw UML 16.8'>
								<modelExtension/>
							</xmi:Extension>
							<redefinedOperation xmi:idref='AuxiliaryConstructs-Templates-ParameterableElement-isCompatibleWith'/>
							<ownedComment xmi:type='uml:Comment' xmi:id='AuxiliaryConstructs-Templates-Property-isCompatibleWith-_ownedComment.0' body='The query isCompatibleWith() determines if this parameterable element is compatible with the specified parameterable element. By default parameterable element P is compatible with parameterable element Q if the kind of P is the same or a subtype as the kind of Q. In addition, for properties, the type must be conformant with the type of the specified parameterable element.'>
								<annotatedElement xmi:idref='AuxiliaryConstructs-Templates-Property-isCompatibleWith'/>
							</ownedComment>
							<ownedRule xmi:type='uml:Constraint' xmi:id='AuxiliaryConstructs-Templates-Property-isCompatibleWith-spec' name='spec' visibility='public'>
								<constrainedElement xmi:idref='AuxiliaryConstructs-Templates-Property-isCompatibleWith'/>
								<specification xmi:type='uml:OpaqueExpression' xmi:id='AuxiliaryConstructs-Templates-Property-isCompatibleWith-spec-_specification' visibility='public'>
									<body>result = p-&gt;oclIsKindOf(self.oclType) and self.type.conformsTo(p.oclAsType(TypedElement).type)</body>
									<language>OCL</language>
								</specification>
							</ownedRule>
							<ownedParameter xmi:type='uml:Parameter' xmi:id='AuxiliaryConstructs-Templates-Property-isCompatibleWith-result' name='result' visibility='public' direction='return' effect='create'>
								<type xmi:type='uml:PrimitiveType' href='http://schema.omg.org/spec/UML/2.3/uml.xml#Boolean'>
									<xmi:Extension extender='MagicDraw UML 16.8'>
										<referenceExtension referentPath='PrimitiveTypes::Boolean' referentType='PrimitiveType'/>
									</xmi:Extension>
								</type>
							</ownedParameter>
							<ownedParameter xmi:type='uml:Parameter' xmi:id='AuxiliaryConstructs-Templates-Property-isCompatibleWith-p' name='p' visibility='public' effect='create' type='AuxiliaryConstructs-Templates-ParameterableElement'/>
						</ownedOperation>
					</packagedElement>
					<packagedElement xmi:type='uml:Association' xmi:id='AuxiliaryConstructs-Templates-A_actual_templateParameterSubstitution' name='A_actual_templateParameterSubstitution' visibility='public'>
						<memberEnd xmi:idref='AuxiliaryConstructs-Templates-TemplateParameterSubstitution-actual'/>
						<memberEnd xmi:idref='AuxiliaryConstructs-Templates-A_actual_templateParameterSubstitution-templateParameterSubstitution'/>
						<ownedEnd xmi:type='uml:Property' xmi:id='AuxiliaryConstructs-Templates-A_actual_templateParameterSubstitution-templateParameterSubstitution' name='templateParameterSubstitution' visibility='public' type='AuxiliaryConstructs-Templates-TemplateParameterSubstitution' association='AuxiliaryConstructs-Templates-A_actual_templateParameterSubstitution'>
							<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='AuxiliaryConstructs-Templates-A_actual_templateParameterSubstitution-templateParameterSubstitution-_upperValue' visibility='public' value='*'/>
							<lowerValue xmi:type='uml:LiteralInteger' xmi:id='AuxiliaryConstructs-Templates-A_actual_templateParameterSubstitution-templateParameterSubstitution-_lowerValue' visibility='public'/>
						</ownedEnd>
					</packagedElement>
					<packagedElement xmi:type='uml:Class' xmi:id='AuxiliaryConstructs-Templates-ConnectableElementTemplateParameter' name='ConnectableElementTemplateParameter' visibility='public'>
						<ownedComment xmi:type='uml:Comment' xmi:id='AuxiliaryConstructs-Templates-ConnectableElementTemplateParameter-_ownedComment.0' body='A connectable element template parameter exposes a connectable element as a formal parameter for a template.'>
							<annotatedElement xmi:idref='AuxiliaryConstructs-Templates-ConnectableElementTemplateParameter'/>
						</ownedComment>
						<generalization xmi:type='uml:Generalization' xmi:id='AuxiliaryConstructs-Templates-ConnectableElementTemplateParameter-_generalization.0' general='AuxiliaryConstructs-Templates-TemplateParameter'/>
						<ownedAttribute xmi:type='uml:Property' xmi:id='AuxiliaryConstructs-Templates-ConnectableElementTemplateParameter-parameteredElement' name='parameteredElement' visibility='public' type='AuxiliaryConstructs-Templates-ConnectableElement' association='AuxiliaryConstructs-Templates-A_connectableElement_templateParameter_parameteredElement'>
							<redefinedProperty xmi:idref='AuxiliaryConstructs-Templates-TemplateParameter-parameteredElement'/>
							<ownedComment xmi:type='uml:Comment' xmi:id='AuxiliaryConstructs-Templates-ConnectableElementTemplateParameter-parameteredElement-_ownedComment.0' body='The ConnectableElement for this template parameter.'>
								<annotatedElement xmi:idref='AuxiliaryConstructs-Templates-ConnectableElementTemplateParameter-parameteredElement'/>
							</ownedComment>
						</ownedAttribute>
					</packagedElement>
					<packagedElement xmi:type='uml:Association' xmi:id='AuxiliaryConstructs-Templates-A_templateBinding_boundElement' name='A_templateBinding_boundElement' visibility='public'>
						<memberEnd xmi:idref='AuxiliaryConstructs-Templates-TemplateBinding-boundElement'/>
						<memberEnd xmi:idref='AuxiliaryConstructs-Templates-TemplateableElement-templateBinding'/>
					</packagedElement>
					<packagedElement xmi:type='uml:Association' xmi:id='AuxiliaryConstructs-Templates-A_ownedTemplateSignature_template' name='A_ownedTemplateSignature_template' visibility='public'>
						<memberEnd xmi:idref='AuxiliaryConstructs-Templates-TemplateSignature-template'/>
						<memberEnd xmi:idref='AuxiliaryConstructs-Templates-TemplateableElement-ownedTemplateSignature'/>
					</packagedElement>
					<packagedElement xmi:type='uml:Association' xmi:id='AuxiliaryConstructs-Templates-A_parameter_templateSignature' name='A_parameter_templateSignature' visibility='public'>
						<memberEnd xmi:idref='AuxiliaryConstructs-Templates-TemplateSignature-parameter'/>
						<memberEnd xmi:idref='AuxiliaryConstructs-Templates-A_parameter_templateSignature-templateSignature'/>
						<ownedEnd xmi:type='uml:Property' xmi:id='AuxiliaryConstructs-Templates-A_parameter_templateSignature-templateSignature' name='templateSignature' visibility='public' type='AuxiliaryConstructs-Templates-TemplateSignature' association='AuxiliaryConstructs-Templates-A_parameter_templateSignature'>
							<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='AuxiliaryConstructs-Templates-A_parameter_templateSignature-templateSignature-_upperValue' visibility='public' value='*'/>
							<lowerValue xmi:type='uml:LiteralInteger' xmi:id='AuxiliaryConstructs-Templates-A_parameter_templateSignature-templateSignature-_lowerValue' visibility='public'/>
						</ownedEnd>
					</packagedElement>
					<packagedElement xmi:type='uml:Class' xmi:id='AuxiliaryConstructs-Templates-Classifier' name='Classifier' visibility='public' isAbstract='true'>
						<ownedComment xmi:type='uml:Comment' xmi:id='AuxiliaryConstructs-Templates-Classifier-_ownedComment.0' body='Classifier is defined to be a kind of templateable element so that a classifier can be parameterized. It is also defined to be a kind of parameterable element so that a classifier can be a formal template parameter.'>
							<annotatedElement xmi:idref='AuxiliaryConstructs-Templates-Classifier'/>
						</ownedComment>
						<generalization xmi:type='uml:Generalization' xmi:id='AuxiliaryConstructs-Templates-Classifier-_generalization.0' general='AuxiliaryConstructs-Templates-TemplateableElement'/>
						<generalization xmi:type='uml:Generalization' xmi:id='AuxiliaryConstructs-Templates-Classifier-_generalization.1' general='Classes-Kernel-Namespace'/>
						<generalization xmi:type='uml:Generalization' xmi:id='AuxiliaryConstructs-Templates-Classifier-_generalization.2' general='AuxiliaryConstructs-Templates-ParameterableElement'/>
						<ownedAttribute xmi:type='uml:Property' xmi:id='AuxiliaryConstructs-Templates-Classifier-ownedTemplateSignature' name='ownedTemplateSignature' visibility='public' aggregation='composite' type='AuxiliaryConstructs-Templates-RedefinableTemplateSignature' association='AuxiliaryConstructs-Templates-A_ownedTemplateSignature_classifier'>
							<redefinedProperty xmi:idref='AuxiliaryConstructs-Templates-TemplateableElement-ownedTemplateSignature'/>
							<subsettedProperty xmi:idref='AuxiliaryConstructs-Templates-A_redefinitionContext_redefinableElement-redefinableElement'/>
							<ownedComment xmi:type='uml:Comment' xmi:id='AuxiliaryConstructs-Templates-Classifier-ownedTemplateSignature-_ownedComment.0' body='The optional template signature specifying the formal template parameters.'>
								<annotatedElement xmi:idref='AuxiliaryConstructs-Templates-Classifier-ownedTemplateSignature'/>
							</ownedComment>
							<lowerValue xmi:type='uml:LiteralInteger' xmi:id='AuxiliaryConstructs-Templates-Classifier-ownedTemplateSignature-_lowerValue' visibility='public'/>
						</ownedAttribute>
						<ownedAttribute xmi:type='uml:Property' xmi:id='AuxiliaryConstructs-Templates-Classifier-templateParameter' name='templateParameter' visibility='public' type='AuxiliaryConstructs-Templates-ClassifierTemplateParameter' association='AuxiliaryConstructs-Templates-A_classifier_templateParameter_parameteredElement'>
							<redefinedProperty xmi:idref='AuxiliaryConstructs-Templates-ParameterableElement-templateParameter'/>
							<ownedComment xmi:type='uml:Comment' xmi:id='AuxiliaryConstructs-Templates-Classifier-templateParameter-_ownedComment.0' body='The template parameter that exposes this element as a formal parameter.'>
								<annotatedElement xmi:idref='AuxiliaryConstructs-Templates-Classifier-templateParameter'/>
							</ownedComment>
							<lowerValue xmi:type='uml:LiteralInteger' xmi:id='AuxiliaryConstructs-Templates-Classifier-templateParameter-_lowerValue' visibility='public'/>
						</ownedAttribute>
						<ownedOperation xmi:type='uml:Operation' xmi:id='AuxiliaryConstructs-Templates-Classifier-isTemplate' name='isTemplate' visibility='public' isQuery='true' bodyCondition='AuxiliaryConstructs-Templates-Classifier-isTemplate-spec'>
							<xmi:Extension extender='MagicDraw UML 16.8'>
								<modelExtension/>
							</xmi:Extension>
							<redefinedOperation xmi:idref='AuxiliaryConstructs-Templates-TemplateableElement-isTemplate'/>
							<ownedComment xmi:type='uml:Comment' xmi:id='AuxiliaryConstructs-Templates-Classifier-isTemplate-_ownedComment.0' body='The query isTemplate() returns whether this templateable element is actually a template.'>
								<annotatedElement xmi:idref='AuxiliaryConstructs-Templates-Classifier-isTemplate'/>
							</ownedComment>
							<ownedRule xmi:type='uml:Constraint' xmi:id='AuxiliaryConstructs-Templates-Classifier-isTemplate-spec' name='spec' visibility='public'>
								<constrainedElement xmi:idref='AuxiliaryConstructs-Templates-Classifier-isTemplate'/>
								<specification xmi:type='uml:OpaqueExpression' xmi:id='AuxiliaryConstructs-Templates-Classifier-isTemplate-spec-_specification' visibility='public'>
									<body>result = oclAsType(TemplatableElement).isTemplate() or general-&gt;exists(g | g.isTemplate())</body>
									<language>OCL</language>
								</specification>
							</ownedRule>
							<ownedParameter xmi:type='uml:Parameter' xmi:id='AuxiliaryConstructs-Templates-Classifier-isTemplate-result' name='result' visibility='public' direction='return' effect='create'>
								<type xmi:type='uml:PrimitiveType' href='http://schema.omg.org/spec/UML/2.3/uml.xml#Boolean'>
									<xmi:Extension extender='MagicDraw UML 16.8'>
										<referenceExtension referentPath='PrimitiveTypes::Boolean' referentType='PrimitiveType'/>
									</xmi:Extension>
								</type>
							</ownedParameter>
						</ownedOperation>
					</packagedElement>
					<packagedElement xmi:type='uml:Class' xmi:id='AuxiliaryConstructs-Templates-PackageableElement' name='PackageableElement' visibility='public' isAbstract='true'>
						<ownedComment xmi:type='uml:Comment' xmi:id='AuxiliaryConstructs-Templates-PackageableElement-_ownedComment.0' body='Packageable elements are able to serve as a template parameter.'>
							<annotatedElement xmi:idref='AuxiliaryConstructs-Templates-PackageableElement'/>
						</ownedComment>
						<generalization xmi:type='uml:Generalization' xmi:id='AuxiliaryConstructs-Templates-PackageableElement-_generalization.0' general='AuxiliaryConstructs-Templates-ParameterableElement'/>
					</packagedElement>
					<packagedElement xmi:type='uml:Class' xmi:id='AuxiliaryConstructs-Templates-NamedElement' name='NamedElement' visibility='public' isAbstract='true'>
						<ownedComment xmi:type='uml:Comment' xmi:id='AuxiliaryConstructs-Templates-NamedElement-_ownedComment.0' body='A named element supports using a string expression to specify its name. This allows names of model elements to involve template parameters. The actual name is evaluated from the string expression only when it is sensible to do so (e.g., when a template is bound).'>
							<annotatedElement xmi:idref='AuxiliaryConstructs-Templates-NamedElement'/>
						</ownedComment>
						<generalization xmi:type='uml:Generalization' xmi:id='AuxiliaryConstructs-Templates-NamedElement-_generalization.0' general='Classes-Kernel-Element'/>
						<ownedAttribute xmi:type='uml:Property' xmi:id='AuxiliaryConstructs-Templates-NamedElement-nameExpression' name='nameExpression' visibility='public' aggregation='composite' type='AuxiliaryConstructs-Templates-StringExpression' association='AuxiliaryConstructs-Templates-A_nameExpression_namedElement'>
							<subsettedProperty xmi:idref='Classes-Kernel-Element-ownedElement'/>
							<ownedComment xmi:type='uml:Comment' xmi:id='AuxiliaryConstructs-Templates-NamedElement-nameExpression-_ownedComment.0' body='The string expression used to define the name of this named element.'>
								<annotatedElement xmi:idref='AuxiliaryConstructs-Templates-NamedElement-nameExpression'/>
							</ownedComment>
							<lowerValue xmi:type='uml:LiteralInteger' xmi:id='AuxiliaryConstructs-Templates-NamedElement-nameExpression-_lowerValue' visibility='public'/>
						</ownedAttribute>
					</packagedElement>
					<packagedElement xmi:type='uml:Association' xmi:id='AuxiliaryConstructs-Templates-A_default_templateParameter' name='A_default_templateParameter' visibility='public'>
						<memberEnd xmi:idref='AuxiliaryConstructs-Templates-A_default_templateParameter-templateParameter'/>
						<memberEnd xmi:idref='AuxiliaryConstructs-Templates-TemplateParameter-default'/>
						<ownedEnd xmi:type='uml:Property' xmi:id='AuxiliaryConstructs-Templates-A_default_templateParameter-templateParameter' name='templateParameter' visibility='public' type='AuxiliaryConstructs-Templates-TemplateParameter' association='AuxiliaryConstructs-Templates-A_default_templateParameter'>
							<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='AuxiliaryConstructs-Templates-A_default_templateParameter-templateParameter-_upperValue' visibility='public' value='*'/>
							<lowerValue xmi:type='uml:LiteralInteger' xmi:id='AuxiliaryConstructs-Templates-A_default_templateParameter-templateParameter-_lowerValue' visibility='public'/>
						</ownedEnd>
					</packagedElement>
					<packagedElement xmi:type='uml:Class' xmi:id='AuxiliaryConstructs-Templates-RedefinableTemplateSignature' name='RedefinableTemplateSignature' visibility='public'>
						<xmi:Extension extender='MagicDraw UML 16.8'>
							<modelExtension/>
						</xmi:Extension>
						<ownedComment xmi:type='uml:Comment' xmi:id='AuxiliaryConstructs-Templates-RedefinableTemplateSignature-_ownedComment.0' body='A redefinable template signature supports the addition of formal template parameters in a specialization of a template classifier.'>
							<annotatedElement xmi:idref='AuxiliaryConstructs-Templates-RedefinableTemplateSignature'/>
						</ownedComment>
						<ownedRule xmi:type='uml:Constraint' xmi:id='AuxiliaryConstructs-Templates-RedefinableTemplateSignature-inherited_parameters' name='inherited_parameters' visibility='public'>
							<constrainedElement xmi:idref='AuxiliaryConstructs-Templates-RedefinableTemplateSignature'/>
							<ownedComment xmi:type='uml:Comment' xmi:id='AuxiliaryConstructs-Templates-RedefinableTemplateSignature-inherited_parameters-_ownedComment.0' body='The inherited parameters are the parameters of the extended template signature.'>
								<annotatedElement xmi:idref='AuxiliaryConstructs-Templates-RedefinableTemplateSignature-inherited_parameters'/>
							</ownedComment>
							<specification xmi:type='uml:OpaqueExpression' xmi:id='AuxiliaryConstructs-Templates-RedefinableTemplateSignature-inherited_parameters-_specification' visibility='public'>
								<body>if extendedSignature-&gt;isEmpty() then Set{} else extendedSignature.parameter endif</body>
								<language>OCL</language>
							</specification>
						</ownedRule>
						<generalization xmi:type='uml:Generalization' xmi:id='AuxiliaryConstructs-Templates-RedefinableTemplateSignature-_generalization.0' general='AuxiliaryConstructs-Templates-RedefinableElement'/>
						<generalization xmi:type='uml:Generalization' xmi:id='AuxiliaryConstructs-Templates-RedefinableTemplateSignature-_generalization.1' general='AuxiliaryConstructs-Templates-TemplateSignature'/>
						<generalization xmi:type='uml:Generalization' xmi:id='AuxiliaryConstructs-Templates-RedefinableTemplateSignature-_generalization.2' general='Classes-Kernel-RedefinableElement'/>
						<ownedAttribute xmi:type='uml:Property' xmi:id='AuxiliaryConstructs-Templates-RedefinableTemplateSignature-classifier' name='classifier' visibility='public' type='AuxiliaryConstructs-Templates-Classifier' association='AuxiliaryConstructs-Templates-A_ownedTemplateSignature_classifier'>
							<redefinedProperty xmi:idref='AuxiliaryConstructs-Templates-TemplateSignature-template'/>
							<subsettedProperty xmi:idref='AuxiliaryConstructs-Templates-RedefinableElement-redefinitionContext'/>
							<ownedComment xmi:type='uml:Comment' xmi:id='AuxiliaryConstructs-Templates-RedefinableTemplateSignature-classifier-_ownedComment.0' body='The classifier that owns this template signature.'>
								<annotatedElement xmi:idref='AuxiliaryConstructs-Templates-RedefinableTemplateSignature-classifier'/>
							</ownedComment>
						</ownedAttribute>
						<ownedAttribute xmi:type='uml:Property' xmi:id='AuxiliaryConstructs-Templates-RedefinableTemplateSignature-extendedSignature' name='extendedSignature' visibility='public' type='AuxiliaryConstructs-Templates-RedefinableTemplateSignature' association='AuxiliaryConstructs-Templates-A_extendedSignature_redefinableTemplateSignature'>
							<subsettedProperty xmi:idref='Classes-Kernel-RedefinableElement-redefinedElement'/>
							<ownedComment xmi:type='uml:Comment' xmi:id='AuxiliaryConstructs-Templates-RedefinableTemplateSignature-extendedSignature-_ownedComment.0' body='The template signature that is extended by this template signature.'>
								<annotatedElement xmi:idref='AuxiliaryConstructs-Templates-RedefinableTemplateSignature-extendedSignature'/>
							</ownedComment>
							<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='AuxiliaryConstructs-Templates-RedefinableTemplateSignature-extendedSignature-_upperValue' visibility='public' value='*'/>
							<lowerValue xmi:type='uml:LiteralInteger' xmi:id='AuxiliaryConstructs-Templates-RedefinableTemplateSignature-extendedSignature-_lowerValue' visibility='public'/>
						</ownedAttribute>
						<ownedAttribute xmi:type='uml:Property' xmi:id='AuxiliaryConstructs-Templates-RedefinableTemplateSignature-inheritedParameter' name='inheritedParameter' visibility='public' isReadOnly='true' isDerived='true' type='AuxiliaryConstructs-Templates-TemplateParameter' association='AuxiliaryConstructs-Templates-A_inheritedParameter_redefinableTemplateSignature'>
							<xmi:Extension extender='MagicDraw UML 16.8'>
								<modelExtension/>
							</xmi:Extension>
							<subsettedProperty xmi:idref='AuxiliaryConstructs-Templates-TemplateSignature-parameter'/>
							<ownedComment xmi:type='uml:Comment' xmi:id='AuxiliaryConstructs-Templates-RedefinableTemplateSignature-inheritedParameter-_ownedComment.0' body='The formal template parameters of the extendedSignature.'>
								<annotatedElement xmi:idref='AuxiliaryConstructs-Templates-RedefinableTemplateSignature-inheritedParameter'/>
							</ownedComment>
							<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='AuxiliaryConstructs-Templates-RedefinableTemplateSignature-inheritedParameter-_upperValue' visibility='public' value='*'/>
							<lowerValue xmi:type='uml:LiteralInteger' xmi:id='AuxiliaryConstructs-Templates-RedefinableTemplateSignature-inheritedParameter-_lowerValue' visibility='public'/>
						</ownedAttribute>
						<ownedOperation xmi:type='uml:Operation' xmi:id='AuxiliaryConstructs-Templates-RedefinableTemplateSignature-inheritedParameter.1' name='inheritedParameter' visibility='public' isQuery='true' bodyCondition='AuxiliaryConstructs-Templates-RedefinableTemplateSignature-inheritedParameter.1-spec'>
							<xmi:Extension extender='MagicDraw UML 16.8'>
								<modelExtension/>
							</xmi:Extension>
							<ownedComment xmi:type='uml:Comment' xmi:id='AuxiliaryConstructs-Templates-RedefinableTemplateSignature-inheritedParameter.1-_ownedComment.0' body='Missing derivation for RedefinableTemplateSignature::/inheritedParameter : TemplateParameter'>
								<annotatedElement xmi:idref='AuxiliaryConstructs-Templates-RedefinableTemplateSignature-inheritedParameter.1'/>
							</ownedComment>
							<ownedRule xmi:type='uml:Constraint' xmi:id='AuxiliaryConstructs-Templates-RedefinableTemplateSignature-inheritedParameter.1-spec' name='spec' visibility='public'>
								<constrainedElement xmi:idref='AuxiliaryConstructs-Templates-RedefinableTemplateSignature-inheritedParameter.1'/>
								<constrainedElement xmi:idref='AuxiliaryConstructs-Templates-RedefinableTemplateSignature-inheritedParameter'/>
								<specification xmi:type='uml:OpaqueExpression' xmi:id='AuxiliaryConstructs-Templates-RedefinableTemplateSignature-inheritedParameter.1-spec-_specification' visibility='public'>
									<body>true</body>
									<language>OCL</language>
								</specification>
							</ownedRule>
							<ownedParameter xmi:type='uml:Parameter' xmi:id='AuxiliaryConstructs-Templates-RedefinableTemplateSignature-inheritedParameter.1-result' name='result' visibility='public' direction='return' effect='create' type='AuxiliaryConstructs-Templates-TemplateParameter'>
								<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='AuxiliaryConstructs-Templates-RedefinableTemplateSignature-inheritedParameter.1-result-_upperValue' visibility='public' value='*'/>
								<lowerValue xmi:type='uml:LiteralInteger' xmi:id='AuxiliaryConstructs-Templates-RedefinableTemplateSignature-inheritedParameter.1-result-_lowerValue' visibility='public'/>
