						<memberEnd xmi:idref='Interactions-BasicInteractions-A_sendEvent_endMessage-endMessage'/>
						<ownedEnd xmi:type='uml:Property' xmi:id='Interactions-BasicInteractions-A_sendEvent_endMessage-endMessage' name='endMessage' visibility='public' type='Interactions-BasicInteractions-Message' association='Interactions-BasicInteractions-A_sendEvent_endMessage'>
							<subsettedProperty xmi:idref='Interactions-BasicInteractions-MessageEnd-message'/>
							<lowerValue xmi:type='uml:LiteralInteger' xmi:id='Interactions-BasicInteractions-A_sendEvent_endMessage-endMessage-_lowerValue' visibility='public'/>
						</ownedEnd>
					</packagedElement>
					<packagedElement xmi:type='uml:Enumeration' xmi:id='Interactions-BasicInteractions-MessageKind' name='MessageKind' visibility='public'>
						<ownedComment xmi:type='uml:Comment' xmi:id='Interactions-BasicInteractions-MessageKind-_ownedComment.0' body='This is an enumerated type that identifies the type of message.'>
							<annotatedElement xmi:idref='Interactions-BasicInteractions-MessageKind'/>
						</ownedComment>
						<ownedLiteral xmi:type='uml:EnumerationLiteral' xmi:id='Interactions-BasicInteractions-MessageKind-complete' name='complete' visibility='public'>
							<classifier xmi:idref='Interactions-BasicInteractions-MessageKind'/>
							<ownedComment xmi:type='uml:Comment' xmi:id='Interactions-BasicInteractions-MessageKind-complete-_ownedComment.0' body='sendEvent and receiveEvent are present'>
								<annotatedElement xmi:idref='Interactions-BasicInteractions-MessageKind-complete'/>
							</ownedComment>
						</ownedLiteral>
						<ownedLiteral xmi:type='uml:EnumerationLiteral' xmi:id='Interactions-BasicInteractions-MessageKind-lost' name='lost' visibility='public'>
							<classifier xmi:idref='Interactions-BasicInteractions-MessageKind'/>
							<ownedComment xmi:type='uml:Comment' xmi:id='Interactions-BasicInteractions-MessageKind-lost-_ownedComment.0' body='sendEvent present and receiveEvent absent'>
								<annotatedElement xmi:idref='Interactions-BasicInteractions-MessageKind-lost'/>
							</ownedComment>
						</ownedLiteral>
						<ownedLiteral xmi:type='uml:EnumerationLiteral' xmi:id='Interactions-BasicInteractions-MessageKind-found' name='found' visibility='public'>
							<classifier xmi:idref='Interactions-BasicInteractions-MessageKind'/>
							<ownedComment xmi:type='uml:Comment' xmi:id='Interactions-BasicInteractions-MessageKind-found-_ownedComment.0' body='sendEvent absent and receiveEvent present'>
								<annotatedElement xmi:idref='Interactions-BasicInteractions-MessageKind-found'/>
							</ownedComment>
						</ownedLiteral>
						<ownedLiteral xmi:type='uml:EnumerationLiteral' xmi:id='Interactions-BasicInteractions-MessageKind-unknown' name='unknown' visibility='public'>
							<classifier xmi:idref='Interactions-BasicInteractions-MessageKind'/>
							<ownedComment xmi:type='uml:Comment' xmi:id='Interactions-BasicInteractions-MessageKind-unknown-_ownedComment.0' body='sendEvent and receiveEvent absent (should not appear)'>
								<annotatedElement xmi:idref='Interactions-BasicInteractions-MessageKind-unknown'/>
							</ownedComment>
						</ownedLiteral>
					</packagedElement>
					<packagedElement xmi:type='uml:Enumeration' xmi:id='Interactions-BasicInteractions-MessageSort' name='MessageSort' visibility='public'>
						<ownedComment xmi:type='uml:Comment' xmi:id='Interactions-BasicInteractions-MessageSort-_ownedComment.0' body='This is an enumerated type that identifies the type of communication action that was used to generate the message.'>
							<annotatedElement xmi:idref='Interactions-BasicInteractions-MessageSort'/>
						</ownedComment>
						<ownedLiteral xmi:type='uml:EnumerationLiteral' xmi:id='Interactions-BasicInteractions-MessageSort-synchCall' name='synchCall' visibility='public'>
							<classifier xmi:idref='Interactions-BasicInteractions-MessageSort'/>
							<ownedComment xmi:type='uml:Comment' xmi:id='Interactions-BasicInteractions-MessageSort-synchCall-_ownedComment.0' body='The message was generated by a synchronous call to an operation.'>
								<annotatedElement xmi:idref='Interactions-BasicInteractions-MessageSort-synchCall'/>
							</ownedComment>
						</ownedLiteral>
						<ownedLiteral xmi:type='uml:EnumerationLiteral' xmi:id='Interactions-BasicInteractions-MessageSort-asynchCall' name='asynchCall' visibility='public'>
							<classifier xmi:idref='Interactions-BasicInteractions-MessageSort'/>
							<ownedComment xmi:type='uml:Comment' xmi:id='Interactions-BasicInteractions-MessageSort-asynchCall-_ownedComment.0' body='The message was generated by an asynchronous call to an operation; i.e., a CallAction with isSynchronous = false.'>
								<annotatedElement xmi:idref='Interactions-BasicInteractions-MessageSort-asynchCall'/>
							</ownedComment>
						</ownedLiteral>
						<ownedLiteral xmi:type='uml:EnumerationLiteral' xmi:id='Interactions-BasicInteractions-MessageSort-asynchSignal' name='asynchSignal' visibility='public'>
							<classifier xmi:idref='Interactions-BasicInteractions-MessageSort'/>
							<ownedComment xmi:type='uml:Comment' xmi:id='Interactions-BasicInteractions-MessageSort-asynchSignal-_ownedComment.0' body='The message was generated by an asynchronous send action.'>
								<annotatedElement xmi:idref='Interactions-BasicInteractions-MessageSort-asynchSignal'/>
							</ownedComment>
						</ownedLiteral>
						<ownedLiteral xmi:type='uml:EnumerationLiteral' xmi:id='Interactions-BasicInteractions-MessageSort-createMessage' name='createMessage' visibility='public'>
							<classifier xmi:idref='Interactions-BasicInteractions-MessageSort'/>
							<ownedComment xmi:type='uml:Comment' xmi:id='Interactions-BasicInteractions-MessageSort-createMessage-_ownedComment.0' body='The message designating the creation of another lifeline object.'>
								<annotatedElement xmi:idref='Interactions-BasicInteractions-MessageSort-createMessage'/>
							</ownedComment>
						</ownedLiteral>
						<ownedLiteral xmi:type='uml:EnumerationLiteral' xmi:id='Interactions-BasicInteractions-MessageSort-deleteMessage' name='deleteMessage' visibility='public'>
							<classifier xmi:idref='Interactions-BasicInteractions-MessageSort'/>
							<ownedComment xmi:type='uml:Comment' xmi:id='Interactions-BasicInteractions-MessageSort-deleteMessage-_ownedComment.0' body='The message designating the termination of another lifeline.'>
								<annotatedElement xmi:idref='Interactions-BasicInteractions-MessageSort-deleteMessage'/>
							</ownedComment>
						</ownedLiteral>
						<ownedLiteral xmi:type='uml:EnumerationLiteral' xmi:id='Interactions-BasicInteractions-MessageSort-reply' name='reply' visibility='public'>
							<classifier xmi:idref='Interactions-BasicInteractions-MessageSort'/>
							<ownedComment xmi:type='uml:Comment' xmi:id='Interactions-BasicInteractions-MessageSort-reply-_ownedComment.0' body='The message is a reply message to an operation call.'>
								<annotatedElement xmi:idref='Interactions-BasicInteractions-MessageSort-reply'/>
							</ownedComment>
						</ownedLiteral>
					</packagedElement>
					<packagedElement xmi:type='uml:Class' xmi:id='Interactions-BasicInteractions-MessageOccurrenceSpecification' name='MessageOccurrenceSpecification' visibility='public'>
						<ownedComment xmi:type='uml:Comment' xmi:id='Interactions-BasicInteractions-MessageOccurrenceSpecification-_ownedComment.0' body='A message occurrence specification pecifies the occurrence of message events, such as sending and receiving of signals or invoking or receiving of operation calls. A message occurrence specification is a kind of message end. Messages are generated either by synchronous operation calls or asynchronous signal sends. They are received by the execution of corresponding accept event actions.'>
							<annotatedElement xmi:idref='Interactions-BasicInteractions-MessageOccurrenceSpecification'/>
						</ownedComment>
						<generalization xmi:type='uml:Generalization' xmi:id='Interactions-BasicInteractions-MessageOccurrenceSpecification-_generalization.0' general='Interactions-BasicInteractions-OccurrenceSpecification'/>
						<generalization xmi:type='uml:Generalization' xmi:id='Interactions-BasicInteractions-MessageOccurrenceSpecification-_generalization.1' general='Interactions-BasicInteractions-MessageEnd'/>
					</packagedElement>
					<packagedElement xmi:type='uml:Association' xmi:id='Interactions-BasicInteractions-A_receiveEvent_endMessage' name='A_receiveEvent_endMessage' visibility='public'>
						<memberEnd xmi:idref='Interactions-BasicInteractions-Message-receiveEvent'/>
						<memberEnd xmi:idref='Interactions-BasicInteractions-A_receiveEvent_endMessage-endMessage'/>
						<ownedEnd xmi:type='uml:Property' xmi:id='Interactions-BasicInteractions-A_receiveEvent_endMessage-endMessage' name='endMessage' visibility='public' type='Interactions-BasicInteractions-Message' association='Interactions-BasicInteractions-A_receiveEvent_endMessage'>
							<subsettedProperty xmi:idref='Interactions-BasicInteractions-MessageEnd-message'/>
