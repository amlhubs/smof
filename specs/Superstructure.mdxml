							<lowerValue xmi:type='uml:LiteralInteger' xmi:id='Activities-IntermediateActivities-ActivityPartition-node-_lowerValue' visibility='public'/>
						</ownedAttribute>
						<ownedAttribute xmi:type='uml:Property' xmi:id='Activities-IntermediateActivities-ActivityPartition-represents' name='represents' visibility='public' type='Classes-Kernel-Element' association='Activities-IntermediateActivities-A_represents_activityPartition'>
