						<memberEnd xmi:idref='Actions-IntermediateActions-LinkEndData-end'/>
						<memberEnd xmi:idref='Actions-IntermediateActions-A_end_linkEndData-linkEndData'/>
						<ownedEnd xmi:type='uml:Property' xmi:id='Actions-IntermediateActions-A_end_linkEndData-linkEndData' name='linkEndData' visibility='public' type='Actions-IntermediateActions-LinkEndData' association='Actions-IntermediateActions-A_end_linkEndData'>
							<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='Actions-IntermediateActions-A_end_linkEndData-linkEndData-_upperValue' visibility='public' value='*'/>
