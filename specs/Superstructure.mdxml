						<ownedComment xmi:type='uml:Comment' xmi:id='AuxiliaryConstructs-Templates-TemplateParameter-_ownedComment.0' body='A template parameter exposes a parameterable element as a formal template parameter of a template.'>
							<annotatedElement xmi:idref='AuxiliaryConstructs-Templates-TemplateParameter'/>
						</ownedComment>
						<ownedRule xmi:type='uml:Constraint' xmi:id='AuxiliaryConstructs-Templates-TemplateParameter-must_be_compatible' name='must_be_compatible' visibility='public'>
							<constrainedElement xmi:idref='AuxiliaryConstructs-Templates-TemplateParameter'/>
							<ownedComment xmi:type='uml:Comment' xmi:id='AuxiliaryConstructs-Templates-TemplateParameter-must_be_compatible-_ownedComment.0' body='The default must be compatible with the formal template parameter.'>
								<annotatedElement xmi:idref='AuxiliaryConstructs-Templates-TemplateParameter-must_be_compatible'/>
							</ownedComment>
							<specification xmi:type='uml:OpaqueExpression' xmi:id='AuxiliaryConstructs-Templates-TemplateParameter-must_be_compatible-_specification' visibility='public'>
								<body>default-&gt;notEmpty() implies default-&gt;isCompatibleWith(parameteredElement)</body>
								<language>OCL</language>
							</specification>
						</ownedRule>
						<generalization xmi:type='uml:Generalization' xmi:id='AuxiliaryConstructs-Templates-TemplateParameter-_generalization.0' general='Classes-Kernel-Element'/>
						<ownedAttribute xmi:type='uml:Property' xmi:id='AuxiliaryConstructs-Templates-TemplateParameter-default' name='default' visibility='public' type='AuxiliaryConstructs-Templates-ParameterableElement' association='AuxiliaryConstructs-Templates-A_default_templateParameter'>
							<ownedComment xmi:type='uml:Comment' xmi:id='AuxiliaryConstructs-Templates-TemplateParameter-default-_ownedComment.0' body='The element that is the default for this formal template parameter.'>
