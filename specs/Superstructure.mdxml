							<lowerValue xmi:type='uml:LiteralInteger' xmi:id='Activities-BasicActivities-ActivityEdge-inGroup-_lowerValue' visibility='public'/>
						</ownedAttribute>
						<ownedAttribute xmi:type='uml:Property' xmi:id='Activities-BasicActivities-ActivityEdge-redefinedEdge' name='redefinedEdge' visibility='public' type='Activities-BasicActivities-ActivityEdge' association='Activities-BasicActivities-A_redefinedEdge_activityEdge'>
							<subsettedProperty xmi:idref='Classes-Kernel-RedefinableElement-redefinedElement'/>
							<ownedComment xmi:type='uml:Comment' xmi:id='Activities-BasicActivities-ActivityEdge-redefinedEdge-_ownedComment.0' body='Inherited edges replaced by this edge in a specialization of the activity.'>
