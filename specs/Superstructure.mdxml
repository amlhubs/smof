						<ownedOperation xmi:type='uml:Operation' xmi:id='Interactions-BasicInteractions-Message-messageKind.1' name='messageKind' visibility='public' isQuery='true' bodyCondition='Interactions-BasicInteractions-Message-messageKind.1-spec'>
