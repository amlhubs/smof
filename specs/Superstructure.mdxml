					</packagedElement>
					<packagedElement xmi:type='uml:Association' xmi:id='Interactions-BasicInteractions-A_represents_lifeline' name='A_represents_lifeline' visibility='public'>
						<memberEnd xmi:idref='Interactions-BasicInteractions-Lifeline-represents'/>
						<memberEnd xmi:idref='Interactions-BasicInteractions-A_represents_lifeline-lifeline'/>
						<ownedComment xmi:type='uml:Comment' xmi:id='Interactions-BasicInteractions-A_represents_lifeline-_ownedComment.0' body='If a Part has multiplicity, multiple lifelines might be used to show it.'>
							<annotatedElement xmi:idref='Interactions-BasicInteractions-A_represents_lifeline'/>
						</ownedComment>
						<ownedEnd xmi:type='uml:Property' xmi:id='Interactions-BasicInteractions-A_represents_lifeline-lifeline' name='lifeline' visibility='public' type='Interactions-BasicInteractions-Lifeline' association='Interactions-BasicInteractions-A_represents_lifeline'>
							<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='Interactions-BasicInteractions-A_represents_lifeline-lifeline-_upperValue' visibility='public' value='*'/>
							<lowerValue xmi:type='uml:LiteralInteger' xmi:id='Interactions-BasicInteractions-A_represents_lifeline-lifeline-_lowerValue' visibility='public'/>
						</ownedEnd>
					</packagedElement>
					<packagedElement xmi:type='uml:Association' xmi:id='Interactions-BasicInteractions-A_covered_stateInvariant' name='A_covered_stateInvariant' visibility='public'>
