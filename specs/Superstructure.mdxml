						</ownedAttribute>
						<ownedAttribute xmi:type='uml:Property' xmi:id='CompositeStructures-Collaborations-Classifier-representation' name='representation' visibility='public' type='CompositeStructures-Collaborations-CollaborationUse' association='CompositeStructures-Collaborations-A_representation_classifier'>
							<subsettedProperty xmi:idref='CompositeStructures-Collaborations-Classifier-collaborationUse'/>
							<ownedComment xmi:type='uml:Comment' xmi:id='CompositeStructures-Collaborations-Classifier-representation-_ownedComment.0' body='References a collaboration use which indicates the collaboration that represents this classifier.'>
								<annotatedElement xmi:idref='CompositeStructures-Collaborations-Classifier-representation'/>
							</ownedComment>
							<lowerValue xmi:type='uml:LiteralInteger' xmi:id='CompositeStructures-Collaborations-Classifier-representation-_lowerValue' visibility='public'/>
