					<packagedElement xmi:type='uml:Association' xmi:id='Interactions-BasicInteractions-A_toBefore_after' name='A_toBefore_after' visibility='public'>
						<memberEnd xmi:idref='Interactions-BasicInteractions-GeneralOrdering-after'/>
						<memberEnd xmi:idref='Interactions-BasicInteractions-OccurrenceSpecification-toBefore'/>
					</packagedElement>
					<packagedElement xmi:type='uml:Association' xmi:id='Interactions-BasicInteractions-A_start_executionSpecification' name='A_start_executionSpecification' visibility='public'>
						<memberEnd xmi:idref='Interactions-BasicInteractions-ExecutionSpecification-start'/>
						<memberEnd xmi:idref='Interactions-BasicInteractions-A_start_executionSpecification-executionSpecification'/>
						<ownedComment xmi:type='uml:Comment' xmi:id='Interactions-BasicInteractions-A_start_executionSpecification-_ownedComment.0' body='The event shows the time point at which the action begins execution.'>
							<annotatedElement xmi:idref='Interactions-BasicInteractions-A_start_executionSpecification'/>
						</ownedComment>
						<ownedEnd xmi:type='uml:Property' xmi:id='Interactions-BasicInteractions-A_start_executionSpecification-executionSpecification' name='executionSpecification' visibility='public' type='Interactions-BasicInteractions-ExecutionSpecification' association='Interactions-BasicInteractions-A_start_executionSpecification'>
							<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='Interactions-BasicInteractions-A_start_executionSpecification-executionSpecification-_upperValue' visibility='public' value='*'/>
							<lowerValue xmi:type='uml:LiteralInteger' xmi:id='Interactions-BasicInteractions-A_start_executionSpecification-executionSpecification-_lowerValue' visibility='public'/>
						</ownedEnd>
					</packagedElement>
					<packagedElement xmi:type='uml:Class' xmi:id='Interactions-BasicInteractions-OccurrenceSpecification' name='OccurrenceSpecification' visibility='public'>
						<ownedComment xmi:type='uml:Comment' xmi:id='Interactions-BasicInteractions-OccurrenceSpecification-_ownedComment.0' body='An occurrence specification is the basic semantic unit of interactions. The sequences of occurrences specified by them are the meanings of interactions.'>
							<annotatedElement xmi:idref='Interactions-BasicInteractions-OccurrenceSpecification'/>
						</ownedComment>
						<generalization xmi:type='uml:Generalization' xmi:id='Interactions-BasicInteractions-OccurrenceSpecification-_generalization.0' general='Interactions-BasicInteractions-InteractionFragment'/>
						<ownedAttribute xmi:type='uml:Property' xmi:id='Interactions-BasicInteractions-OccurrenceSpecification-covered' name='covered' visibility='public' type='Interactions-BasicInteractions-Lifeline' association='Interactions-BasicInteractions-A_covered_events'>
							<redefinedProperty xmi:idref='Interactions-BasicInteractions-InteractionFragment-covered'/>
							<ownedComment xmi:type='uml:Comment' xmi:id='Interactions-BasicInteractions-OccurrenceSpecification-covered-_ownedComment.0' body='References the Lifeline on which the OccurrenceSpecification appears.'>
								<annotatedElement xmi:idref='Interactions-BasicInteractions-OccurrenceSpecification-covered'/>
							</ownedComment>
						</ownedAttribute>
						<ownedAttribute xmi:type='uml:Property' xmi:id='Interactions-BasicInteractions-OccurrenceSpecification-toAfter' name='toAfter' visibility='public' type='Interactions-BasicInteractions-GeneralOrdering' association='Interactions-BasicInteractions-A_before_toAfter'>
							<ownedComment xmi:type='uml:Comment' xmi:id='Interactions-BasicInteractions-OccurrenceSpecification-toAfter-_ownedComment.0' body='References the GeneralOrderings that specify EventOcurrences that must occur after this OccurrenceSpecification'>
								<annotatedElement xmi:idref='Interactions-BasicInteractions-OccurrenceSpecification-toAfter'/>
							</ownedComment>
							<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='Interactions-BasicInteractions-OccurrenceSpecification-toAfter-_upperValue' visibility='public' value='*'/>
							<lowerValue xmi:type='uml:LiteralInteger' xmi:id='Interactions-BasicInteractions-OccurrenceSpecification-toAfter-_lowerValue' visibility='public'/>
						</ownedAttribute>
						<ownedAttribute xmi:type='uml:Property' xmi:id='Interactions-BasicInteractions-OccurrenceSpecification-toBefore' name='toBefore' visibility='public' type='Interactions-BasicInteractions-GeneralOrdering' association='Interactions-BasicInteractions-A_toBefore_after'>
							<ownedComment xmi:type='uml:Comment' xmi:id='Interactions-BasicInteractions-OccurrenceSpecification-toBefore-_ownedComment.0' body='References the GeneralOrderings that specify EventOcurrences that must occur before this OccurrenceSpecification'>
								<annotatedElement xmi:idref='Interactions-BasicInteractions-OccurrenceSpecification-toBefore'/>
							</ownedComment>
							<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='Interactions-BasicInteractions-OccurrenceSpecification-toBefore-_upperValue' visibility='public' value='*'/>
							<lowerValue xmi:type='uml:LiteralInteger' xmi:id='Interactions-BasicInteractions-OccurrenceSpecification-toBefore-_lowerValue' visibility='public'/>
						</ownedAttribute>
					</packagedElement>
					<packagedElement xmi:type='uml:Class' xmi:id='Interactions-BasicInteractions-InteractionFragment' name='InteractionFragment' visibility='public' isAbstract='true'>
						<ownedComment xmi:type='uml:Comment' xmi:id='Interactions-BasicInteractions-InteractionFragment-_ownedComment.0' body='InteractionFragment is an abstract notion of the most general interaction unit. An interaction fragment is a piece of an interaction. Each interaction fragment is conceptually like an interaction by itself.'>
							<annotatedElement xmi:idref='Interactions-BasicInteractions-InteractionFragment'/>
						</ownedComment>
						<generalization xmi:type='uml:Generalization' xmi:id='Interactions-BasicInteractions-InteractionFragment-_generalization.0' general='Classes-Kernel-NamedElement'/>
						<ownedAttribute xmi:type='uml:Property' xmi:id='Interactions-BasicInteractions-InteractionFragment-covered' name='covered' visibility='public' type='Interactions-BasicInteractions-Lifeline' association='Interactions-BasicInteractions-A_covered_coveredBy'>
							<ownedComment xmi:type='uml:Comment' xmi:id='Interactions-BasicInteractions-InteractionFragment-covered-_ownedComment.0' body='References the Lifelines that the InteractionFragment involves.'>
								<annotatedElement xmi:idref='Interactions-BasicInteractions-InteractionFragment-covered'/>
							</ownedComment>
							<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='Interactions-BasicInteractions-InteractionFragment-covered-_upperValue' visibility='public' value='*'/>
							<lowerValue xmi:type='uml:LiteralInteger' xmi:id='Interactions-BasicInteractions-InteractionFragment-covered-_lowerValue' visibility='public'/>
						</ownedAttribute>
						<ownedAttribute xmi:type='uml:Property' xmi:id='Interactions-BasicInteractions-InteractionFragment-enclosingInteraction' name='enclosingInteraction' visibility='public' type='Interactions-BasicInteractions-Interaction' association='Interactions-BasicInteractions-A_fragment_enclosingInteraction'>
							<subsettedProperty xmi:idref='Classes-Kernel-NamedElement-namespace'/>
							<ownedComment xmi:type='uml:Comment' xmi:id='Interactions-BasicInteractions-InteractionFragment-enclosingInteraction-_ownedComment.0' body='The Interaction enclosing this InteractionFragment.'>
								<annotatedElement xmi:idref='Interactions-BasicInteractions-InteractionFragment-enclosingInteraction'/>
							</ownedComment>
							<lowerValue xmi:type='uml:LiteralInteger' xmi:id='Interactions-BasicInteractions-InteractionFragment-enclosingInteraction-_lowerValue' visibility='public'/>
						</ownedAttribute>
						<ownedAttribute xmi:type='uml:Property' xmi:id='Interactions-BasicInteractions-InteractionFragment-generalOrdering' name='generalOrdering' visibility='public' aggregation='composite' type='Interactions-BasicInteractions-GeneralOrdering' association='Interactions-BasicInteractions-A_generalOrdering_interactionFragment'>
							<subsettedProperty xmi:idref='Classes-Kernel-Element-ownedElement'/>
							<ownedComment xmi:type='uml:Comment' xmi:id='Interactions-BasicInteractions-InteractionFragment-generalOrdering-_ownedComment.0' body='The general ordering relationships contained in this fragment.'>
								<annotatedElement xmi:idref='Interactions-BasicInteractions-InteractionFragment-generalOrdering'/>
							</ownedComment>
							<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='Interactions-BasicInteractions-InteractionFragment-generalOrdering-_upperValue' visibility='public' value='*'/>
							<lowerValue xmi:type='uml:LiteralInteger' xmi:id='Interactions-BasicInteractions-InteractionFragment-generalOrdering-_lowerValue' visibility='public'/>
						</ownedAttribute>
					</packagedElement>
					<packagedElement xmi:type='uml:Class' xmi:id='Interactions-BasicInteractions-BehaviorExecutionSpecification' name='BehaviorExecutionSpecification' visibility='public'>
						<ownedComment xmi:type='uml:Comment' xmi:id='Interactions-BasicInteractions-BehaviorExecutionSpecification-_ownedComment.0' body='A behavior execution specification is a kind of execution specification representing the execution of a behavior.'>
							<annotatedElement xmi:idref='Interactions-BasicInteractions-BehaviorExecutionSpecification'/>
						</ownedComment>
						<generalization xmi:type='uml:Generalization' xmi:id='Interactions-BasicInteractions-BehaviorExecutionSpecification-_generalization.0' general='Interactions-BasicInteractions-ExecutionSpecification'/>
						<ownedAttribute xmi:type='uml:Property' xmi:id='Interactions-BasicInteractions-BehaviorExecutionSpecification-behavior' name='behavior' visibility='public' type='CommonBehaviors-BasicBehaviors-Behavior' association='Interactions-BasicInteractions-A_behavior_behaviorExecutionSpecification'>
							<ownedComment xmi:type='uml:Comment' xmi:id='Interactions-BasicInteractions-BehaviorExecutionSpecification-behavior-_ownedComment.0' body='Behavior whose execution is occurring.'>
								<annotatedElement xmi:idref='Interactions-BasicInteractions-BehaviorExecutionSpecification-behavior'/>
							</ownedComment>
							<lowerValue xmi:type='uml:LiteralInteger' xmi:id='Interactions-BasicInteractions-BehaviorExecutionSpecification-behavior-_lowerValue' visibility='public'/>
						</ownedAttribute>
					</packagedElement>
				</packagedElement>
			</packagedElement>
			<packagedElement xmi:type='uml:Package' xmi:id='UseCases' name='UseCases' visibility='public'>
				<packageMerge xmi:type='uml:PackageMerge' xmi:id='UseCases-_packageMerge.0' mergedPackage='CommonBehaviors-BasicBehaviors'/>
				<packagedElement xmi:type='uml:Association' xmi:id='UseCases-A_condition_extend' name='A_condition_extend' visibility='public'>
					<memberEnd xmi:idref='UseCases-Extend-condition'/>
					<memberEnd xmi:idref='UseCases-A_condition_extend-extend'/>
					<ownedEnd xmi:type='uml:Property' xmi:id='UseCases-A_condition_extend-extend' name='extend' visibility='public' type='UseCases-Extend' association='UseCases-A_condition_extend'>
						<subsettedProperty xmi:idref='Classes-Kernel-Element-owner'/>
						<lowerValue xmi:type='uml:LiteralInteger' xmi:id='UseCases-A_condition_extend-extend-_lowerValue' visibility='public'/>
					</ownedEnd>
				</packagedElement>
				<packagedElement xmi:type='uml:Class' xmi:id='UseCases-Include' name='Include' visibility='public'>
					<ownedComment xmi:type='uml:Comment' xmi:id='UseCases-Include-_ownedComment.0' body='An include relationship defines that a use case contains the behavior defined in another use case.'>
						<annotatedElement xmi:idref='UseCases-Include'/>
					</ownedComment>
					<generalization xmi:type='uml:Generalization' xmi:id='UseCases-Include-_generalization.0' general='Classes-Kernel-DirectedRelationship'/>
					<generalization xmi:type='uml:Generalization' xmi:id='UseCases-Include-_generalization.1' general='Classes-Kernel-NamedElement'/>
					<ownedAttribute xmi:type='uml:Property' xmi:id='UseCases-Include-addition' name='addition' visibility='public' type='UseCases-UseCase' association='UseCases-A_addition_include'>
						<subsettedProperty xmi:idref='Classes-Kernel-DirectedRelationship-target'/>
						<ownedComment xmi:type='uml:Comment' xmi:id='UseCases-Include-addition-_ownedComment.0' body='References the use case that is to be included.'>
							<annotatedElement xmi:idref='UseCases-Include-addition'/>
						</ownedComment>
					</ownedAttribute>
					<ownedAttribute xmi:type='uml:Property' xmi:id='UseCases-Include-includingCase' name='includingCase' visibility='public' type='UseCases-UseCase' association='UseCases-A_include_includingCase'>
						<subsettedProperty xmi:idref='Classes-Kernel-DirectedRelationship-source'/>
						<subsettedProperty xmi:idref='Classes-Kernel-NamedElement-namespace'/>
						<ownedComment xmi:type='uml:Comment' xmi:id='UseCases-Include-includingCase-_ownedComment.0' body='References the use case which will include the addition and owns the include relationship.'>
							<annotatedElement xmi:idref='UseCases-Include-includingCase'/>
						</ownedComment>
					</ownedAttribute>
				</packagedElement>
				<packagedElement xmi:type='uml:Association' xmi:id='UseCases-A_extensionPoint_useCase' name='A_extensionPoint_useCase' visibility='public'>
					<memberEnd xmi:idref='UseCases-UseCase-extensionPoint'/>
					<memberEnd xmi:idref='UseCases-ExtensionPoint-useCase'/>
				</packagedElement>
				<packagedElement xmi:type='uml:Association' xmi:id='UseCases-A_subject_useCase' name='A_subject_useCase' visibility='public'>
					<memberEnd xmi:idref='UseCases-Classifier-useCase'/>
					<memberEnd xmi:idref='UseCases-UseCase-subject'/>
				</packagedElement>
				<packagedElement xmi:type='uml:Association' xmi:id='UseCases-A_include_includingCase' name='A_include_includingCase' visibility='public'>
					<memberEnd xmi:idref='UseCases-UseCase-include'/>
					<memberEnd xmi:idref='UseCases-Include-includingCase'/>
				</packagedElement>
				<packagedElement xmi:type='uml:Association' xmi:id='UseCases-A_ownedUseCase_classifier' name='A_ownedUseCase_classifier' visibility='public'>
					<memberEnd xmi:idref='UseCases-Classifier-ownedUseCase'/>
					<memberEnd xmi:idref='UseCases-A_ownedUseCase_classifier-classifier'/>
					<ownedEnd xmi:type='uml:Property' xmi:id='UseCases-A_ownedUseCase_classifier-classifier' name='classifier' visibility='public' type='UseCases-Classifier' association='UseCases-A_ownedUseCase_classifier'>
						<subsettedProperty xmi:idref='Classes-Kernel-NamedElement-namespace'/>
						<lowerValue xmi:type='uml:LiteralInteger' xmi:id='UseCases-A_ownedUseCase_classifier-classifier-_lowerValue' visibility='public'/>
					</ownedEnd>
				</packagedElement>
				<packagedElement xmi:type='uml:Class' xmi:id='UseCases-Classifier' name='Classifier' visibility='public' isAbstract='true'>
					<ownedComment xmi:type='uml:Comment' xmi:id='UseCases-Classifier-_ownedComment.0' body='A classifier has the capability to own use cases. Although the owning classifier typically represents the subject to which the owned use cases apply, this is not necessarily the case. In principle, the same use case can be applied to multiple subjects, as identified by the subject association role of a use case.'>
						<annotatedElement xmi:idref='UseCases-Classifier'/>
					</ownedComment>
					<generalization xmi:type='uml:Generalization' xmi:id='UseCases-Classifier-_generalization.0' general='Classes-Kernel-Namespace'/>
					<ownedAttribute xmi:type='uml:Property' xmi:id='UseCases-Classifier-ownedUseCase' name='ownedUseCase' visibility='public' aggregation='composite' type='UseCases-UseCase' association='UseCases-A_ownedUseCase_classifier'>
						<subsettedProperty xmi:idref='Classes-Kernel-Namespace-ownedMember'/>
						<ownedComment xmi:type='uml:Comment' xmi:id='UseCases-Classifier-ownedUseCase-_ownedComment.0' body='References the use cases owned by this classifier.'>
							<annotatedElement xmi:idref='UseCases-Classifier-ownedUseCase'/>
						</ownedComment>
						<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='UseCases-Classifier-ownedUseCase-_upperValue' visibility='public' value='*'/>
						<lowerValue xmi:type='uml:LiteralInteger' xmi:id='UseCases-Classifier-ownedUseCase-_lowerValue' visibility='public'/>
					</ownedAttribute>
					<ownedAttribute xmi:type='uml:Property' xmi:id='UseCases-Classifier-useCase' name='useCase' visibility='public' type='UseCases-UseCase' association='UseCases-A_subject_useCase'>
						<ownedComment xmi:type='uml:Comment' xmi:id='UseCases-Classifier-useCase-_ownedComment.0' body='The set of use cases for which this Classifier is the subject.'>
							<annotatedElement xmi:idref='UseCases-Classifier-useCase'/>
						</ownedComment>
						<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='UseCases-Classifier-useCase-_upperValue' visibility='public' value='*'/>
						<lowerValue xmi:type='uml:LiteralInteger' xmi:id='UseCases-Classifier-useCase-_lowerValue' visibility='public'/>
					</ownedAttribute>
				</packagedElement>
				<packagedElement xmi:type='uml:Association' xmi:id='UseCases-A_extensionLocation_extension' name='A_extensionLocation_extension' visibility='public'>
					<memberEnd xmi:idref='UseCases-A_extensionLocation_extension-extension'/>
					<memberEnd xmi:idref='UseCases-Extend-extensionLocation'/>
					<ownedEnd xmi:type='uml:Property' xmi:id='UseCases-A_extensionLocation_extension-extension' name='extension' visibility='public' type='UseCases-Extend' association='UseCases-A_extensionLocation_extension'>
						<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='UseCases-A_extensionLocation_extension-extension-_upperValue' visibility='public' value='*'/>
						<lowerValue xmi:type='uml:LiteralInteger' xmi:id='UseCases-A_extensionLocation_extension-extension-_lowerValue' visibility='public'/>
					</ownedEnd>
				</packagedElement>
				<packagedElement xmi:type='uml:Association' xmi:id='UseCases-A_extend_extension' name='A_extend_extension' visibility='public'>
					<memberEnd xmi:idref='UseCases-Extend-extension'/>
					<memberEnd xmi:idref='UseCases-UseCase-extend'/>
				</packagedElement>
				<packagedElement xmi:type='uml:Association' xmi:id='UseCases-A_addition_include' name='A_addition_include' visibility='public'>
					<memberEnd xmi:idref='UseCases-Include-addition'/>
					<memberEnd xmi:idref='UseCases-A_addition_include-include'/>
					<ownedEnd xmi:type='uml:Property' xmi:id='UseCases-A_addition_include-include' name='include' visibility='public' type='UseCases-Include' association='UseCases-A_addition_include'>
						<subsettedProperty xmi:idref='Classes-Kernel-A_target_directedRelationship-directedRelationship'/>
						<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='UseCases-A_addition_include-include-_upperValue' visibility='public' value='*'/>
						<lowerValue xmi:type='uml:LiteralInteger' xmi:id='UseCases-A_addition_include-include-_lowerValue' visibility='public'/>
					</ownedEnd>
				</packagedElement>
				<packagedElement xmi:type='uml:Class' xmi:id='UseCases-Actor' name='Actor' visibility='public'>
					<xmi:Extension extender='MagicDraw UML 16.8'>
						<modelExtension/>
					</xmi:Extension>
					<ownedComment xmi:type='uml:Comment' xmi:id='UseCases-Actor-_ownedComment.0' body='An actor specifies a role played by a user or any other system that interacts with the subject.'>
						<annotatedElement xmi:idref='UseCases-Actor'/>
					</ownedComment>
					<ownedRule xmi:type='uml:Constraint' xmi:id='UseCases-Actor-must_have_name' name='must_have_name' visibility='public'>
						<constrainedElement xmi:idref='UseCases-Actor'/>
						<ownedComment xmi:type='uml:Comment' xmi:id='UseCases-Actor-must_have_name-_ownedComment.0' body='An actor must have a name.'>
							<annotatedElement xmi:idref='UseCases-Actor-must_have_name'/>
						</ownedComment>
						<specification xmi:type='uml:OpaqueExpression' xmi:id='UseCases-Actor-must_have_name-_specification' visibility='public'>
							<body>name-&gt;notEmpty()</body>
							<language>OCL</language>
						</specification>
					</ownedRule>
					<ownedRule xmi:type='uml:Constraint' xmi:id='UseCases-Actor-associations' name='associations' visibility='public'>
						<constrainedElement xmi:idref='UseCases-Actor'/>
						<ownedComment xmi:type='uml:Comment' xmi:id='UseCases-Actor-associations-_ownedComment.0' body='An actor can only have associations to use cases, components and classes. Furthermore these associations must be binary.'>
							<annotatedElement xmi:idref='UseCases-Actor-associations'/>
						</ownedComment>
						<specification xmi:type='uml:OpaqueExpression' xmi:id='UseCases-Actor-associations-_specification' visibility='public'>
							<body>self.ownedAttribute-&gt;forAll ( a |
(a.association-&gt;notEmpty()) implies
((a.association.memberEnd.size() = 2) and
(a.opposite.class.oclIsKindOf(UseCase) or
(a.opposite.class.oclIsKindOf(Class) and not a.opposite.class.oclIsKindOf(Behavior))))
</body>
							<language>OCL</language>
						</specification>
					</ownedRule>
					<generalization xmi:type='uml:Generalization' xmi:id='UseCases-Actor-_generalization.0' general='CommonBehaviors-BasicBehaviors-BehavioredClassifier'/>
				</packagedElement>
				<packagedElement xmi:type='uml:Class' xmi:id='UseCases-ExtensionPoint' name='ExtensionPoint' visibility='public'>
					<xmi:Extension extender='MagicDraw UML 16.8'>
						<modelExtension/>
					</xmi:Extension>
					<ownedComment xmi:type='uml:Comment' xmi:id='UseCases-ExtensionPoint-_ownedComment.0' body='An extension point identifies a point in the behavior of a use case where that behavior can be extended by the behavior of some other (extending) use case, as specified by an extend relationship.'>
						<annotatedElement xmi:idref='UseCases-ExtensionPoint'/>
					</ownedComment>
					<ownedRule xmi:type='uml:Constraint' xmi:id='UseCases-ExtensionPoint-must_have_name' name='must_have_name' visibility='public'>
						<constrainedElement xmi:idref='UseCases-ExtensionPoint'/>
						<ownedComment xmi:type='uml:Comment' xmi:id='UseCases-ExtensionPoint-must_have_name-_ownedComment.0' body='An ExtensionPoint must have a name.'>
							<annotatedElement xmi:idref='UseCases-ExtensionPoint-must_have_name'/>
						</ownedComment>
						<specification xmi:type='uml:OpaqueExpression' xmi:id='UseCases-ExtensionPoint-must_have_name-_specification' visibility='public'>
							<body>self.name-&gt;notEmpty ()</body>
							<language>OCL</language>
						</specification>
					</ownedRule>
					<generalization xmi:type='uml:Generalization' xmi:id='UseCases-ExtensionPoint-_generalization.0' general='Classes-Kernel-RedefinableElement'/>
					<ownedAttribute xmi:type='uml:Property' xmi:id='UseCases-ExtensionPoint-useCase' name='useCase' visibility='public' type='UseCases-UseCase' association='UseCases-A_extensionPoint_useCase'>
						<subsettedProperty xmi:idref='Classes-Kernel-NamedElement-namespace'/>
						<ownedComment xmi:type='uml:Comment' xmi:id='UseCases-ExtensionPoint-useCase-_ownedComment.0' body='References the use case that owns this extension point.'>
							<annotatedElement xmi:idref='UseCases-ExtensionPoint-useCase'/>
						</ownedComment>
					</ownedAttribute>
				</packagedElement>
				<packagedElement xmi:type='uml:Class' xmi:id='UseCases-UseCase' name='UseCase' visibility='public'>
					<xmi:Extension extender='MagicDraw UML 16.8'>
						<modelExtension/>
					</xmi:Extension>
					<ownedComment xmi:type='uml:Comment' xmi:id='UseCases-UseCase-_ownedComment.0' body='A use case is the specification of a set of actions performed by a system, which yields an observable result that is, typically, of value for one or more actors or other stakeholders of the system.'>
						<annotatedElement xmi:idref='UseCases-UseCase'/>
					</ownedComment>
					<ownedRule xmi:type='uml:Constraint' xmi:id='UseCases-UseCase-binary_associations' name='binary_associations' visibility='public'>
						<constrainedElement xmi:idref='UseCases-UseCase'/>
						<ownedComment xmi:type='uml:Comment' xmi:id='UseCases-UseCase-binary_associations-_ownedComment.0' body='UseCases can only be involved in binary Associations.'>
							<annotatedElement xmi:idref='UseCases-UseCase-binary_associations'/>
						</ownedComment>
						<specification xmi:type='uml:OpaqueExpression' xmi:id='UseCases-UseCase-binary_associations-_specification' visibility='public'>
							<body>true</body>
							<language>OCL</language>
						</specification>
					</ownedRule>
					<ownedRule xmi:type='uml:Constraint' xmi:id='UseCases-UseCase-cannot_include_self' name='cannot_include_self' visibility='public'>
						<constrainedElement xmi:idref='UseCases-UseCase'/>
						<ownedComment xmi:type='uml:Comment' xmi:id='UseCases-UseCase-cannot_include_self-_ownedComment.0' body='A use case cannot include use cases that directly or indirectly include it.'>
							<annotatedElement xmi:idref='UseCases-UseCase-cannot_include_self'/>
						</ownedComment>
						<specification xmi:type='uml:OpaqueExpression' xmi:id='UseCases-UseCase-cannot_include_self-_specification' visibility='public'>
							<body>not self.allIncludedUseCases()-&gt;includes(self)</body>
							<language>OCL</language>
						</specification>
					</ownedRule>
					<ownedRule xmi:type='uml:Constraint' xmi:id='UseCases-UseCase-must_have_name' name='must_have_name' visibility='public'>
						<constrainedElement xmi:idref='UseCases-UseCase'/>
						<ownedComment xmi:type='uml:Comment' xmi:id='UseCases-UseCase-must_have_name-_ownedComment.0' body='A UseCase must have a name.'>
							<annotatedElement xmi:idref='UseCases-UseCase-must_have_name'/>
						</ownedComment>
						<specification xmi:type='uml:OpaqueExpression' xmi:id='UseCases-UseCase-must_have_name-_specification' visibility='public'>
							<body>self.name -&gt; notEmpty ()</body>
							<language>OCL</language>
						</specification>
					</ownedRule>
					<ownedRule xmi:type='uml:Constraint' xmi:id='UseCases-UseCase-no_association_to_use_case' name='no_association_to_use_case' visibility='public'>
						<constrainedElement xmi:idref='UseCases-UseCase'/>
						<ownedComment xmi:type='uml:Comment' xmi:id='UseCases-UseCase-no_association_to_use_case-_ownedComment.0' body='UseCases can not have Associations to UseCases specifying the same subject.'>
							<annotatedElement xmi:idref='UseCases-UseCase-no_association_to_use_case'/>
						</ownedComment>
						<specification xmi:type='uml:OpaqueExpression' xmi:id='UseCases-UseCase-no_association_to_use_case-_specification' visibility='public'>
							<body>true</body>
							<language>OCL</language>
						</specification>
					</ownedRule>
					<generalization xmi:type='uml:Generalization' xmi:id='UseCases-UseCase-_generalization.0' general='CommonBehaviors-BasicBehaviors-BehavioredClassifier'/>
					<ownedAttribute xmi:type='uml:Property' xmi:id='UseCases-UseCase-extend' name='extend' visibility='public' aggregation='composite' type='UseCases-Extend' association='UseCases-A_extend_extension'>
						<subsettedProperty xmi:idref='Classes-Kernel-A_source_directedRelationship-directedRelationship'/>
						<subsettedProperty xmi:idref='Classes-Kernel-Namespace-ownedMember'/>
						<ownedComment xmi:type='uml:Comment' xmi:id='UseCases-UseCase-extend-_ownedComment.0' body='References the Extend relationships owned by this use case.'>
							<annotatedElement xmi:idref='UseCases-UseCase-extend'/>
						</ownedComment>
						<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='UseCases-UseCase-extend-_upperValue' visibility='public' value='*'/>
						<lowerValue xmi:type='uml:LiteralInteger' xmi:id='UseCases-UseCase-extend-_lowerValue' visibility='public'/>
					</ownedAttribute>
					<ownedAttribute xmi:type='uml:Property' xmi:id='UseCases-UseCase-extensionPoint' name='extensionPoint' visibility='public' aggregation='composite' type='UseCases-ExtensionPoint' association='UseCases-A_extensionPoint_useCase'>
						<subsettedProperty xmi:idref='Classes-Kernel-Namespace-ownedMember'/>
						<ownedComment xmi:type='uml:Comment' xmi:id='UseCases-UseCase-extensionPoint-_ownedComment.0' body='References the ExtensionPoints owned by the use case.'>
							<annotatedElement xmi:idref='UseCases-UseCase-extensionPoint'/>
						</ownedComment>
						<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='UseCases-UseCase-extensionPoint-_upperValue' visibility='public' value='*'/>
						<lowerValue xmi:type='uml:LiteralInteger' xmi:id='UseCases-UseCase-extensionPoint-_lowerValue' visibility='public'/>
					</ownedAttribute>
					<ownedAttribute xmi:type='uml:Property' xmi:id='UseCases-UseCase-include' name='include' visibility='public' aggregation='composite' type='UseCases-Include' association='UseCases-A_include_includingCase'>
						<subsettedProperty xmi:idref='Classes-Kernel-A_source_directedRelationship-directedRelationship'/>
						<subsettedProperty xmi:idref='Classes-Kernel-Namespace-ownedMember'/>
						<ownedComment xmi:type='uml:Comment' xmi:id='UseCases-UseCase-include-_ownedComment.0' body='References the Include relationships owned by this use case.'>
							<annotatedElement xmi:idref='UseCases-UseCase-include'/>
						</ownedComment>
						<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='UseCases-UseCase-include-_upperValue' visibility='public' value='*'/>
						<lowerValue xmi:type='uml:LiteralInteger' xmi:id='UseCases-UseCase-include-_lowerValue' visibility='public'/>
					</ownedAttribute>
					<ownedAttribute xmi:type='uml:Property' xmi:id='UseCases-UseCase-subject' name='subject' visibility='public' type='UseCases-Classifier' association='UseCases-A_subject_useCase'>
						<ownedComment xmi:type='uml:Comment' xmi:id='UseCases-UseCase-subject-_ownedComment.0' body='References the subjects to which this use case applies. The subject or its parts realize all the use cases that apply to this subject. Use cases need not be attached to any specific subject, however. The subject may, but need not, own the use cases that apply to it.'>
							<annotatedElement xmi:idref='UseCases-UseCase-subject'/>
						</ownedComment>
						<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='UseCases-UseCase-subject-_upperValue' visibility='public' value='*'/>
						<lowerValue xmi:type='uml:LiteralInteger' xmi:id='UseCases-UseCase-subject-_lowerValue' visibility='public'/>
					</ownedAttribute>
					<ownedOperation xmi:type='uml:Operation' xmi:id='UseCases-UseCase-allIncludedUseCases' name='allIncludedUseCases' visibility='public' isQuery='true' bodyCondition='UseCases-UseCase-allIncludedUseCases-spec'>
						<xmi:Extension extender='MagicDraw UML 16.8'>
							<modelExtension/>
						</xmi:Extension>
						<ownedComment xmi:type='uml:Comment' xmi:id='UseCases-UseCase-allIncludedUseCases-_ownedComment.0' body='The query allIncludedUseCases() returns the transitive closure of all use cases (directly or indirectly) included by this use case.'>
							<annotatedElement xmi:idref='UseCases-UseCase-allIncludedUseCases'/>
						</ownedComment>
						<ownedRule xmi:type='uml:Constraint' xmi:id='UseCases-UseCase-allIncludedUseCases-spec' name='spec' visibility='public'>
							<constrainedElement xmi:idref='UseCases-UseCase-allIncludedUseCases'/>
							<specification xmi:type='uml:OpaqueExpression' xmi:id='UseCases-UseCase-allIncludedUseCases-spec-_specification' visibility='public'>
								<body>result = self.include-&gt;union(self.include-&gt;collect(in | in.allIncludedUseCases()))</body>
								<language>OCL</language>
							</specification>
						</ownedRule>
						<ownedParameter xmi:type='uml:Parameter' xmi:id='UseCases-UseCase-allIncludedUseCases-result' name='result' visibility='public' direction='return' effect='create' type='UseCases-UseCase'>
							<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='UseCases-UseCase-allIncludedUseCases-result-_upperValue' visibility='public' value='*'/>
							<lowerValue xmi:type='uml:LiteralInteger' xmi:id='UseCases-UseCase-allIncludedUseCases-result-_lowerValue' visibility='public'/>
						</ownedParameter>
					</ownedOperation>
				</packagedElement>
				<packagedElement xmi:type='uml:Class' xmi:id='UseCases-Extend' name='Extend' visibility='public'>
					<xmi:Extension extender='MagicDraw UML 16.8'>
						<modelExtension/>
					</xmi:Extension>
					<ownedComment xmi:type='uml:Comment' xmi:id='UseCases-Extend-_ownedComment.0' body='A relationship from an extending use case to an extended use case that specifies how and when the behavior defined in the extending use case can be inserted into the behavior defined in the extended use case.'>
						<annotatedElement xmi:idref='UseCases-Extend'/>
					</ownedComment>
					<ownedRule xmi:type='uml:Constraint' xmi:id='UseCases-Extend-extension_points' name='extension_points' visibility='public'>
						<constrainedElement xmi:idref='UseCases-Extend'/>
						<ownedComment xmi:type='uml:Comment' xmi:id='UseCases-Extend-extension_points-_ownedComment.0' body='The extension points referenced by the extend relationship must belong to the use case that is being extended.'>
							<annotatedElement xmi:idref='UseCases-Extend-extension_points'/>
						</ownedComment>
						<specification xmi:type='uml:OpaqueExpression' xmi:id='UseCases-Extend-extension_points-_specification' visibility='public'>
							<body>extensionLocation-&gt;forAll (xp | extendedCase.extensionPoint-&gt;includes(xp))</body>
							<language>OCL</language>
						</specification>
					</ownedRule>
					<generalization xmi:type='uml:Generalization' xmi:id='UseCases-Extend-_generalization.0' general='Classes-Kernel-DirectedRelationship'/>
					<generalization xmi:type='uml:Generalization' xmi:id='UseCases-Extend-_generalization.1' general='Classes-Kernel-NamedElement'/>
					<ownedAttribute xmi:type='uml:Property' xmi:id='UseCases-Extend-condition' name='condition' visibility='public' aggregation='composite' type='Classes-Kernel-Constraint' association='UseCases-A_condition_extend'>
						<subsettedProperty xmi:idref='Classes-Kernel-Element-ownedElement'/>
						<ownedComment xmi:type='uml:Comment' xmi:id='UseCases-Extend-condition-_ownedComment.0' body='References the condition that must hold when the first extension point is reached for the extension to take place. If no constraint is associated with the extend relationship, the extension is unconditional.'>
							<annotatedElement xmi:idref='UseCases-Extend-condition'/>
						</ownedComment>
						<lowerValue xmi:type='uml:LiteralInteger' xmi:id='UseCases-Extend-condition-_lowerValue' visibility='public'/>
					</ownedAttribute>
					<ownedAttribute xmi:type='uml:Property' xmi:id='UseCases-Extend-extendedCase' name='extendedCase' visibility='public' type='UseCases-UseCase' association='UseCases-A_extendedCase_extend'>
						<subsettedProperty xmi:idref='Classes-Kernel-DirectedRelationship-target'/>
						<ownedComment xmi:type='uml:Comment' xmi:id='UseCases-Extend-extendedCase-_ownedComment.0' body='References the use case that is being extended.'>
							<annotatedElement xmi:idref='UseCases-Extend-extendedCase'/>
						</ownedComment>
					</ownedAttribute>
					<ownedAttribute xmi:type='uml:Property' xmi:id='UseCases-Extend-extension' name='extension' visibility='public' type='UseCases-UseCase' association='UseCases-A_extend_extension'>
						<subsettedProperty xmi:idref='Classes-Kernel-DirectedRelationship-source'/>
						<subsettedProperty xmi:idref='Classes-Kernel-NamedElement-namespace'/>
						<ownedComment xmi:type='uml:Comment' xmi:id='UseCases-Extend-extension-_ownedComment.0' body='References the use case that represents the extension and owns the extend relationship.'>
							<annotatedElement xmi:idref='UseCases-Extend-extension'/>
						</ownedComment>
					</ownedAttribute>
					<ownedAttribute xmi:type='uml:Property' xmi:id='UseCases-Extend-extensionLocation' name='extensionLocation' visibility='public' isOrdered='true' type='UseCases-ExtensionPoint' association='UseCases-A_extensionLocation_extension'>
						<ownedComment xmi:type='uml:Comment' xmi:id='UseCases-Extend-extensionLocation-_ownedComment.0' body='An ordered list of extension points belonging to the extended use case, specifying where the respective behavioral fragments of the extending use case are to be inserted. The first fragment in the extending use case is associated with the first extension point in the list, the second fragment with the second point, and so on. (Note that, in most practical cases, the extending use case has just a single behavior fragment, so that the list of extension points is trivial.)'>
							<annotatedElement xmi:idref='UseCases-Extend-extensionLocation'/>
						</ownedComment>
						<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='UseCases-Extend-extensionLocation-_upperValue' visibility='public' value='*'/>
					</ownedAttribute>
				</packagedElement>
				<packagedElement xmi:type='uml:Association' xmi:id='UseCases-A_extendedCase_extend' name='A_extendedCase_extend' visibility='public'>
					<memberEnd xmi:idref='UseCases-A_extendedCase_extend-extend'/>
					<memberEnd xmi:idref='UseCases-Extend-extendedCase'/>
					<ownedEnd xmi:type='uml:Property' xmi:id='UseCases-A_extendedCase_extend-extend' name='extend' visibility='public' type='UseCases-Extend' association='UseCases-A_extendedCase_extend'>
						<subsettedProperty xmi:idref='Classes-Kernel-A_target_directedRelationship-directedRelationship'/>
						<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='UseCases-A_extendedCase_extend-extend-_upperValue' visibility='public' value='*'/>
						<lowerValue xmi:type='uml:LiteralInteger' xmi:id='UseCases-A_extendedCase_extend-extend-_lowerValue' visibility='public'/>
					</ownedEnd>
				</packagedElement>
			</packagedElement>
			<packagedElement xmi:type='uml:Package' xmi:id='Activities' name='Activities' visibility='public'>
				<packageImport xmi:type='uml:PackageImport' xmi:id='Activities-_packageImport.0' importedPackage='CommonBehaviors'/>
				<packageImport xmi:type='uml:PackageImport' xmi:id='Activities-_packageImport.1' importedPackage='StateMachines'/>
				<packageImport xmi:type='uml:PackageImport' xmi:id='Activities-_packageImport.2' importedPackage='CompositeStructures'/>
				<packagedElement xmi:type='uml:Package' xmi:id='Activities-CompleteStructuredActivities' name='CompleteStructuredActivities' visibility='public'>
					<packageMerge xmi:type='uml:PackageMerge' xmi:id='Activities-CompleteStructuredActivities-_packageMerge.0' mergedPackage='Activities-BasicActivities'/>
					<packageMerge xmi:type='uml:PackageMerge' xmi:id='Activities-CompleteStructuredActivities-_packageMerge.1' mergedPackage='Activities-StructuredActivities'/>
					<packagedElement xmi:type='uml:Association' xmi:id='Activities-CompleteStructuredActivities-A_result_conditionalNode' name='A_result_conditionalNode' visibility='public'>
						<memberEnd xmi:idref='Activities-CompleteStructuredActivities-A_result_conditionalNode-conditionalNode'/>
						<memberEnd xmi:idref='Activities-CompleteStructuredActivities-ConditionalNode-result'/>
						<ownedEnd xmi:type='uml:Property' xmi:id='Activities-CompleteStructuredActivities-A_result_conditionalNode-conditionalNode' name='conditionalNode' visibility='public' type='Activities-CompleteStructuredActivities-ConditionalNode' association='Activities-CompleteStructuredActivities-A_result_conditionalNode'>
							<subsettedProperty xmi:idref='Activities-CompleteStructuredActivities-A_structuredNodeOutput_structuredActivityNode-structuredActivityNode'/>
							<lowerValue xmi:type='uml:LiteralInteger' xmi:id='Activities-CompleteStructuredActivities-A_result_conditionalNode-conditionalNode-_lowerValue' visibility='public'/>
						</ownedEnd>
					</packagedElement>
					<packagedElement xmi:type='uml:Class' xmi:id='Activities-CompleteStructuredActivities-Action' name='Action' visibility='public' isAbstract='true'>
						<generalization xmi:type='uml:Generalization' xmi:id='Activities-CompleteStructuredActivities-Action-_generalization.0' general='Classes-Kernel-NamedElement'/>
						<ownedAttribute xmi:type='uml:Property' xmi:id='Activities-CompleteStructuredActivities-Action-input' name='input' visibility='public' isReadOnly='true' isDerived='true' isDerivedUnion='true' aggregation='composite' type='Activities-CompleteStructuredActivities-InputPin' association='Activities-CompleteStructuredActivities-A_input_action'>
							<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='Activities-CompleteStructuredActivities-Action-input-_upperValue' visibility='public' value='*'/>
							<lowerValue xmi:type='uml:LiteralInteger' xmi:id='Activities-CompleteStructuredActivities-Action-input-_lowerValue' visibility='public'/>
						</ownedAttribute>
						<ownedAttribute xmi:type='uml:Property' xmi:id='Activities-CompleteStructuredActivities-Action-output' name='output' visibility='public' isReadOnly='true' isDerived='true' isDerivedUnion='true' aggregation='composite' type='Activities-CompleteStructuredActivities-OutputPin' association='Activities-CompleteStructuredActivities-A_output_action'>
							<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='Activities-CompleteStructuredActivities-Action-output-_upperValue' visibility='public' value='*'/>
							<lowerValue xmi:type='uml:LiteralInteger' xmi:id='Activities-CompleteStructuredActivities-Action-output-_lowerValue' visibility='public'/>
						</ownedAttribute>
					</packagedElement>
					<packagedElement xmi:type='uml:Class' xmi:id='Activities-CompleteStructuredActivities-StructuredActivityNode' name='StructuredActivityNode' visibility='public'>
						<xmi:Extension extender='MagicDraw UML 16.8'>
							<modelExtension/>
						</xmi:Extension>
						<ownedComment xmi:type='uml:Comment' xmi:id='Activities-CompleteStructuredActivities-StructuredActivityNode-_ownedComment.0' body='Because of the concurrent nature of the execution of actions within and across activities, it can be difficult to guarantee the consistent access and modification of object memory. In order to avoid race conditions or other concurrency-related problems, it is sometimes necessary to isolate the effects of a group of actions from the effects of actions outside the group. This may be indicated by setting the mustIsolate attribute to true on a structured activity node. If a structured activity node is &quot;isolated,&quot; then any object used by an action within the node cannot be accessed by any action outside the node until the structured activity node as a whole completes. Any concurrent actions that would result in accessing such objects are required to have their execution deferred until the completion of the node.'>
							<annotatedElement xmi:idref='Activities-CompleteStructuredActivities-StructuredActivityNode'/>
						</ownedComment>
						<ownedRule xmi:type='uml:Constraint' xmi:id='Activities-CompleteStructuredActivities-StructuredActivityNode-edges' name='edges' visibility='public'>
							<constrainedElement xmi:idref='Activities-CompleteStructuredActivities-StructuredActivityNode'/>
							<ownedComment xmi:type='uml:Comment' xmi:id='Activities-CompleteStructuredActivities-StructuredActivityNode-edges-_ownedComment.0' body='The edges owned by a structured node must have source and target nodes in the structured node, and vice versa.'>
								<annotatedElement xmi:idref='Activities-CompleteStructuredActivities-StructuredActivityNode-edges'/>
							</ownedComment>
							<specification xmi:type='uml:OpaqueExpression' xmi:id='Activities-CompleteStructuredActivities-StructuredActivityNode-edges-_specification' visibility='public'>
								<body>true</body>
								<language>OCL</language>
							</specification>
						</ownedRule>
						<ownedRule xmi:type='uml:Constraint' xmi:id='Activities-CompleteStructuredActivities-StructuredActivityNode-output_pin_edges' name='output_pin_edges' visibility='public'>
							<constrainedElement xmi:idref='Activities-CompleteStructuredActivities-StructuredActivityNode'/>
							<ownedComment xmi:type='uml:Comment' xmi:id='Activities-CompleteStructuredActivities-StructuredActivityNode-output_pin_edges-_ownedComment.0' body='The outgoing edges of the output pins of a StructuredActivityNode must have targets that are not within the StructuredActivityNode.'>
								<annotatedElement xmi:idref='Activities-CompleteStructuredActivities-StructuredActivityNode-output_pin_edges'/>
							</ownedComment>
							<specification xmi:type='uml:OpaqueExpression' xmi:id='Activities-CompleteStructuredActivities-StructuredActivityNode-output_pin_edges-_specification' visibility='public'>
								<body>true</body>
								<language>OCL</language>
							</specification>
						</ownedRule>
						<ownedRule xmi:type='uml:Constraint' xmi:id='Activities-CompleteStructuredActivities-StructuredActivityNode-input_pin_edges' name='input_pin_edges' visibility='public'>
							<constrainedElement xmi:idref='Activities-CompleteStructuredActivities-StructuredActivityNode'/>
							<ownedComment xmi:type='uml:Comment' xmi:id='Activities-CompleteStructuredActivities-StructuredActivityNode-input_pin_edges-_ownedComment.0' body='The incoming edges of the input pins of a StructuredActivityNode must have sources that are not within the StructuredActivityNode.'>
								<annotatedElement xmi:idref='Activities-CompleteStructuredActivities-StructuredActivityNode-input_pin_edges'/>
							</ownedComment>
							<specification xmi:type='uml:OpaqueExpression' xmi:id='Activities-CompleteStructuredActivities-StructuredActivityNode-input_pin_edges-_specification' visibility='public'>
								<body>true</body>
								<language>OCL</language>
							</specification>
						</ownedRule>
						<generalization xmi:type='uml:Generalization' xmi:id='Activities-CompleteStructuredActivities-StructuredActivityNode-_generalization.0' general='Activities-CompleteStructuredActivities-ActivityGroup'/>
						<generalization xmi:type='uml:Generalization' xmi:id='Activities-CompleteStructuredActivities-StructuredActivityNode-_generalization.1' general='Activities-CompleteStructuredActivities-Action'/>
						<ownedAttribute xmi:type='uml:Property' xmi:id='Activities-CompleteStructuredActivities-StructuredActivityNode-edge' name='edge' visibility='public' aggregation='composite' type='Activities-CompleteStructuredActivities-ActivityEdge' association='Activities-CompleteStructuredActivities-A_edge_inStructuredNode'>
							<subsettedProperty xmi:idref='Classes-Kernel-Element-ownedElement'/>
							<subsettedProperty xmi:idref='Activities-CompleteStructuredActivities-ActivityGroup-containedEdge'/>
							<ownedComment xmi:type='uml:Comment' xmi:id='Activities-CompleteStructuredActivities-StructuredActivityNode-edge-_ownedComment.0' body='Edges immediately contained in the structured node.'>
								<annotatedElement xmi:idref='Activities-CompleteStructuredActivities-StructuredActivityNode-edge'/>
							</ownedComment>
							<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='Activities-CompleteStructuredActivities-StructuredActivityNode-edge-_upperValue' visibility='public' value='*'/>
							<lowerValue xmi:type='uml:LiteralInteger' xmi:id='Activities-CompleteStructuredActivities-StructuredActivityNode-edge-_lowerValue' visibility='public'/>
						</ownedAttribute>
						<ownedAttribute xmi:type='uml:Property' xmi:id='Activities-CompleteStructuredActivities-StructuredActivityNode-mustIsolate' name='mustIsolate' visibility='public'>
							<type xmi:type='uml:PrimitiveType' href='http://schema.omg.org/spec/UML/2.3/uml.xml#Boolean'>
								<xmi:Extension extender='MagicDraw UML 16.8'>
									<referenceExtension referentPath='PrimitiveTypes::Boolean' referentType='PrimitiveType'/>
								</xmi:Extension>
							</type>
							<ownedComment xmi:type='uml:Comment' xmi:id='Activities-CompleteStructuredActivities-StructuredActivityNode-mustIsolate-_ownedComment.0' body='If true, then the actions in the node execute in isolation from actions outside the node.'>
								<annotatedElement xmi:idref='Activities-CompleteStructuredActivities-StructuredActivityNode-mustIsolate'/>
							</ownedComment>
							<defaultValue xmi:type='uml:LiteralBoolean' xmi:id='Activities-CompleteStructuredActivities-StructuredActivityNode-mustIsolate-_defaultValue' visibility='public'/>
						</ownedAttribute>
						<ownedAttribute xmi:type='uml:Property' xmi:id='Activities-CompleteStructuredActivities-StructuredActivityNode-structuredNodeInput' name='structuredNodeInput' visibility='public' aggregation='composite' type='Activities-CompleteStructuredActivities-InputPin' association='Activities-CompleteStructuredActivities-A_structuredNodeInput_structuredActivityNode'>
							<subsettedProperty xmi:idref='Activities-CompleteStructuredActivities-Action-input'/>
							<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='Activities-CompleteStructuredActivities-StructuredActivityNode-structuredNodeInput-_upperValue' visibility='public' value='*'/>
							<lowerValue xmi:type='uml:LiteralInteger' xmi:id='Activities-CompleteStructuredActivities-StructuredActivityNode-structuredNodeInput-_lowerValue' visibility='public'/>
						</ownedAttribute>
						<ownedAttribute xmi:type='uml:Property' xmi:id='Activities-CompleteStructuredActivities-StructuredActivityNode-structuredNodeOutput' name='structuredNodeOutput' visibility='public' aggregation='composite' type='Activities-CompleteStructuredActivities-OutputPin' association='Activities-CompleteStructuredActivities-A_structuredNodeOutput_structuredActivityNode'>
							<subsettedProperty xmi:idref='Activities-CompleteStructuredActivities-Action-output'/>
							<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='Activities-CompleteStructuredActivities-StructuredActivityNode-structuredNodeOutput-_upperValue' visibility='public' value='*'/>
							<lowerValue xmi:type='uml:LiteralInteger' xmi:id='Activities-CompleteStructuredActivities-StructuredActivityNode-structuredNodeOutput-_lowerValue' visibility='public'/>
						</ownedAttribute>
					</packagedElement>
					<packagedElement xmi:type='uml:Association' xmi:id='Activities-CompleteStructuredActivities-A_input_action' name='A_input_action' visibility='public' isDerived='true'>
						<memberEnd xmi:idref='Activities-CompleteStructuredActivities-Action-input'/>
						<memberEnd xmi:idref='Activities-CompleteStructuredActivities-A_input_action-action'/>
						<ownedEnd xmi:type='uml:Property' xmi:id='Activities-CompleteStructuredActivities-A_input_action-action' name='action' visibility='public' type='Activities-CompleteStructuredActivities-Action' association='Activities-CompleteStructuredActivities-A_input_action'>
							<lowerValue xmi:type='uml:LiteralInteger' xmi:id='Activities-CompleteStructuredActivities-A_input_action-action-_lowerValue' visibility='public'/>
						</ownedEnd>
					</packagedElement>
					<packagedElement xmi:type='uml:Association' xmi:id='Activities-CompleteStructuredActivities-A_loopVariableInput_loopNode' name='A_loopVariableInput_loopNode' visibility='public'>
						<memberEnd xmi:idref='Activities-CompleteStructuredActivities-LoopNode-loopVariableInput'/>
						<memberEnd xmi:idref='Activities-CompleteStructuredActivities-A_loopVariableInput_loopNode-loopNode'/>
						<ownedEnd xmi:type='uml:Property' xmi:id='Activities-CompleteStructuredActivities-A_loopVariableInput_loopNode-loopNode' name='loopNode' visibility='public' type='Activities-CompleteStructuredActivities-LoopNode' association='Activities-CompleteStructuredActivities-A_loopVariableInput_loopNode'>
							<subsettedProperty xmi:idref='Activities-CompleteStructuredActivities-A_structuredNodeInput_structuredActivityNode-structuredActivityNode'/>
							<lowerValue xmi:type='uml:LiteralInteger' xmi:id='Activities-CompleteStructuredActivities-A_loopVariableInput_loopNode-loopNode-_lowerValue' visibility='public'/>
						</ownedEnd>
