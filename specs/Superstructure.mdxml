								</xmi:Extension>
							</type>
							<ownedComment xmi:type='uml:Comment' xmi:id='Deployments-Artifacts-Artifact-fileName-_ownedComment.0' body='A concrete name that is used to refer to the Artifact in a physical context. Example: file system name, universal resource locator.'>
