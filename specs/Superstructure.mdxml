						</ownedAttribute>
						<ownedAttribute xmi:type='uml:Property' xmi:id='Classes-Kernel-Operation-ownedParameter' name='ownedParameter' visibility='public' isOrdered='true' aggregation='composite' type='Classes-Kernel-Parameter' association='Classes-Kernel-A_ownedParameter_operation'>
