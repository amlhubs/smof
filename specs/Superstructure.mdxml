							</type>
							<ownedComment xmi:type='uml:Comment' xmi:id='Classes-Kernel-Operation-isQuery-_ownedComment.0' body='Specifies whether an execution of the BehavioralFeature leaves the state of the system unchanged (isQuery=true) or whether side effects may occur (isQuery=false).'>
								<annotatedElement xmi:idref='Classes-Kernel-Operation-isQuery'/>
