						<memberEnd xmi:idref='Classes-Kernel-A_constrainedElement_constraint-constraint'/>
						<ownedEnd xmi:type='uml:Property' xmi:id='Classes-Kernel-A_constrainedElement_constraint-constraint' name='constraint' visibility='public' type='Classes-Kernel-Constraint' association='Classes-Kernel-A_constrainedElement_constraint'>
							<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='Classes-Kernel-A_constrainedElement_constraint-constraint-_upperValue' visibility='public' value='*'/>
							<lowerValue xmi:type='uml:LiteralInteger' xmi:id='Classes-Kernel-A_constrainedElement_constraint-constraint-_lowerValue' visibility='public'/>
						</ownedEnd>
					</packagedElement>
					<packagedElement xmi:type='uml:Class' xmi:id='Classes-Kernel-Element' name='Element' visibility='public' isAbstract='true'>
						<xmi:Extension extender='MagicDraw UML 16.8'>
							<modelExtension/>
						</xmi:Extension>
						<ownedComment xmi:type='uml:Comment' xmi:id='Classes-Kernel-Element-_ownedComment.0' body='An element is a constituent of a model. As such, it has the capability of owning other elements.'>
							<annotatedElement xmi:idref='Classes-Kernel-Element'/>
						</ownedComment>
						<ownedRule xmi:type='uml:Constraint' xmi:id='Classes-Kernel-Element-not_own_self' name='not_own_self' visibility='public'>
							<constrainedElement xmi:idref='Classes-Kernel-Element'/>
							<ownedComment xmi:type='uml:Comment' xmi:id='Classes-Kernel-Element-not_own_self-_ownedComment.0' body='An element may not directly or indirectly own itself.'>
								<annotatedElement xmi:idref='Classes-Kernel-Element-not_own_self'/>
							</ownedComment>
							<specification xmi:type='uml:OpaqueExpression' xmi:id='Classes-Kernel-Element-not_own_self-_specification' visibility='public'>
								<body>not self.allOwnedElements()-&gt;includes(self)</body>
								<language>OCL</language>
							</specification>
						</ownedRule>
						<ownedRule xmi:type='uml:Constraint' xmi:id='Classes-Kernel-Element-has_owner' name='has_owner' visibility='public'>
							<constrainedElement xmi:idref='Classes-Kernel-Element'/>
							<ownedComment xmi:type='uml:Comment' xmi:id='Classes-Kernel-Element-has_owner-_ownedComment.0' body='Elements that must be owned must have an owner.'>
								<annotatedElement xmi:idref='Classes-Kernel-Element-has_owner'/>
							</ownedComment>
							<specification xmi:type='uml:OpaqueExpression' xmi:id='Classes-Kernel-Element-has_owner-_specification' visibility='public'>
								<body>self.mustBeOwned() implies owner-&gt;notEmpty()</body>
								<language>OCL</language>
							</specification>
						</ownedRule>
						<ownedAttribute xmi:type='uml:Property' xmi:id='Classes-Kernel-Element-ownedComment' name='ownedComment' visibility='public' aggregation='composite' type='Classes-Kernel-Comment' association='Classes-Kernel-A_ownedComment_owningElement'>
							<subsettedProperty xmi:idref='Classes-Kernel-Element-ownedElement'/>
							<ownedComment xmi:type='uml:Comment' xmi:id='Classes-Kernel-Element-ownedComment-_ownedComment.0' body='The Comments owned by this element.'>
								<annotatedElement xmi:idref='Classes-Kernel-Element-ownedComment'/>
							</ownedComment>
							<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='Classes-Kernel-Element-ownedComment-_upperValue' visibility='public' value='*'/>
							<lowerValue xmi:type='uml:LiteralInteger' xmi:id='Classes-Kernel-Element-ownedComment-_lowerValue' visibility='public'/>
						</ownedAttribute>
						<ownedAttribute xmi:type='uml:Property' xmi:id='Classes-Kernel-Element-ownedElement' name='ownedElement' visibility='public' isReadOnly='true' isDerived='true' isDerivedUnion='true' aggregation='composite' type='Classes-Kernel-Element' association='Classes-Kernel-A_ownedElement_owner'>
							<ownedComment xmi:type='uml:Comment' xmi:id='Classes-Kernel-Element-ownedElement-_ownedComment.0' body='The Elements owned by this element.'>
								<annotatedElement xmi:idref='Classes-Kernel-Element-ownedElement'/>
							</ownedComment>
							<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='Classes-Kernel-Element-ownedElement-_upperValue' visibility='public' value='*'/>
							<lowerValue xmi:type='uml:LiteralInteger' xmi:id='Classes-Kernel-Element-ownedElement-_lowerValue' visibility='public'/>
						</ownedAttribute>
						<ownedAttribute xmi:type='uml:Property' xmi:id='Classes-Kernel-Element-owner' name='owner' visibility='public' isReadOnly='true' isDerived='true' isDerivedUnion='true' type='Classes-Kernel-Element' association='Classes-Kernel-A_ownedElement_owner'>
							<ownedComment xmi:type='uml:Comment' xmi:id='Classes-Kernel-Element-owner-_ownedComment.0' body='The Element that owns this element.'>
								<annotatedElement xmi:idref='Classes-Kernel-Element-owner'/>
							</ownedComment>
							<lowerValue xmi:type='uml:LiteralInteger' xmi:id='Classes-Kernel-Element-owner-_lowerValue' visibility='public'/>
						</ownedAttribute>
						<ownedOperation xmi:type='uml:Operation' xmi:id='Classes-Kernel-Element-allOwnedElements' name='allOwnedElements' visibility='public' isQuery='true' bodyCondition='Classes-Kernel-Element-allOwnedElements-spec'>
							<xmi:Extension extender='MagicDraw UML 16.8'>
								<modelExtension/>
							</xmi:Extension>
							<ownedComment xmi:type='uml:Comment' xmi:id='Classes-Kernel-Element-allOwnedElements-_ownedComment.0' body='The query allOwnedElements() gives all of the direct and indirect owned elements of an element.'>
								<annotatedElement xmi:idref='Classes-Kernel-Element-allOwnedElements'/>
							</ownedComment>
							<ownedRule xmi:type='uml:Constraint' xmi:id='Classes-Kernel-Element-allOwnedElements-spec' name='spec' visibility='public'>
								<constrainedElement xmi:idref='Classes-Kernel-Element-allOwnedElements'/>
								<specification xmi:type='uml:OpaqueExpression' xmi:id='Classes-Kernel-Element-allOwnedElements-spec-_specification' visibility='public'>
									<body>result = ownedElement-&gt;union(ownedElement-&gt;collect(e | e.allOwnedElements()))</body>
									<language>OCL</language>
								</specification>
							</ownedRule>
							<ownedParameter xmi:type='uml:Parameter' xmi:id='Classes-Kernel-Element-allOwnedElements-result' name='result' visibility='public' direction='return' effect='create' type='Classes-Kernel-Element'>
								<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='Classes-Kernel-Element-allOwnedElements-result-_upperValue' visibility='public' value='*'/>
								<lowerValue xmi:type='uml:LiteralInteger' xmi:id='Classes-Kernel-Element-allOwnedElements-result-_lowerValue' visibility='public'/>
							</ownedParameter>
						</ownedOperation>
						<ownedOperation xmi:type='uml:Operation' xmi:id='Classes-Kernel-Element-mustBeOwned' name='mustBeOwned' visibility='public' isQuery='true' bodyCondition='Classes-Kernel-Element-mustBeOwned-spec'>
							<xmi:Extension extender='MagicDraw UML 16.8'>
								<modelExtension/>
							</xmi:Extension>
							<ownedComment xmi:type='uml:Comment' xmi:id='Classes-Kernel-Element-mustBeOwned-_ownedComment.0' body='The query mustBeOwned() indicates whether elements of this type must have an owner. Subclasses of Element that do not require an owner must override this operation.'>
								<annotatedElement xmi:idref='Classes-Kernel-Element-mustBeOwned'/>
							</ownedComment>
							<ownedRule xmi:type='uml:Constraint' xmi:id='Classes-Kernel-Element-mustBeOwned-spec' name='spec' visibility='public'>
								<constrainedElement xmi:idref='Classes-Kernel-Element-mustBeOwned'/>
								<specification xmi:type='uml:OpaqueExpression' xmi:id='Classes-Kernel-Element-mustBeOwned-spec-_specification' visibility='public'>
									<body>result = true</body>
									<language>OCL</language>
								</specification>
							</ownedRule>
							<ownedParameter xmi:type='uml:Parameter' xmi:id='Classes-Kernel-Element-mustBeOwned-result' name='result' visibility='public' direction='return' effect='create'>
								<type xmi:type='uml:PrimitiveType' href='http://schema.omg.org/spec/UML/2.3/uml.xml#Boolean'>
									<xmi:Extension extender='MagicDraw UML 16.8'>
										<referenceExtension referentPath='PrimitiveTypes::Boolean' referentType='PrimitiveType'/>
									</xmi:Extension>
								</type>
							</ownedParameter>
						</ownedOperation>
					</packagedElement>
					<packagedElement xmi:type='uml:Class' xmi:id='Classes-Kernel-Enumeration' name='Enumeration' visibility='public'>
						<ownedComment xmi:type='uml:Comment' xmi:id='Classes-Kernel-Enumeration-_ownedComment.0' body='An enumeration is a data type whose values are enumerated in the model as enumeration literals.'>
							<annotatedElement xmi:idref='Classes-Kernel-Enumeration'/>
						</ownedComment>
						<generalization xmi:type='uml:Generalization' xmi:id='Classes-Kernel-Enumeration-_generalization.0' general='Classes-Kernel-DataType'/>
						<ownedAttribute xmi:type='uml:Property' xmi:id='Classes-Kernel-Enumeration-ownedLiteral' name='ownedLiteral' visibility='public' isOrdered='true' aggregation='composite' type='Classes-Kernel-EnumerationLiteral' association='Classes-Kernel-A_ownedLiteral_enumeration'>
							<subsettedProperty xmi:idref='Classes-Kernel-Namespace-ownedMember'/>
							<ownedComment xmi:type='uml:Comment' xmi:id='Classes-Kernel-Enumeration-ownedLiteral-_ownedComment.0' body='The ordered set of literals for this Enumeration.'>
								<annotatedElement xmi:idref='Classes-Kernel-Enumeration-ownedLiteral'/>
							</ownedComment>
							<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='Classes-Kernel-Enumeration-ownedLiteral-_upperValue' visibility='public' value='*'/>
							<lowerValue xmi:type='uml:LiteralInteger' xmi:id='Classes-Kernel-Enumeration-ownedLiteral-_lowerValue' visibility='public'/>
						</ownedAttribute>
					</packagedElement>
					<packagedElement xmi:type='uml:Association' xmi:id='Classes-Kernel-A_ownedParameter_operation' name='A_ownedParameter_operation' visibility='public'>
						<memberEnd xmi:idref='Classes-Kernel-Parameter-operation'/>
						<memberEnd xmi:idref='Classes-Kernel-Operation-ownedParameter'/>
					</packagedElement>
					<packagedElement xmi:type='uml:Association' xmi:id='Classes-Kernel-A_lowerValue_owningLower' name='A_lowerValue_owningLower' visibility='public'>
						<memberEnd xmi:idref='Classes-Kernel-MultiplicityElement-lowerValue'/>
						<memberEnd xmi:idref='Classes-Kernel-A_lowerValue_owningLower-owningLower'/>
						<ownedEnd xmi:type='uml:Property' xmi:id='Classes-Kernel-A_lowerValue_owningLower-owningLower' name='owningLower' visibility='public' type='Classes-Kernel-MultiplicityElement' association='Classes-Kernel-A_lowerValue_owningLower'>
							<subsettedProperty xmi:idref='Classes-Kernel-Element-owner'/>
