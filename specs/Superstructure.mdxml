							<redefinedProperty xmi:idref='Activities-StructuredActivities-StructuredActivityNode-node'/>
							<ownedComment xmi:type='uml:Comment' xmi:id='Activities-StructuredActivities-SequenceNode-executableNode-_ownedComment.0' body='An ordered set of executable nodes.'>
