						</xmi:Extension>
						<ownedComment xmi:type='uml:Comment' xmi:id='Activities-BasicActivities-ActivityEdge-_ownedComment.0' body='An activity edge is an abstract class for directed connections between two activity nodes.'>
							<annotatedElement xmi:idref='Activities-BasicActivities-ActivityEdge'/>
						</ownedComment>
						<ownedRule xmi:type='uml:Constraint' xmi:id='Activities-BasicActivities-ActivityEdge-owned' name='owned' visibility='public'>
