						<memberEnd xmi:idref='Actions-IntermediateActions-A_result_clearStructuralFeatureAction-clearStructuralFeatureAction'/>
						<ownedEnd xmi:type='uml:Property' xmi:id='Actions-IntermediateActions-A_result_clearStructuralFeatureAction-clearStructuralFeatureAction' name='clearStructuralFeatureAction' visibility='public' type='Actions-IntermediateActions-ClearStructuralFeatureAction' association='Actions-IntermediateActions-A_result_clearStructuralFeatureAction'>
