						<ownedRule xmi:type='uml:Constraint' xmi:id='Activities-IntermediateActivities-ActivityPartition-represents_part' name='represents_part' visibility='public'>
							<constrainedElement xmi:idref='Activities-IntermediateActivities-ActivityPartition'/>
							<ownedComment xmi:type='uml:Comment' xmi:id='Activities-IntermediateActivities-ActivityPartition-represents_part-_ownedComment.0' body='If a partition represents a part, then all the non-external partitions in the same dimension and at the same level of nesting in that dimension must represent parts directly contained in the internal structure of the same classifier.'>
