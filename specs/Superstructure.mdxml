						<ownedAttribute xmi:type='uml:Property' xmi:id='Activities-BasicActivities-ActivityEdge-activity' name='activity' visibility='public' type='Activities-BasicActivities-Activity' association='Activities-BasicActivities-A_edge_activity'>
