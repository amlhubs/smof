							<subsettedProperty xmi:idref='Classes-Kernel-Element-ownedElement'/>
							<subsettedProperty xmi:idref='Classes-Dependencies-NamedElement-clientDependency'/>
							<ownedComment xmi:type='uml:Comment' xmi:id='Deployments-Nodes-DeploymentTarget-deployment-_ownedComment.0' body='The set of Deployments for a DeploymentTarget.'>
