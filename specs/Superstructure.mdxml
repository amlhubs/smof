						<ownedRule xmi:type='uml:Constraint' xmi:id='Activities-BasicActivities-ObjectFlow-same_upper_bounds' name='same_upper_bounds' visibility='public'>
							<constrainedElement xmi:idref='Activities-BasicActivities-ObjectFlow'/>
							<ownedComment xmi:type='uml:Comment' xmi:id='Activities-BasicActivities-ObjectFlow-same_upper_bounds-_ownedComment.0' body='Object nodes connected by an object flow, with optionally intervening control nodes, must have the same upper bounds.'>
