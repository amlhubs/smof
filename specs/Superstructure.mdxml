							<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='CommonBehaviors-SimpleTime-A_event_durationObservation-durationObservation-_upperValue' visibility='public' value='*'/>
							<lowerValue xmi:type='uml:LiteralInteger' xmi:id='CommonBehaviors-SimpleTime-A_event_durationObservation-durationObservation-_lowerValue' visibility='public'/>
