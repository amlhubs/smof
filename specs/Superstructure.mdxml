							<subsettedProperty xmi:idref='Classes-Kernel-RedefinableElement-redefinedElement'/>
							<ownedComment xmi:type='uml:Comment' xmi:id='Classes-Kernel-Operation-redefinedOperation-_ownedComment.0' body='References the Operations that are redefined by this Operation.'>
								<annotatedElement xmi:idref='Classes-Kernel-Operation-redefinedOperation'/>
							</ownedComment>
							<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='Classes-Kernel-Operation-redefinedOperation-_upperValue' visibility='public' value='*'/>
							<lowerValue xmi:type='uml:LiteralInteger' xmi:id='Classes-Kernel-Operation-redefinedOperation-_lowerValue' visibility='public'/>
						</ownedAttribute>
