							<ownedParameter xmi:type='uml:Parameter' xmi:id='Interactions-BasicInteractions-Message-messageKind.1-result' name='result' visibility='public' direction='return' effect='create' type='Interactions-BasicInteractions-MessageKind'/>
						</ownedOperation>
					</packagedElement>
					<packagedElement xmi:type='uml:Association' xmi:id='Interactions-BasicInteractions-A_message_messageEnd' name='A_message_messageEnd' visibility='public'>
						<memberEnd xmi:idref='Interactions-BasicInteractions-MessageEnd-message'/>
						<memberEnd xmi:idref='Interactions-BasicInteractions-A_message_messageEnd-messageEnd'/>
						<ownedEnd xmi:type='uml:Property' xmi:id='Interactions-BasicInteractions-A_message_messageEnd-messageEnd' name='messageEnd' visibility='public' type='Interactions-BasicInteractions-MessageEnd' association='Interactions-BasicInteractions-A_message_messageEnd'>
							<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='Interactions-BasicInteractions-A_message_messageEnd-messageEnd-_upperValue' visibility='public' value='2'/>
							<lowerValue xmi:type='uml:LiteralInteger' xmi:id='Interactions-BasicInteractions-A_message_messageEnd-messageEnd-_lowerValue' visibility='public'/>
						</ownedEnd>
					</packagedElement>
					<packagedElement xmi:type='uml:Class' xmi:id='Interactions-BasicInteractions-DestructionOccurenceSpecification' name='DestructionOccurenceSpecification' visibility='public'>
						<xmi:Extension extender='MagicDraw UML 16.8'>
							<modelExtension/>
						</xmi:Extension>
						<ownedComment xmi:type='uml:Comment' xmi:id='Interactions-BasicInteractions-DestructionOccurenceSpecification-_ownedComment.0' body='A destruction event models the destruction of an object.'>
							<annotatedElement xmi:idref='Interactions-BasicInteractions-DestructionOccurenceSpecification'/>
						</ownedComment>
						<ownedRule xmi:type='uml:Constraint' xmi:id='Interactions-BasicInteractions-DestructionOccurenceSpecification-no_occurrence_specifications_below' name='no_occurrence_specifications_below' visibility='public'>
							<constrainedElement xmi:idref='Interactions-BasicInteractions-DestructionOccurenceSpecification'/>
							<ownedComment xmi:type='uml:Comment' xmi:id='Interactions-BasicInteractions-DestructionOccurenceSpecification-no_occurrence_specifications_below-_ownedComment.0' body='No other OccurrenceSpecifications on a given Lifeline in an InteractionOperand may appear below a DestructionOccurrenceSpecification.'>
								<annotatedElement xmi:idref='Interactions-BasicInteractions-DestructionOccurenceSpecification-no_occurrence_specifications_below'/>
							</ownedComment>
							<specification xmi:type='uml:OpaqueExpression' xmi:id='Interactions-BasicInteractions-DestructionOccurenceSpecification-no_occurrence_specifications_below-_specification' visibility='public'>
								<body>true</body>
								<language>OCL</language>
							</specification>
						</ownedRule>
						<generalization xmi:type='uml:Generalization' xmi:id='Interactions-BasicInteractions-DestructionOccurenceSpecification-_generalization.0' general='Interactions-BasicInteractions-MessageOccurrenceSpecification'/>
					</packagedElement>
					<packagedElement xmi:type='uml:Class' xmi:id='Interactions-BasicInteractions-GeneralOrdering' name='GeneralOrdering' visibility='public'>
						<xmi:Extension extender='MagicDraw UML 16.8'>
							<modelExtension/>
						</xmi:Extension>
						<ownedComment xmi:type='uml:Comment' xmi:id='Interactions-BasicInteractions-GeneralOrdering-_ownedComment.0' body='A general ordering represents a binary relation between two occurrence specifications, to describe that one occurrence specification must occur before the other in a valid trace. This mechanism provides the ability to define partial orders of occurrence cpecifications that may otherwise not have a specified order.'>
							<annotatedElement xmi:idref='Interactions-BasicInteractions-GeneralOrdering'/>
						</ownedComment>
						<ownedRule xmi:type='uml:Constraint' xmi:id='Interactions-BasicInteractions-GeneralOrdering-irreflexsive_transitive_closure' name='irreflexsive_transitive_closure' visibility='public'>
							<constrainedElement xmi:idref='Interactions-BasicInteractions-GeneralOrdering'/>
							<ownedComment xmi:type='uml:Comment' xmi:id='Interactions-BasicInteractions-GeneralOrdering-irreflexsive_transitive_closure-_ownedComment.0' body='An occurrence specification must not be ordered relative to itself through a series of general orderings. (In other words, the transitive closure of the general orderings is irreflexive.)'>
								<annotatedElement xmi:idref='Interactions-BasicInteractions-GeneralOrdering-irreflexsive_transitive_closure'/>
							</ownedComment>
							<specification xmi:type='uml:OpaqueExpression' xmi:id='Interactions-BasicInteractions-GeneralOrdering-irreflexsive_transitive_closure-_specification' visibility='public'>
								<body>start.lifeline = finish.lifeline</body>
								<language>OCL</language>
							</specification>
						</ownedRule>
						<generalization xmi:type='uml:Generalization' xmi:id='Interactions-BasicInteractions-GeneralOrdering-_generalization.0' general='Classes-Kernel-NamedElement'/>
						<ownedAttribute xmi:type='uml:Property' xmi:id='Interactions-BasicInteractions-GeneralOrdering-after' name='after' visibility='public' type='Interactions-BasicInteractions-OccurrenceSpecification' association='Interactions-BasicInteractions-A_toBefore_after'>
							<ownedComment xmi:type='uml:Comment' xmi:id='Interactions-BasicInteractions-GeneralOrdering-after-_ownedComment.0' body='The OccurrenceSpecification referenced comes after the OccurrenceSpecification referenced by before.'>
								<annotatedElement xmi:idref='Interactions-BasicInteractions-GeneralOrdering-after'/>
							</ownedComment>
						</ownedAttribute>
						<ownedAttribute xmi:type='uml:Property' xmi:id='Interactions-BasicInteractions-GeneralOrdering-before' name='before' visibility='public' type='Interactions-BasicInteractions-OccurrenceSpecification' association='Interactions-BasicInteractions-A_before_toAfter'>
							<ownedComment xmi:type='uml:Comment' xmi:id='Interactions-BasicInteractions-GeneralOrdering-before-_ownedComment.0' body='The OccurrenceSpecification referenced comes before the OccurrenceSpecification referenced by after.'>
								<annotatedElement xmi:idref='Interactions-BasicInteractions-GeneralOrdering-before'/>
							</ownedComment>
						</ownedAttribute>
					</packagedElement>
					<packagedElement xmi:type='uml:Association' xmi:id='Interactions-BasicInteractions-A_generalOrdering_interactionFragment' name='A_generalOrdering_interactionFragment' visibility='public'>
						<memberEnd xmi:idref='Interactions-BasicInteractions-InteractionFragment-generalOrdering'/>
						<memberEnd xmi:idref='Interactions-BasicInteractions-A_generalOrdering_interactionFragment-interactionFragment'/>
						<ownedEnd xmi:type='uml:Property' xmi:id='Interactions-BasicInteractions-A_generalOrdering_interactionFragment-interactionFragment' name='interactionFragment' visibility='public' type='Interactions-BasicInteractions-InteractionFragment' association='Interactions-BasicInteractions-A_generalOrdering_interactionFragment'>
							<subsettedProperty xmi:idref='Classes-Kernel-Element-owner'/>
							<lowerValue xmi:type='uml:LiteralInteger' xmi:id='Interactions-BasicInteractions-A_generalOrdering_interactionFragment-interactionFragment-_lowerValue' visibility='public'/>
						</ownedEnd>
					</packagedElement>
					<packagedElement xmi:type='uml:Class' xmi:id='Interactions-BasicInteractions-Lifeline' name='Lifeline' visibility='public'>
						<xmi:Extension extender='MagicDraw UML 16.8'>
							<modelExtension/>
						</xmi:Extension>
						<ownedComment xmi:type='uml:Comment' xmi:id='Interactions-BasicInteractions-Lifeline-_ownedComment.0' body='A lifeline represents an individual participant in the interaction. While parts and structural features may have multiplicity greater than 1, lifelines represent only one interacting entity.'>
							<annotatedElement xmi:idref='Interactions-BasicInteractions-Lifeline'/>
						</ownedComment>
						<ownedRule xmi:type='uml:Constraint' xmi:id='Interactions-BasicInteractions-Lifeline-selector_specified' name='selector_specified' visibility='public'>
							<constrainedElement xmi:idref='Interactions-BasicInteractions-Lifeline'/>
							<ownedComment xmi:type='uml:Comment' xmi:id='Interactions-BasicInteractions-Lifeline-selector_specified-_ownedComment.0' body='The selector for a Lifeline must only be specified if the referenced Part is multivalued.'>
								<annotatedElement xmi:idref='Interactions-BasicInteractions-Lifeline-selector_specified'/>
							</ownedComment>
							<specification xmi:type='uml:OpaqueExpression' xmi:id='Interactions-BasicInteractions-Lifeline-selector_specified-_specification' visibility='public'>
								<body>(self.selector-&gt;isEmpty() implies not self.represents.isMultivalued()) or
(not self.selector-&gt;isEmpty() implies self.represents.isMultivalued())
</body>
								<language>OCL</language>
							</specification>
						</ownedRule>
						<ownedRule xmi:type='uml:Constraint' xmi:id='Interactions-BasicInteractions-Lifeline-interaction_uses_share_lifeline' name='interaction_uses_share_lifeline' visibility='public'>
							<constrainedElement xmi:idref='Interactions-BasicInteractions-Lifeline'/>
							<ownedComment xmi:type='uml:Comment' xmi:id='Interactions-BasicInteractions-Lifeline-interaction_uses_share_lifeline-_ownedComment.0' body='If two (or more) InteractionUses within one Interaction, refer to Interactions with &#39;common Lifelines,&#39; those Lifelines must also appear in the Interaction with the InteractionUses. By common Lifelines we mean Lifelines with the same selector and represents associations.'>
								<annotatedElement xmi:idref='Interactions-BasicInteractions-Lifeline-interaction_uses_share_lifeline'/>
							</ownedComment>
							<specification xmi:type='uml:OpaqueExpression' xmi:id='Interactions-BasicInteractions-Lifeline-interaction_uses_share_lifeline-_specification' visibility='public'>
								<body>true</body>
								<language>OCL</language>
							</specification>
						</ownedRule>
						<ownedRule xmi:type='uml:Constraint' xmi:id='Interactions-BasicInteractions-Lifeline-same_classifier' name='same_classifier' visibility='public'>
							<constrainedElement xmi:idref='Interactions-BasicInteractions-Lifeline'/>
							<ownedComment xmi:type='uml:Comment' xmi:id='Interactions-BasicInteractions-Lifeline-same_classifier-_ownedComment.0' body='The classifier containing the referenced ConnectableElement must be the same classifier, or an ancestor, of the classifier that contains the interaction enclosing this lifeline.'>
								<annotatedElement xmi:idref='Interactions-BasicInteractions-Lifeline-same_classifier'/>
							</ownedComment>
							<specification xmi:type='uml:OpaqueExpression' xmi:id='Interactions-BasicInteractions-Lifeline-same_classifier-_specification' visibility='public'>
								<body>if (represents-&gt;notEmpty()) then
(if selector-&gt;notEmpty() then represents.isMultivalued() else not represents.isMultivalued())
</body>
								<language>OCL</language>
							</specification>
						</ownedRule>
						<generalization xmi:type='uml:Generalization' xmi:id='Interactions-BasicInteractions-Lifeline-_generalization.0' general='Classes-Kernel-NamedElement'/>
						<ownedAttribute xmi:type='uml:Property' xmi:id='Interactions-BasicInteractions-Lifeline-coveredBy' name='coveredBy' visibility='public' type='Interactions-BasicInteractions-InteractionFragment' association='Interactions-BasicInteractions-A_covered_coveredBy'>
							<ownedComment xmi:type='uml:Comment' xmi:id='Interactions-BasicInteractions-Lifeline-coveredBy-_ownedComment.0' body='References the InteractionFragments in which this Lifeline takes part.'>
								<annotatedElement xmi:idref='Interactions-BasicInteractions-Lifeline-coveredBy'/>
							</ownedComment>
							<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='Interactions-BasicInteractions-Lifeline-coveredBy-_upperValue' visibility='public' value='*'/>
							<lowerValue xmi:type='uml:LiteralInteger' xmi:id='Interactions-BasicInteractions-Lifeline-coveredBy-_lowerValue' visibility='public'/>
						</ownedAttribute>
						<ownedAttribute xmi:type='uml:Property' xmi:id='Interactions-BasicInteractions-Lifeline-interaction' name='interaction' visibility='public' type='Interactions-BasicInteractions-Interaction' association='Interactions-BasicInteractions-A_lifeline_interaction'>
							<subsettedProperty xmi:idref='Classes-Kernel-NamedElement-namespace'/>
							<ownedComment xmi:type='uml:Comment' xmi:id='Interactions-BasicInteractions-Lifeline-interaction-_ownedComment.0' body='References the Interaction enclosing this Lifeline.'>
								<annotatedElement xmi:idref='Interactions-BasicInteractions-Lifeline-interaction'/>
							</ownedComment>
						</ownedAttribute>
						<ownedAttribute xmi:type='uml:Property' xmi:id='Interactions-BasicInteractions-Lifeline-represents' name='represents' visibility='public' type='CompositeStructures-InternalStructures-ConnectableElement' association='Interactions-BasicInteractions-A_represents_lifeline'>
							<ownedComment xmi:type='uml:Comment' xmi:id='Interactions-BasicInteractions-Lifeline-represents-_ownedComment.0' body='References the ConnectableElement within the classifier that contains the enclosing interaction.'>
								<annotatedElement xmi:idref='Interactions-BasicInteractions-Lifeline-represents'/>
							</ownedComment>
							<lowerValue xmi:type='uml:LiteralInteger' xmi:id='Interactions-BasicInteractions-Lifeline-represents-_lowerValue' visibility='public'/>
						</ownedAttribute>
						<ownedAttribute xmi:type='uml:Property' xmi:id='Interactions-BasicInteractions-Lifeline-selector' name='selector' visibility='public' aggregation='composite' type='Classes-Kernel-ValueSpecification' association='Interactions-BasicInteractions-A_selector_lifeline'>
							<subsettedProperty xmi:idref='Classes-Kernel-Element-ownedElement'/>
							<ownedComment xmi:type='uml:Comment' xmi:id='Interactions-BasicInteractions-Lifeline-selector-_ownedComment.0' body='If the referenced ConnectableElement is multivalued, then this specifies the specific individual part within that set.'>
								<annotatedElement xmi:idref='Interactions-BasicInteractions-Lifeline-selector'/>
							</ownedComment>
							<lowerValue xmi:type='uml:LiteralInteger' xmi:id='Interactions-BasicInteractions-Lifeline-selector-_lowerValue' visibility='public'/>
						</ownedAttribute>
					</packagedElement>
					<packagedElement xmi:type='uml:Association' xmi:id='Interactions-BasicInteractions-A_lifeline_interaction' name='A_lifeline_interaction' visibility='public'>
						<memberEnd xmi:idref='Interactions-BasicInteractions-Lifeline-interaction'/>
						<memberEnd xmi:idref='Interactions-BasicInteractions-Interaction-lifeline'/>
					</packagedElement>
					<packagedElement xmi:type='uml:Class' xmi:id='Interactions-BasicInteractions-Interaction' name='Interaction' visibility='public'>
						<ownedComment xmi:type='uml:Comment' xmi:id='Interactions-BasicInteractions-Interaction-_ownedComment.0' body='An interaction is a unit of behavior that focuses on the observable exchange of information between connectable elements.'>
							<annotatedElement xmi:idref='Interactions-BasicInteractions-Interaction'/>
						</ownedComment>
						<generalization xmi:type='uml:Generalization' xmi:id='Interactions-BasicInteractions-Interaction-_generalization.0' general='CommonBehaviors-BasicBehaviors-Behavior'/>
						<generalization xmi:type='uml:Generalization' xmi:id='Interactions-BasicInteractions-Interaction-_generalization.1' general='Interactions-BasicInteractions-InteractionFragment'/>
						<ownedAttribute xmi:type='uml:Property' xmi:id='Interactions-BasicInteractions-Interaction-action' name='action' visibility='public' aggregation='composite' type='Actions-BasicActions-Action' association='Interactions-BasicInteractions-A_action_interaction'>
							<subsettedProperty xmi:idref='Classes-Kernel-Element-ownedElement'/>
							<ownedComment xmi:type='uml:Comment' xmi:id='Interactions-BasicInteractions-Interaction-action-_ownedComment.0' body='Actions owned by the Interaction.'>
								<annotatedElement xmi:idref='Interactions-BasicInteractions-Interaction-action'/>
							</ownedComment>
							<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='Interactions-BasicInteractions-Interaction-action-_upperValue' visibility='public' value='*'/>
							<lowerValue xmi:type='uml:LiteralInteger' xmi:id='Interactions-BasicInteractions-Interaction-action-_lowerValue' visibility='public'/>
						</ownedAttribute>
						<ownedAttribute xmi:type='uml:Property' xmi:id='Interactions-BasicInteractions-Interaction-fragment' name='fragment' visibility='public' isOrdered='true' aggregation='composite' type='Interactions-BasicInteractions-InteractionFragment' association='Interactions-BasicInteractions-A_fragment_enclosingInteraction'>
							<subsettedProperty xmi:idref='Classes-Kernel-Namespace-ownedMember'/>
							<ownedComment xmi:type='uml:Comment' xmi:id='Interactions-BasicInteractions-Interaction-fragment-_ownedComment.0' body='The ordered set of fragments in the Interaction.'>
								<annotatedElement xmi:idref='Interactions-BasicInteractions-Interaction-fragment'/>
							</ownedComment>
							<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='Interactions-BasicInteractions-Interaction-fragment-_upperValue' visibility='public' value='*'/>
							<lowerValue xmi:type='uml:LiteralInteger' xmi:id='Interactions-BasicInteractions-Interaction-fragment-_lowerValue' visibility='public'/>
						</ownedAttribute>
						<ownedAttribute xmi:type='uml:Property' xmi:id='Interactions-BasicInteractions-Interaction-lifeline' name='lifeline' visibility='public' aggregation='composite' type='Interactions-BasicInteractions-Lifeline' association='Interactions-BasicInteractions-A_lifeline_interaction'>
							<subsettedProperty xmi:idref='Classes-Kernel-Namespace-ownedMember'/>
							<ownedComment xmi:type='uml:Comment' xmi:id='Interactions-BasicInteractions-Interaction-lifeline-_ownedComment.0' body='Specifies the participants in this Interaction.'>
								<annotatedElement xmi:idref='Interactions-BasicInteractions-Interaction-lifeline'/>
							</ownedComment>
							<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='Interactions-BasicInteractions-Interaction-lifeline-_upperValue' visibility='public' value='*'/>
							<lowerValue xmi:type='uml:LiteralInteger' xmi:id='Interactions-BasicInteractions-Interaction-lifeline-_lowerValue' visibility='public'/>
						</ownedAttribute>
						<ownedAttribute xmi:type='uml:Property' xmi:id='Interactions-BasicInteractions-Interaction-message' name='message' visibility='public' aggregation='composite' type='Interactions-BasicInteractions-Message' association='Interactions-BasicInteractions-A_message_interaction'>
							<subsettedProperty xmi:idref='Classes-Kernel-Namespace-ownedMember'/>
							<ownedComment xmi:type='uml:Comment' xmi:id='Interactions-BasicInteractions-Interaction-message-_ownedComment.0' body='The Messages contained in this Interaction.'>
								<annotatedElement xmi:idref='Interactions-BasicInteractions-Interaction-message'/>
							</ownedComment>
							<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='Interactions-BasicInteractions-Interaction-message-_upperValue' visibility='public' value='*'/>
							<lowerValue xmi:type='uml:LiteralInteger' xmi:id='Interactions-BasicInteractions-Interaction-message-_lowerValue' visibility='public'/>
						</ownedAttribute>
					</packagedElement>
					<packagedElement xmi:type='uml:Class' xmi:id='Interactions-BasicInteractions-ExecutionSpecification' name='ExecutionSpecification' visibility='public' isAbstract='true'>
						<xmi:Extension extender='MagicDraw UML 16.8'>
							<modelExtension/>
						</xmi:Extension>
						<ownedComment xmi:type='uml:Comment' xmi:id='Interactions-BasicInteractions-ExecutionSpecification-_ownedComment.0' body='An execution specification is a specification of the execution of a unit of behavior or action within the lifeline. The duration of an execution specification is represented by two cccurrence specifications, the start occurrence specification and the finish occurrence specification.'>
							<annotatedElement xmi:idref='Interactions-BasicInteractions-ExecutionSpecification'/>
						</ownedComment>
						<ownedRule xmi:type='uml:Constraint' xmi:id='Interactions-BasicInteractions-ExecutionSpecification-same_lifeline' name='same_lifeline' visibility='public'>
							<constrainedElement xmi:idref='Interactions-BasicInteractions-ExecutionSpecification'/>
							<ownedComment xmi:type='uml:Comment' xmi:id='Interactions-BasicInteractions-ExecutionSpecification-same_lifeline-_ownedComment.0' body='The startEvent and the finishEvent must be on the same Lifeline'>
								<annotatedElement xmi:idref='Interactions-BasicInteractions-ExecutionSpecification-same_lifeline'/>
							</ownedComment>
							<specification xmi:type='uml:OpaqueExpression' xmi:id='Interactions-BasicInteractions-ExecutionSpecification-same_lifeline-_specification' visibility='public'>
								<body>start.lifeline = finish.lifeline</body>
								<language>OCL</language>
							</specification>
						</ownedRule>
						<generalization xmi:type='uml:Generalization' xmi:id='Interactions-BasicInteractions-ExecutionSpecification-_generalization.0' general='Interactions-BasicInteractions-InteractionFragment'/>
						<ownedAttribute xmi:type='uml:Property' xmi:id='Interactions-BasicInteractions-ExecutionSpecification-finish' name='finish' visibility='public' type='Interactions-BasicInteractions-OccurrenceSpecification' association='Interactions-BasicInteractions-A_finish_executionSpecification'>
							<ownedComment xmi:type='uml:Comment' xmi:id='Interactions-BasicInteractions-ExecutionSpecification-finish-_ownedComment.0' body='References the OccurrenceSpecification that designates the finish of the Action or Behavior.'>
								<annotatedElement xmi:idref='Interactions-BasicInteractions-ExecutionSpecification-finish'/>
							</ownedComment>
						</ownedAttribute>
						<ownedAttribute xmi:type='uml:Property' xmi:id='Interactions-BasicInteractions-ExecutionSpecification-start' name='start' visibility='public' type='Interactions-BasicInteractions-OccurrenceSpecification' association='Interactions-BasicInteractions-A_start_executionSpecification'>
							<ownedComment xmi:type='uml:Comment' xmi:id='Interactions-BasicInteractions-ExecutionSpecification-start-_ownedComment.0' body='References the OccurrenceSpecification that designates the start of the Action or Behavior'>
								<annotatedElement xmi:idref='Interactions-BasicInteractions-ExecutionSpecification-start'/>
							</ownedComment>
						</ownedAttribute>
					</packagedElement>
					<packagedElement xmi:type='uml:Association' xmi:id='Interactions-BasicInteractions-A_execution_executionOccurrenceSpecification' name='A_execution_executionOccurrenceSpecification' visibility='public'>
						<memberEnd xmi:idref='Interactions-BasicInteractions-A_execution_executionOccurrenceSpecification-executionOccurrenceSpecification'/>
						<memberEnd xmi:idref='Interactions-BasicInteractions-ExecutionOccurrenceSpecification-execution'/>
						<ownedEnd xmi:type='uml:Property' xmi:id='Interactions-BasicInteractions-A_execution_executionOccurrenceSpecification-executionOccurrenceSpecification' name='executionOccurrenceSpecification' visibility='public' type='Interactions-BasicInteractions-ExecutionOccurrenceSpecification' association='Interactions-BasicInteractions-A_execution_executionOccurrenceSpecification'>
							<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='Interactions-BasicInteractions-A_execution_executionOccurrenceSpecification-executionOccurrenceSpecification-_upperValue' visibility='public' value='2'/>
							<lowerValue xmi:type='uml:LiteralInteger' xmi:id='Interactions-BasicInteractions-A_execution_executionOccurrenceSpecification-executionOccurrenceSpecification-_lowerValue' visibility='public'/>
						</ownedEnd>
					</packagedElement>
					<packagedElement xmi:type='uml:Association' xmi:id='Interactions-BasicInteractions-A_action_interaction' name='A_action_interaction' visibility='public'>
						<memberEnd xmi:idref='Interactions-BasicInteractions-Interaction-action'/>
						<memberEnd xmi:idref='Interactions-BasicInteractions-A_action_interaction-interaction'/>
						<ownedEnd xmi:type='uml:Property' xmi:id='Interactions-BasicInteractions-A_action_interaction-interaction' name='interaction' visibility='public' type='Interactions-BasicInteractions-Interaction' association='Interactions-BasicInteractions-A_action_interaction'>
							<subsettedProperty xmi:idref='Classes-Kernel-Element-owner'/>
							<lowerValue xmi:type='uml:LiteralInteger' xmi:id='Interactions-BasicInteractions-A_action_interaction-interaction-_lowerValue' visibility='public'/>
						</ownedEnd>
					</packagedElement>
					<packagedElement xmi:type='uml:Association' xmi:id='Interactions-BasicInteractions-A_action_actionExecutionSpecification' name='A_action_actionExecutionSpecification' visibility='public'>
						<memberEnd xmi:idref='Interactions-BasicInteractions-A_action_actionExecutionSpecification-actionExecutionSpecification'/>
						<memberEnd xmi:idref='Interactions-BasicInteractions-ActionExecutionSpecification-action'/>
						<ownedEnd xmi:type='uml:Property' xmi:id='Interactions-BasicInteractions-A_action_actionExecutionSpecification-actionExecutionSpecification' name='actionExecutionSpecification' visibility='public' type='Interactions-BasicInteractions-ActionExecutionSpecification' association='Interactions-BasicInteractions-A_action_actionExecutionSpecification'>
							<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='Interactions-BasicInteractions-A_action_actionExecutionSpecification-actionExecutionSpecification-_upperValue' visibility='public' value='*'/>
							<lowerValue xmi:type='uml:LiteralInteger' xmi:id='Interactions-BasicInteractions-A_action_actionExecutionSpecification-actionExecutionSpecification-_lowerValue' visibility='public'/>
						</ownedEnd>
					</packagedElement>
					<packagedElement xmi:type='uml:Association' xmi:id='Interactions-BasicInteractions-A_invariant_stateInvariant' name='A_invariant_stateInvariant' visibility='public'>
						<memberEnd xmi:idref='Interactions-BasicInteractions-StateInvariant-invariant'/>
						<memberEnd xmi:idref='Interactions-BasicInteractions-A_invariant_stateInvariant-stateInvariant'/>
						<ownedEnd xmi:type='uml:Property' xmi:id='Interactions-BasicInteractions-A_invariant_stateInvariant-stateInvariant' name='stateInvariant' visibility='public' type='Interactions-BasicInteractions-StateInvariant' association='Interactions-BasicInteractions-A_invariant_stateInvariant'>
							<subsettedProperty xmi:idref='Classes-Kernel-Element-owner'/>
