						<ownedComment xmi:type='uml:Comment' xmi:id='Activities-StructuredActivities-StructuredActivityNode-_ownedComment.0' body='A structured activity node is an executable activity node that may have an expansion into subordinate nodes as an activity group. The subordinate nodes must belong to only one structured activity node, although they may be nested.'>
							<annotatedElement xmi:idref='Activities-StructuredActivities-StructuredActivityNode'/>
