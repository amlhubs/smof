							<ownedComment xmi:type='uml:Comment' xmi:id='Classes-Kernel-Operation-ownedParameter-_ownedComment.0' body='Specifies the parameters owned by this Operation.'>
								<annotatedElement xmi:idref='Classes-Kernel-Operation-ownedParameter'/>
							</ownedComment>
							<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='Classes-Kernel-Operation-ownedParameter-_upperValue' visibility='public' value='*'/>
							<lowerValue xmi:type='uml:LiteralInteger' xmi:id='Classes-Kernel-Operation-ownedParameter-_lowerValue' visibility='public'/>
						</ownedAttribute>
						<ownedAttribute xmi:type='uml:Property' xmi:id='Classes-Kernel-Operation-postcondition' name='postcondition' visibility='public' aggregation='composite' type='Classes-Kernel-Constraint' association='Classes-Kernel-A_postcondition_postContext'>
							<subsettedProperty xmi:idref='Classes-Kernel-Namespace-ownedRule'/>
							<ownedComment xmi:type='uml:Comment' xmi:id='Classes-Kernel-Operation-postcondition-_ownedComment.0' body='An optional set of Constraints specifying the state of the system when the Operation is completed.'>
								<annotatedElement xmi:idref='Classes-Kernel-Operation-postcondition'/>
							</ownedComment>
							<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='Classes-Kernel-Operation-postcondition-_upperValue' visibility='public' value='*'/>
							<lowerValue xmi:type='uml:LiteralInteger' xmi:id='Classes-Kernel-Operation-postcondition-_lowerValue' visibility='public'/>
						</ownedAttribute>
						<ownedAttribute xmi:type='uml:Property' xmi:id='Classes-Kernel-Operation-precondition' name='precondition' visibility='public' aggregation='composite' type='Classes-Kernel-Constraint' association='Classes-Kernel-A_precondition_preContext'>
							<subsettedProperty xmi:idref='Classes-Kernel-Namespace-ownedRule'/>
							<ownedComment xmi:type='uml:Comment' xmi:id='Classes-Kernel-Operation-precondition-_ownedComment.0' body='An optional set of Constraints on the state of the system when the Operation is invoked.'>
								<annotatedElement xmi:idref='Classes-Kernel-Operation-precondition'/>
							</ownedComment>
