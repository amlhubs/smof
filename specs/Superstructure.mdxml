					<packagedElement xmi:type='uml:Class' xmi:id='Classes-Kernel-Operation' name='Operation' visibility='public'>
						<xmi:Extension extender='MagicDraw UML 16.8'>
							<modelExtension/>
						</xmi:Extension>
						<ownedComment xmi:type='uml:Comment' xmi:id='Classes-Kernel-Operation-_ownedComment.0' body='An operation is a behavioral feature of a classifier that specifies the name, type, parameters, and constraints for invoking an associated behavior.'>
							<annotatedElement xmi:idref='Classes-Kernel-Operation'/>
						</ownedComment>
						<ownedRule xmi:type='uml:Constraint' xmi:id='Classes-Kernel-Operation-at_most_one_return' name='at_most_one_return' visibility='public'>
							<constrainedElement xmi:idref='Classes-Kernel-Operation'/>
							<ownedComment xmi:type='uml:Comment' xmi:id='Classes-Kernel-Operation-at_most_one_return-_ownedComment.0' body='An operation can have at most one return parameter; i.e., an owned parameter with the direction set to &#39;return&#39;'>
								<annotatedElement xmi:idref='Classes-Kernel-Operation-at_most_one_return'/>
							</ownedComment>
							<specification xmi:type='uml:OpaqueExpression' xmi:id='Classes-Kernel-Operation-at_most_one_return-_specification' visibility='public'>
								<body>self.ownedParameter-&gt;select(par | par.direction = #return)-&gt;size() &lt;= 1</body>
								<language>OCL</language>
							</specification>
						</ownedRule>
						<ownedRule xmi:type='uml:Constraint' xmi:id='Classes-Kernel-Operation-only_body_for_query' name='only_body_for_query' visibility='public'>
							<constrainedElement xmi:idref='Classes-Kernel-Operation'/>
							<ownedComment xmi:type='uml:Comment' xmi:id='Classes-Kernel-Operation-only_body_for_query-_ownedComment.0' body='A bodyCondition can only be specified for a query operation.'>
								<annotatedElement xmi:idref='Classes-Kernel-Operation-only_body_for_query'/>
							</ownedComment>
							<specification xmi:type='uml:OpaqueExpression' xmi:id='Classes-Kernel-Operation-only_body_for_query-_specification' visibility='public'>
								<body>bodyCondition-&gt;notEmpty() implies isQuery</body>
								<language>OCL</language>
							</specification>
						</ownedRule>
