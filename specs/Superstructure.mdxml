							<ownedComment xmi:type='uml:Comment' xmi:id='Activities-BasicActivities-ActivityEdge-activity-_ownedComment.0' body='Activity containing the edge.'>
								<annotatedElement xmi:idref='Activities-BasicActivities-ActivityEdge-activity'/>
							</ownedComment>
							<lowerValue xmi:type='uml:LiteralInteger' xmi:id='Activities-BasicActivities-ActivityEdge-activity-_lowerValue' visibility='public'/>
						</ownedAttribute>
						<ownedAttribute xmi:type='uml:Property' xmi:id='Activities-BasicActivities-ActivityEdge-inGroup' name='inGroup' visibility='public' isReadOnly='true' isDerived='true' isDerivedUnion='true' type='Activities-BasicActivities-ActivityGroup' association='Activities-BasicActivities-A_containedEdge_inGroup'>
							<ownedComment xmi:type='uml:Comment' xmi:id='Activities-BasicActivities-ActivityEdge-inGroup-_ownedComment.0' body='Groups containing the edge.'>
