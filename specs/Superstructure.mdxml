								<specification xmi:type='uml:OpaqueExpression' xmi:id='Classes-Kernel-Type-conformsTo-spec-_specification' visibility='public'>
									<body>result = false</body>
									<language>OCL</language>
								</specification>
							</ownedRule>
							<ownedParameter xmi:type='uml:Parameter' xmi:id='Classes-Kernel-Type-conformsTo-result' name='result' visibility='public' direction='return' effect='create'>
