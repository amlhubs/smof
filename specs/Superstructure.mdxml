								<specification xmi:type='uml:OpaqueExpression' xmi:id='Classes-Kernel-DataType-inherit-spec-_specification' visibility='public'>
									<body>result = inhs-&gt;excluding(inh | ownedMember-&gt;select(oclIsKindOf(RedefinableElement))-&gt;select(redefinedElement-&gt;includes(inh)))</body>
									<language>OCL</language>
								</specification>
							</ownedRule>
