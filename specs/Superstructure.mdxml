							<ownedComment xmi:type='uml:Comment' xmi:id='Activities-BasicActivities-ActivityEdge-source_and_target-_ownedComment.0' body='The source and target of an edge must be in the same activity as the edge.'>
								<annotatedElement xmi:idref='Activities-BasicActivities-ActivityEdge-source_and_target'/>
							</ownedComment>
							<specification xmi:type='uml:OpaqueExpression' xmi:id='Activities-BasicActivities-ActivityEdge-source_and_target-_specification' visibility='public'>
								<body>true</body>
								<language>OCL</language>
							</specification>
