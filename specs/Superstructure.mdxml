							<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='Activities-BasicActivities-ActivityEdge-redefinedEdge-_upperValue' visibility='public' value='*'/>
							<lowerValue xmi:type='uml:LiteralInteger' xmi:id='Activities-BasicActivities-ActivityEdge-redefinedEdge-_lowerValue' visibility='public'/>
						</ownedAttribute>
						<ownedAttribute xmi:type='uml:Property' xmi:id='Activities-BasicActivities-ActivityEdge-source' name='source' visibility='public' type='Activities-BasicActivities-ActivityNode' association='Activities-BasicActivities-A_outgoing_source_node'>
							<ownedComment xmi:type='uml:Comment' xmi:id='Activities-BasicActivities-ActivityEdge-source-_ownedComment.0' body='Node from which tokens are taken when they traverse the edge.'>
								<annotatedElement xmi:idref='Activities-BasicActivities-ActivityEdge-source'/>
							</ownedComment>
						</ownedAttribute>
						<ownedAttribute xmi:type='uml:Property' xmi:id='Activities-BasicActivities-ActivityEdge-target' name='target' visibility='public' type='Activities-BasicActivities-ActivityNode' association='Activities-BasicActivities-A_incoming_target_node'>
							<ownedComment xmi:type='uml:Comment' xmi:id='Activities-BasicActivities-ActivityEdge-target-_ownedComment.0' body='Node to which tokens are put when they traverse the edge.'>
								<annotatedElement xmi:idref='Activities-BasicActivities-ActivityEdge-target'/>
							</ownedComment>
						</ownedAttribute>
					</packagedElement>
					<packagedElement xmi:type='uml:Class' xmi:id='Activities-BasicActivities-ObjectNode' name='ObjectNode' visibility='public' isAbstract='true'>
						<xmi:Extension extender='MagicDraw UML 16.8'>
							<modelExtension/>
						</xmi:Extension>
						<ownedComment xmi:type='uml:Comment' xmi:id='Activities-BasicActivities-ObjectNode-_ownedComment.0' body='An object node is an abstract activity node that is part of defining object flow in an activity.'>
							<annotatedElement xmi:idref='Activities-BasicActivities-ObjectNode'/>
						</ownedComment>
						<ownedRule xmi:type='uml:Constraint' xmi:id='Activities-BasicActivities-ObjectNode-object_flow_edges' name='object_flow_edges' visibility='public'>
							<constrainedElement xmi:idref='Activities-BasicActivities-ObjectNode'/>
							<ownedComment xmi:type='uml:Comment' xmi:id='Activities-BasicActivities-ObjectNode-object_flow_edges-_ownedComment.0' body='All edges coming into or going out of object nodes must be object flow edges.'>
								<annotatedElement xmi:idref='Activities-BasicActivities-ObjectNode-object_flow_edges'/>
							</ownedComment>
							<specification xmi:type='uml:OpaqueExpression' xmi:id='Activities-BasicActivities-ObjectNode-object_flow_edges-_specification' visibility='public'>
								<body>true</body>
								<language>OCL</language>
							</specification>
						</ownedRule>
						<generalization xmi:type='uml:Generalization' xmi:id='Activities-BasicActivities-ObjectNode-_generalization.0' general='Activities-BasicActivities-ActivityNode'/>
						<generalization xmi:type='uml:Generalization' xmi:id='Activities-BasicActivities-ObjectNode-_generalization.1' general='Classes-Kernel-TypedElement'/>
					</packagedElement>
					<packagedElement xmi:type='uml:Association' xmi:id='Activities-BasicActivities-A_redefinedNode_activityNode' name='A_redefinedNode_activityNode' visibility='public'>
						<memberEnd xmi:idref='Activities-BasicActivities-ActivityNode-redefinedNode'/>
						<memberEnd xmi:idref='Activities-BasicActivities-A_redefinedNode_activityNode-activityNode'/>
