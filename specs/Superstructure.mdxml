						</xmi:Extension>
						<ownedComment xmi:type='uml:Comment' xmi:id='Activities-FundamentalActivities-Activity-_ownedComment.0' body='An activity is the specification of parameterized behavior as the coordinated sequencing of subordinate units whose individual elements are actions.'>
							<annotatedElement xmi:idref='Activities-FundamentalActivities-Activity'/>
						</ownedComment>
						<ownedRule xmi:type='uml:Constraint' xmi:id='Activities-FundamentalActivities-Activity-no_supergroups' name='no_supergroups' visibility='public'>
