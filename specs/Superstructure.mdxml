							<ownedComment xmi:type='uml:Comment' xmi:id='Activities-StructuredActivities-ConditionalNode-one_clause_with_executable_node-_ownedComment.0' body='No ExecutableNode may appear in the test or body part of more than one clause of a conditional node.'>
