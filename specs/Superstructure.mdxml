					<packagedElement xmi:type='uml:Class' xmi:id='AuxiliaryConstructs-Templates-TemplateParameterSubstitution' name='TemplateParameterSubstitution' visibility='public'>
						<xmi:Extension extender='MagicDraw UML 16.8'>
							<modelExtension/>
						</xmi:Extension>
						<ownedComment xmi:type='uml:Comment' xmi:id='AuxiliaryConstructs-Templates-TemplateParameterSubstitution-_ownedComment.0' body='A template parameter substitution relates the actual parameter to a formal template parameter as part of a template binding.'>
							<annotatedElement xmi:idref='AuxiliaryConstructs-Templates-TemplateParameterSubstitution'/>
						</ownedComment>
						<ownedRule xmi:type='uml:Constraint' xmi:id='AuxiliaryConstructs-Templates-TemplateParameterSubstitution-must_be_compatible' name='must_be_compatible' visibility='public'>
							<constrainedElement xmi:idref='AuxiliaryConstructs-Templates-TemplateParameterSubstitution'/>
							<ownedComment xmi:type='uml:Comment' xmi:id='AuxiliaryConstructs-Templates-TemplateParameterSubstitution-must_be_compatible-_ownedComment.0' body='The actual parameter must be compatible with the formal template parameter, e.g. the actual parameter for a class template parameter must be a class.'>
								<annotatedElement xmi:idref='AuxiliaryConstructs-Templates-TemplateParameterSubstitution-must_be_compatible'/>
							</ownedComment>
							<specification xmi:type='uml:OpaqueExpression' xmi:id='AuxiliaryConstructs-Templates-TemplateParameterSubstitution-must_be_compatible-_specification' visibility='public'>
								<body>actual-&gt;forAll(a | a.isCompatibleWith(formal.parameteredElement))</body>
								<language>OCL</language>
							</specification>
						</ownedRule>
						<generalization xmi:type='uml:Generalization' xmi:id='AuxiliaryConstructs-Templates-TemplateParameterSubstitution-_generalization.0' general='Classes-Kernel-Element'/>
