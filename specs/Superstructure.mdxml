						<ownedAttribute xmi:type='uml:Property' xmi:id='Activities-StructuredActivities-ConditionalNode-clause' name='clause' visibility='public' aggregation='composite' type='Activities-StructuredActivities-Clause' association='Activities-StructuredActivities-A_clause_conditionalNode'>
