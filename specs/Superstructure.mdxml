							<xmi:Extension extender='MagicDraw UML 16.8'>
								<modelExtension/>
							</xmi:Extension>
							<ownedComment xmi:type='uml:Comment' xmi:id='Deployments-Nodes-DeploymentTarget-deployedElement.1-_ownedComment.0' body='Missing derivation for DeploymentTarget::/deployedElement : PackageableElement'>
								<annotatedElement xmi:idref='Deployments-Nodes-DeploymentTarget-deployedElement.1'/>
							</ownedComment>
							<ownedRule xmi:type='uml:Constraint' xmi:id='Deployments-Nodes-DeploymentTarget-deployedElement.1-spec' name='spec' visibility='public'>
								<constrainedElement xmi:idref='Deployments-Nodes-DeploymentTarget-deployedElement.1'/>
