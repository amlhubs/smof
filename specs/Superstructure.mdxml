					<packagedElement xmi:type='uml:Class' xmi:id='CommonBehaviors-SimpleTime-Duration' name='Duration' visibility='public'>
						<ownedComment xmi:type='uml:Comment' xmi:id='CommonBehaviors-SimpleTime-Duration-_ownedComment.0' body='Duration defines a value specification that specifies the temporal distance between two time instants.'>
