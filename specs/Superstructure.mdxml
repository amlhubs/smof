						</ownedComment>
						<ownedRule xmi:type='uml:Constraint' xmi:id='Activities-StructuredActivities-ConditionalNode-clause_no_predecessor' name='clause_no_predecessor' visibility='public'>
							<constrainedElement xmi:idref='Activities-StructuredActivities-ConditionalNode'/>
							<ownedComment xmi:type='uml:Comment' xmi:id='Activities-StructuredActivities-ConditionalNode-clause_no_predecessor-_ownedComment.0' body='No two clauses within a ConditionalNode maybe predecessor clauses of each other, either directly or indirectly.'>
