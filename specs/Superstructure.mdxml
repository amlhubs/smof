							<ownedComment xmi:type='uml:Comment' xmi:id='Activities-CompleteStructuredActivities-ConditionalNode-matching_output_pins-_ownedComment.0' body='Each clause of a conditional node must have the same number of bodyOutput pins as the conditional node has result output pins, and each clause bodyOutput pin must be compatible with the corresponding result pin (by positional order) in type, multiplicity, ordering and uniqueness.'>
