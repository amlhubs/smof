							<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='Classes-Kernel-A_type_typedElement-typedElement-_upperValue' visibility='public' value='*'/>
							<lowerValue xmi:type='uml:LiteralInteger' xmi:id='Classes-Kernel-A_type_typedElement-typedElement-_lowerValue' visibility='public'/>
						</ownedEnd>
