							<lowerValue xmi:type='uml:LiteralInteger' xmi:id='Interactions-Fragments-InteractionUse-argument-_lowerValue' visibility='public'/>
						</ownedAttribute>
						<ownedAttribute xmi:type='uml:Property' xmi:id='Interactions-Fragments-InteractionUse-refersTo' name='refersTo' visibility='public' type='Interactions-Fragments-Interaction' association='Interactions-Fragments-A_refersTo_interactionUse'>
							<ownedComment xmi:type='uml:Comment' xmi:id='Interactions-Fragments-InteractionUse-refersTo-_ownedComment.0' body='Refers to the Interaction that defines its meaning'>
