								<specification xmi:type='uml:OpaqueExpression' xmi:id='AuxiliaryConstructs-Templates-ParameterableElement-isTemplateParameter-spec-_specification' visibility='public'>
									<body>result = templateParameter-&gt;notEmpty()</body>
									<language>OCL</language>
								</specification>
							</ownedRule>
							<ownedParameter xmi:type='uml:Parameter' xmi:id='AuxiliaryConstructs-Templates-ParameterableElement-isTemplateParameter-result' name='result' visibility='public' direction='return' effect='create'>
