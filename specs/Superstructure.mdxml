				<packagedElement xmi:type='uml:Package' xmi:id='Classes-PowerTypes' name='PowerTypes' visibility='public'>
					<packageMerge xmi:type='uml:PackageMerge' xmi:id='Classes-PowerTypes-_packageMerge.0' mergedPackage='Classes-Kernel'/>
					<packagedElement xmi:type='uml:Class' xmi:id='Classes-PowerTypes-Classifier' name='Classifier' visibility='public' isAbstract='true'>
						<xmi:Extension extender='MagicDraw UML 16.8'>
							<modelExtension/>
						</xmi:Extension>
						<ownedRule xmi:type='uml:Constraint' xmi:id='Classes-PowerTypes-Classifier-maps_to_generalization_set' name='maps_to_generalization_set' visibility='public'>
							<constrainedElement xmi:idref='Classes-PowerTypes-Classifier'/>
							<ownedComment xmi:type='uml:Comment' xmi:id='Classes-PowerTypes-Classifier-maps_to_generalization_set-_ownedComment.0' body='The Classifier that maps to a GeneralizationSet may neither be a specific nor a general Classifier in any of the Generalization relationships defined for that GeneralizationSet. In other words, a power type may not be an instance of itself nor may its instances also be its subclasses.'>
								<annotatedElement xmi:idref='Classes-PowerTypes-Classifier-maps_to_generalization_set'/>
							</ownedComment>
							<specification xmi:type='uml:OpaqueExpression' xmi:id='Classes-PowerTypes-Classifier-maps_to_generalization_set-_specification' visibility='public'>
								<body>true</body>
								<language>OCL</language>
							</specification>
						</ownedRule>
						<ownedAttribute xmi:type='uml:Property' xmi:id='Classes-PowerTypes-Classifier-powertypeExtent' name='powertypeExtent' visibility='public' type='Classes-PowerTypes-GeneralizationSet' association='Classes-PowerTypes-A_powertypeExtent_powertype'>
							<ownedComment xmi:type='uml:Comment' xmi:id='Classes-PowerTypes-Classifier-powertypeExtent-_ownedComment.0' body='Designates the GeneralizationSet of which the associated Classifier is a power type.'>
								<annotatedElement xmi:idref='Classes-PowerTypes-Classifier-powertypeExtent'/>
							</ownedComment>
							<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='Classes-PowerTypes-Classifier-powertypeExtent-_upperValue' visibility='public' value='*'/>
							<lowerValue xmi:type='uml:LiteralInteger' xmi:id='Classes-PowerTypes-Classifier-powertypeExtent-_lowerValue' visibility='public'/>
						</ownedAttribute>
					</packagedElement>
					<packagedElement xmi:type='uml:Association' xmi:id='Classes-PowerTypes-A_generalizationSet_generalization' name='A_generalizationSet_generalization' visibility='public'>
						<memberEnd xmi:idref='Classes-PowerTypes-GeneralizationSet-generalization'/>
						<memberEnd xmi:idref='Classes-PowerTypes-Generalization-generalizationSet'/>
					</packagedElement>
					<packagedElement xmi:type='uml:Class' xmi:id='Classes-PowerTypes-GeneralizationSet' name='GeneralizationSet' visibility='public'>
						<xmi:Extension extender='MagicDraw UML 16.8'>
							<modelExtension/>
						</xmi:Extension>
						<ownedComment xmi:type='uml:Comment' xmi:id='Classes-PowerTypes-GeneralizationSet-_ownedComment.0' body='A generalization set is a packageable element whose instances define collections of subsets of generalization relationships.'>
							<annotatedElement xmi:idref='Classes-PowerTypes-GeneralizationSet'/>
						</ownedComment>
						<ownedRule xmi:type='uml:Constraint' xmi:id='Classes-PowerTypes-GeneralizationSet-generalization_same_classifier' name='generalization_same_classifier' visibility='public'>
							<constrainedElement xmi:idref='Classes-PowerTypes-GeneralizationSet'/>
							<ownedComment xmi:type='uml:Comment' xmi:id='Classes-PowerTypes-GeneralizationSet-generalization_same_classifier-_ownedComment.0' body='Every Generalization associated with a particular GeneralizationSet must have the same general Classifier.'>
								<annotatedElement xmi:idref='Classes-PowerTypes-GeneralizationSet-generalization_same_classifier'/>
							</ownedComment>
							<specification xmi:type='uml:OpaqueExpression' xmi:id='Classes-PowerTypes-GeneralizationSet-generalization_same_classifier-_specification' visibility='public'>
								<body>generalization-&gt;collect(g | g.general)-&gt;asSet()-&gt;size() &lt;= 1</body>
								<language>OCL</language>
							</specification>
						</ownedRule>
						<ownedRule xmi:type='uml:Constraint' xmi:id='Classes-PowerTypes-GeneralizationSet-maps_to_generalization_set' name='maps_to_generalization_set' visibility='public'>
							<constrainedElement xmi:idref='Classes-PowerTypes-GeneralizationSet'/>
							<ownedComment xmi:type='uml:Comment' xmi:id='Classes-PowerTypes-GeneralizationSet-maps_to_generalization_set-_ownedComment.0' body='The Classifier that maps to a GeneralizationSet may neither be a specific nor a general Classifier in any of the Generalization relationships defined for that GeneralizationSet. In other words, a power type may not be an instance of itself nor may its instances be its subclasses.'>
								<annotatedElement xmi:idref='Classes-PowerTypes-GeneralizationSet-maps_to_generalization_set'/>
							</ownedComment>
							<specification xmi:type='uml:OpaqueExpression' xmi:id='Classes-PowerTypes-GeneralizationSet-maps_to_generalization_set-_specification' visibility='public'>
								<body>true</body>
								<language>OCL</language>
							</specification>
						</ownedRule>
						<generalization xmi:type='uml:Generalization' xmi:id='Classes-PowerTypes-GeneralizationSet-_generalization.0' general='Classes-Kernel-PackageableElement'/>
						<ownedAttribute xmi:type='uml:Property' xmi:id='Classes-PowerTypes-GeneralizationSet-generalization' name='generalization' visibility='public' type='Classes-PowerTypes-Generalization' association='Classes-PowerTypes-A_generalizationSet_generalization'>
							<ownedComment xmi:type='uml:Comment' xmi:id='Classes-PowerTypes-GeneralizationSet-generalization-_ownedComment.0' body='Designates the instances of Generalization which are members of a given GeneralizationSet.'>
								<annotatedElement xmi:idref='Classes-PowerTypes-GeneralizationSet-generalization'/>
							</ownedComment>
							<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='Classes-PowerTypes-GeneralizationSet-generalization-_upperValue' visibility='public' value='*'/>
							<lowerValue xmi:type='uml:LiteralInteger' xmi:id='Classes-PowerTypes-GeneralizationSet-generalization-_lowerValue' visibility='public'/>
						</ownedAttribute>
						<ownedAttribute xmi:type='uml:Property' xmi:id='Classes-PowerTypes-GeneralizationSet-isCovering' name='isCovering' visibility='public'>
							<type xmi:type='uml:PrimitiveType' href='http://schema.omg.org/spec/UML/2.3/uml.xml#Boolean'>
								<xmi:Extension extender='MagicDraw UML 16.8'>
									<referenceExtension referentPath='PrimitiveTypes::Boolean' referentType='PrimitiveType'/>
								</xmi:Extension>
							</type>
							<ownedComment xmi:type='uml:Comment' xmi:id='Classes-PowerTypes-GeneralizationSet-isCovering-_ownedComment.0' body='Indicates (via the associated Generalizations) whether or not the set of specific Classifiers are covering for a particular general classifier. When isCovering is true, every instance of a particular general Classifier is also an instance of at least one of its specific Classifiers for the GeneralizationSet. When isCovering is false, there are one or more instances of the particular general Classifier that are not instances of at least one of its specific Classifiers defined for the GeneralizationSet.'>
								<annotatedElement xmi:idref='Classes-PowerTypes-GeneralizationSet-isCovering'/>
							</ownedComment>
							<defaultValue xmi:type='uml:LiteralBoolean' xmi:id='Classes-PowerTypes-GeneralizationSet-isCovering-_defaultValue' visibility='public'/>
						</ownedAttribute>
						<ownedAttribute xmi:type='uml:Property' xmi:id='Classes-PowerTypes-GeneralizationSet-isDisjoint' name='isDisjoint' visibility='public'>
							<type xmi:type='uml:PrimitiveType' href='http://schema.omg.org/spec/UML/2.3/uml.xml#Boolean'>
								<xmi:Extension extender='MagicDraw UML 16.8'>
									<referenceExtension referentPath='PrimitiveTypes::Boolean' referentType='PrimitiveType'/>
								</xmi:Extension>
							</type>
							<ownedComment xmi:type='uml:Comment' xmi:id='Classes-PowerTypes-GeneralizationSet-isDisjoint-_ownedComment.0' body='Indicates whether or not the set of specific Classifiers in a Generalization relationship have instance in common. If isDisjoint is true, the specific Classifiers for a particular GeneralizationSet have no members in common; that is, their intersection is empty. If isDisjoint is false, the specific Classifiers in a particular GeneralizationSet have one or more members in common; that is, their intersection is not empty. For example, Person could have two Generalization relationships, each with the different specific Classifier: Manager or Staff. This would be disjoint because every instance of Person must either be a Manager or Staff. In contrast, Person could have two Generalization relationships involving two specific (and non-covering) Classifiers: Sales Person and Manager. This GeneralizationSet would not be disjoint because there are instances of Person which can be a Sales Person and a Manager.'>
								<annotatedElement xmi:idref='Classes-PowerTypes-GeneralizationSet-isDisjoint'/>
							</ownedComment>
							<defaultValue xmi:type='uml:LiteralBoolean' xmi:id='Classes-PowerTypes-GeneralizationSet-isDisjoint-_defaultValue' visibility='public'/>
						</ownedAttribute>
						<ownedAttribute xmi:type='uml:Property' xmi:id='Classes-PowerTypes-GeneralizationSet-powertype' name='powertype' visibility='public' type='Classes-PowerTypes-Classifier' association='Classes-PowerTypes-A_powertypeExtent_powertype'>
							<ownedComment xmi:type='uml:Comment' xmi:id='Classes-PowerTypes-GeneralizationSet-powertype-_ownedComment.0' body='Designates the Classifier that is defined as the power type for the associated GeneralizationSet.'>
								<annotatedElement xmi:idref='Classes-PowerTypes-GeneralizationSet-powertype'/>
							</ownedComment>
							<lowerValue xmi:type='uml:LiteralInteger' xmi:id='Classes-PowerTypes-GeneralizationSet-powertype-_lowerValue' visibility='public'/>
						</ownedAttribute>
					</packagedElement>
					<packagedElement xmi:type='uml:Class' xmi:id='Classes-PowerTypes-Generalization' name='Generalization' visibility='public'>
						<xmi:Extension extender='MagicDraw UML 16.8'>
							<modelExtension/>
						</xmi:Extension>
						<ownedComment xmi:type='uml:Comment' xmi:id='Classes-PowerTypes-Generalization-_ownedComment.0' body='A generalization relates a specific classifier to a more general classifier, and is owned by the specific classifier.'>
							<annotatedElement xmi:idref='Classes-PowerTypes-Generalization'/>
						</ownedComment>
						<ownedRule xmi:type='uml:Constraint' xmi:id='Classes-PowerTypes-Generalization-generalization_same_classifier' name='generalization_same_classifier' visibility='public'>
							<constrainedElement xmi:idref='Classes-PowerTypes-Generalization'/>
							<ownedComment xmi:type='uml:Comment' xmi:id='Classes-PowerTypes-Generalization-generalization_same_classifier-_ownedComment.0' body='Every Generalization associated with a given GeneralizationSet must have the same general Classifier. That is, all Generalizations for a particular GeneralizationSet must have the same superclass.'>
								<annotatedElement xmi:idref='Classes-PowerTypes-Generalization-generalization_same_classifier'/>
							</ownedComment>
							<specification xmi:type='uml:OpaqueExpression' xmi:id='Classes-PowerTypes-Generalization-generalization_same_classifier-_specification' visibility='public'>
								<body>true</body>
								<language>OCL</language>
							</specification>
						</ownedRule>
						<ownedAttribute xmi:type='uml:Property' xmi:id='Classes-PowerTypes-Generalization-generalizationSet' name='generalizationSet' visibility='public' type='Classes-PowerTypes-GeneralizationSet' association='Classes-PowerTypes-A_generalizationSet_generalization'>
							<ownedComment xmi:type='uml:Comment' xmi:id='Classes-PowerTypes-Generalization-generalizationSet-_ownedComment.0' body='Designates a set in which instances of Generalization is considered members.'>
								<annotatedElement xmi:idref='Classes-PowerTypes-Generalization-generalizationSet'/>
							</ownedComment>
							<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='Classes-PowerTypes-Generalization-generalizationSet-_upperValue' visibility='public' value='*'/>
							<lowerValue xmi:type='uml:LiteralInteger' xmi:id='Classes-PowerTypes-Generalization-generalizationSet-_lowerValue' visibility='public'/>
						</ownedAttribute>
					</packagedElement>
