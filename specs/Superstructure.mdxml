						<ownedEnd xmi:type='uml:Property' xmi:id='StateMachines-BehaviorStateMachines-A_stateInvariant_owningState-owningState' name='owningState' visibility='public' type='StateMachines-BehaviorStateMachines-State' association='StateMachines-BehaviorStateMachines-A_stateInvariant_owningState'>
							<subsettedProperty xmi:idref='Classes-Kernel-Constraint-context'/>
