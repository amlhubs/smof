							<xmi:Extension extender='MagicDraw UML 16.8'>
								<modelExtension/>
							</xmi:Extension>
							<precondition xmi:idref='Classes-Kernel-MultiplicityElement-includesCardinality-pre'/>
							<ownedComment xmi:type='uml:Comment' xmi:id='Classes-Kernel-MultiplicityElement-includesCardinality-_ownedComment.0' body='The query includesCardinality() checks whether the specified cardinality is valid for this multiplicity.'>
								<annotatedElement xmi:idref='Classes-Kernel-MultiplicityElement-includesCardinality'/>
							</ownedComment>
							<ownedRule xmi:type='uml:Constraint' xmi:id='Classes-Kernel-MultiplicityElement-includesCardinality-spec' name='spec' visibility='public'>
								<constrainedElement xmi:idref='Classes-Kernel-MultiplicityElement-includesCardinality'/>
								<specification xmi:type='uml:OpaqueExpression' xmi:id='Classes-Kernel-MultiplicityElement-includesCardinality-spec-_specification' visibility='public'>
									<body>result = (lowerBound() &lt;= C) and (upperBound() &gt;= C)</body>
									<language>OCL</language>
								</specification>
							</ownedRule>
							<ownedRule xmi:type='uml:Constraint' xmi:id='Classes-Kernel-MultiplicityElement-includesCardinality-pre' name='pre' visibility='public'>
								<constrainedElement xmi:idref='Classes-Kernel-MultiplicityElement-includesCardinality'/>
								<specification xmi:type='uml:OpaqueExpression' xmi:id='Classes-Kernel-MultiplicityElement-includesCardinality-pre-_specification' visibility='public'>
									<body>upperBound()-&gt;notEmpty() and lowerBound()-&gt;notEmpty()</body>
									<language>OCL</language>
								</specification>
							</ownedRule>
							<ownedParameter xmi:type='uml:Parameter' xmi:id='Classes-Kernel-MultiplicityElement-includesCardinality-result' name='result' visibility='public' direction='return' effect='create'>
								<type xmi:type='uml:PrimitiveType' href='http://schema.omg.org/spec/UML/2.3/uml.xml#Boolean'>
									<xmi:Extension extender='MagicDraw UML 16.8'>
										<referenceExtension referentPath='PrimitiveTypes::Boolean' referentType='PrimitiveType'/>
									</xmi:Extension>
								</type>
							</ownedParameter>
							<ownedParameter xmi:type='uml:Parameter' xmi:id='Classes-Kernel-MultiplicityElement-includesCardinality-C' name='C' visibility='public' effect='create'>
								<type xmi:type='uml:PrimitiveType' href='http://schema.omg.org/spec/UML/2.3/uml.xml#Integer'>
									<xmi:Extension extender='MagicDraw UML 16.8'>
										<referenceExtension referentPath='PrimitiveTypes::Integer' referentType='PrimitiveType'/>
									</xmi:Extension>
								</type>
							</ownedParameter>
						</ownedOperation>
						<ownedOperation xmi:type='uml:Operation' xmi:id='Classes-Kernel-MultiplicityElement-includesMultiplicity' name='includesMultiplicity' visibility='public' isQuery='true' bodyCondition='Classes-Kernel-MultiplicityElement-includesMultiplicity-spec'>
							<xmi:Extension extender='MagicDraw UML 16.8'>
								<modelExtension/>
							</xmi:Extension>
							<precondition xmi:idref='Classes-Kernel-MultiplicityElement-includesMultiplicity-pre'/>
							<ownedComment xmi:type='uml:Comment' xmi:id='Classes-Kernel-MultiplicityElement-includesMultiplicity-_ownedComment.0' body='The query includesMultiplicity() checks whether this multiplicity includes all the cardinalities allowed by the specified multiplicity.'>
								<annotatedElement xmi:idref='Classes-Kernel-MultiplicityElement-includesMultiplicity'/>
							</ownedComment>
							<ownedRule xmi:type='uml:Constraint' xmi:id='Classes-Kernel-MultiplicityElement-includesMultiplicity-pre' name='pre' visibility='public'>
								<constrainedElement xmi:idref='Classes-Kernel-MultiplicityElement-includesMultiplicity'/>
								<specification xmi:type='uml:OpaqueExpression' xmi:id='Classes-Kernel-MultiplicityElement-includesMultiplicity-pre-_specification' visibility='public'>
									<body>self.upperBound()-&gt;notEmpty() and self.lowerBound()-&gt;notEmpty() and M.upperBound()-&gt;notEmpty() and M.lowerBound()-&gt;notEmpty()</body>
									<language>OCL</language>
								</specification>
							</ownedRule>
							<ownedRule xmi:type='uml:Constraint' xmi:id='Classes-Kernel-MultiplicityElement-includesMultiplicity-spec' name='spec' visibility='public'>
								<constrainedElement xmi:idref='Classes-Kernel-MultiplicityElement-includesMultiplicity'/>
								<specification xmi:type='uml:OpaqueExpression' xmi:id='Classes-Kernel-MultiplicityElement-includesMultiplicity-spec-_specification' visibility='public'>
									<body>result = (self.lowerBound() &lt;= M.lowerBound()) and (self.upperBound() &gt;= M.upperBound())</body>
									<language>OCL</language>
								</specification>
							</ownedRule>
							<ownedParameter xmi:type='uml:Parameter' xmi:id='Classes-Kernel-MultiplicityElement-includesMultiplicity-result' name='result' visibility='public' direction='return' effect='create'>
								<type xmi:type='uml:PrimitiveType' href='http://schema.omg.org/spec/UML/2.3/uml.xml#Boolean'>
									<xmi:Extension extender='MagicDraw UML 16.8'>
										<referenceExtension referentPath='PrimitiveTypes::Boolean' referentType='PrimitiveType'/>
									</xmi:Extension>
								</type>
							</ownedParameter>
							<ownedParameter xmi:type='uml:Parameter' xmi:id='Classes-Kernel-MultiplicityElement-includesMultiplicity-M' name='M' visibility='public' effect='create' type='Classes-Kernel-MultiplicityElement'/>
						</ownedOperation>
						<ownedOperation xmi:type='uml:Operation' xmi:id='Classes-Kernel-MultiplicityElement-isMultivalued' name='isMultivalued' visibility='public' isQuery='true' bodyCondition='Classes-Kernel-MultiplicityElement-isMultivalued-spec'>
							<xmi:Extension extender='MagicDraw UML 16.8'>
								<modelExtension/>
							</xmi:Extension>
