							</ownedComment>
							<specification xmi:type='uml:OpaqueExpression' xmi:id='Activities-BasicActivities-ActivityGroup-not_contained-_specification' visibility='public'>
								<body>true</body>
								<language>OCL</language>
							</specification>
						</ownedRule>
						<ownedRule xmi:type='uml:Constraint' xmi:id='Activities-BasicActivities-ActivityGroup-nodes_and_edges' name='nodes_and_edges' visibility='public'>
							<constrainedElement xmi:idref='Activities-BasicActivities-ActivityGroup'/>
							<ownedComment xmi:type='uml:Comment' xmi:id='Activities-BasicActivities-ActivityGroup-nodes_and_edges-_ownedComment.0' body='All nodes and edges of the group must be in the same activity as the group.'>
								<annotatedElement xmi:idref='Activities-BasicActivities-ActivityGroup-nodes_and_edges'/>
							</ownedComment>
							<specification xmi:type='uml:OpaqueExpression' xmi:id='Activities-BasicActivities-ActivityGroup-nodes_and_edges-_specification' visibility='public'>
								<body>true</body>
								<language>OCL</language>
