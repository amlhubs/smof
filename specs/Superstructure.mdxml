					<packagedElement xmi:type='uml:Association' xmi:id='StateMachines-BehaviorStateMachines-A_redefinitionContext_transition' name='A_redefinitionContext_transition' visibility='public' isDerived='true'>
						<memberEnd xmi:idref='StateMachines-BehaviorStateMachines-Transition-redefinitionContext'/>
						<memberEnd xmi:idref='StateMachines-BehaviorStateMachines-A_redefinitionContext_transition-transition'/>
