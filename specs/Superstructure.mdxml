					</packagedElement>
					<packagedElement xmi:type='uml:Class' xmi:id='Activities-StructuredActivities-LoopNode' name='LoopNode' visibility='public'>
						<xmi:Extension extender='MagicDraw UML 16.8'>
							<modelExtension/>
						</xmi:Extension>
						<ownedComment xmi:type='uml:Comment' xmi:id='Activities-StructuredActivities-LoopNode-_ownedComment.0' body='A loop node is a structured activity node that represents a loop with setup, test, and body sections.'>
							<annotatedElement xmi:idref='Activities-StructuredActivities-LoopNode'/>
						</ownedComment>
						<ownedRule xmi:type='uml:Constraint' xmi:id='Activities-StructuredActivities-LoopNode-executable_nodes' name='executable_nodes' visibility='public'>
							<constrainedElement xmi:idref='Activities-StructuredActivities-LoopNode'/>
							<ownedComment xmi:type='uml:Comment' xmi:id='Activities-StructuredActivities-LoopNode-executable_nodes-_ownedComment.0' body='The union of the ExecutableNodes in the setupPart, test and bodyPart of a LoopNode must be the same as the subset of nodes contained in the LoopNode (considered as a StructuredActivityNode) that are ExecutableNodes.'>
								<annotatedElement xmi:idref='Activities-StructuredActivities-LoopNode-executable_nodes'/>
							</ownedComment>
							<specification xmi:type='uml:OpaqueExpression' xmi:id='Activities-StructuredActivities-LoopNode-executable_nodes-_specification' visibility='public'>
								<body>true</body>
								<language>OCL</language>
							</specification>
						</ownedRule>
						<generalization xmi:type='uml:Generalization' xmi:id='Activities-StructuredActivities-LoopNode-_generalization.0' general='Activities-StructuredActivities-StructuredActivityNode'/>
						<ownedAttribute xmi:type='uml:Property' xmi:id='Activities-StructuredActivities-LoopNode-bodyPart' name='bodyPart' visibility='public' type='Activities-StructuredActivities-ExecutableNode' association='Activities-StructuredActivities-A_bodyPart_loopNode'>
							<ownedComment xmi:type='uml:Comment' xmi:id='Activities-StructuredActivities-LoopNode-bodyPart-_ownedComment.0' body='The set of nodes and edges that perform the repetitive computations of the loop. The body section is executed as long as the test section produces a true value.'>
								<annotatedElement xmi:idref='Activities-StructuredActivities-LoopNode-bodyPart'/>
							</ownedComment>
							<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='Activities-StructuredActivities-LoopNode-bodyPart-_upperValue' visibility='public' value='*'/>
							<lowerValue xmi:type='uml:LiteralInteger' xmi:id='Activities-StructuredActivities-LoopNode-bodyPart-_lowerValue' visibility='public'/>
						</ownedAttribute>
						<ownedAttribute xmi:type='uml:Property' xmi:id='Activities-StructuredActivities-LoopNode-decider' name='decider' visibility='public' type='Activities-StructuredActivities-OutputPin' association='Activities-StructuredActivities-A_decider_loopNode'>
							<ownedComment xmi:type='uml:Comment' xmi:id='Activities-StructuredActivities-LoopNode-decider-_ownedComment.0' body='An output pin within the test fragment the value of which is examined after execution of the test to determine whether to execute the loop body.'>
								<annotatedElement xmi:idref='Activities-StructuredActivities-LoopNode-decider'/>
							</ownedComment>
						</ownedAttribute>
						<ownedAttribute xmi:type='uml:Property' xmi:id='Activities-StructuredActivities-LoopNode-isTestedFirst' name='isTestedFirst' visibility='public'>
							<type xmi:type='uml:PrimitiveType' href='http://schema.omg.org/spec/UML/2.3/uml.xml#Boolean'>
								<xmi:Extension extender='MagicDraw UML 16.8'>
									<referenceExtension referentPath='PrimitiveTypes::Boolean' referentType='PrimitiveType'/>
								</xmi:Extension>
							</type>
							<ownedComment xmi:type='uml:Comment' xmi:id='Activities-StructuredActivities-LoopNode-isTestedFirst-_ownedComment.0' body='If true, the test is performed before the first execution of the body. If false, the body is executed once before the test is performed.'>
								<annotatedElement xmi:idref='Activities-StructuredActivities-LoopNode-isTestedFirst'/>
							</ownedComment>
							<defaultValue xmi:type='uml:LiteralBoolean' xmi:id='Activities-StructuredActivities-LoopNode-isTestedFirst-_defaultValue' visibility='public'/>
						</ownedAttribute>
						<ownedAttribute xmi:type='uml:Property' xmi:id='Activities-StructuredActivities-LoopNode-setupPart' name='setupPart' visibility='public' type='Activities-StructuredActivities-ExecutableNode' association='Activities-StructuredActivities-A_setupPart_loopNode'>
							<ownedComment xmi:type='uml:Comment' xmi:id='Activities-StructuredActivities-LoopNode-setupPart-_ownedComment.0' body='The set of nodes and edges that initialize values or perform other setup computations for the loop.'>
								<annotatedElement xmi:idref='Activities-StructuredActivities-LoopNode-setupPart'/>
							</ownedComment>
							<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='Activities-StructuredActivities-LoopNode-setupPart-_upperValue' visibility='public' value='*'/>
							<lowerValue xmi:type='uml:LiteralInteger' xmi:id='Activities-StructuredActivities-LoopNode-setupPart-_lowerValue' visibility='public'/>
						</ownedAttribute>
						<ownedAttribute xmi:type='uml:Property' xmi:id='Activities-StructuredActivities-LoopNode-test' name='test' visibility='public' type='Activities-StructuredActivities-ExecutableNode' association='Activities-StructuredActivities-A_test_loopNode'>
							<ownedComment xmi:type='uml:Comment' xmi:id='Activities-StructuredActivities-LoopNode-test-_ownedComment.0' body='The set of nodes, edges, and designated value that compute a Boolean value to determine if another execution of the body will be performed.'>
								<annotatedElement xmi:idref='Activities-StructuredActivities-LoopNode-test'/>
							</ownedComment>
							<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='Activities-StructuredActivities-LoopNode-test-_upperValue' visibility='public' value='*'/>
						</ownedAttribute>
					</packagedElement>
					<packagedElement xmi:type='uml:Association' xmi:id='Activities-StructuredActivities-A_bodyPart_loopNode' name='A_bodyPart_loopNode' visibility='public'>
						<memberEnd xmi:idref='Activities-StructuredActivities-LoopNode-bodyPart'/>
						<memberEnd xmi:idref='Activities-StructuredActivities-A_bodyPart_loopNode-loopNode'/>
						<ownedEnd xmi:type='uml:Property' xmi:id='Activities-StructuredActivities-A_bodyPart_loopNode-loopNode' name='loopNode' visibility='public' type='Activities-StructuredActivities-LoopNode' association='Activities-StructuredActivities-A_bodyPart_loopNode'>
							<lowerValue xmi:type='uml:LiteralInteger' xmi:id='Activities-StructuredActivities-A_bodyPart_loopNode-loopNode-_lowerValue' visibility='public'/>
						</ownedEnd>
					</packagedElement>
					<packagedElement xmi:type='uml:Class' xmi:id='Activities-StructuredActivities-Clause' name='Clause' visibility='public'>
						<xmi:Extension extender='MagicDraw UML 16.8'>
							<modelExtension/>
						</xmi:Extension>
						<ownedComment xmi:type='uml:Comment' xmi:id='Activities-StructuredActivities-Clause-_ownedComment.0' body='A clause is an element that represents a single branch of a conditional construct, including a test and a body section. The body section is executed only if (but not necessarily if) the test section evaluates true.'>
							<annotatedElement xmi:idref='Activities-StructuredActivities-Clause'/>
						</ownedComment>
						<ownedRule xmi:type='uml:Constraint' xmi:id='Activities-StructuredActivities-Clause-test_and_body' name='test_and_body' visibility='public'>
							<constrainedElement xmi:idref='Activities-StructuredActivities-Clause'/>
							<ownedComment xmi:type='uml:Comment' xmi:id='Activities-StructuredActivities-Clause-test_and_body-_ownedComment.0' body='The test and body parts must be disjoint.'>
								<annotatedElement xmi:idref='Activities-StructuredActivities-Clause-test_and_body'/>
							</ownedComment>
							<specification xmi:type='uml:OpaqueExpression' xmi:id='Activities-StructuredActivities-Clause-test_and_body-_specification' visibility='public'>
								<body>true</body>
								<language>OCL</language>
							</specification>
						</ownedRule>
						<ownedRule xmi:type='uml:Constraint' xmi:id='Activities-StructuredActivities-Clause-decider_output' name='decider_output' visibility='public'>
							<constrainedElement xmi:idref='Activities-StructuredActivities-Clause'/>
							<ownedComment xmi:type='uml:Comment' xmi:id='Activities-StructuredActivities-Clause-decider_output-_ownedComment.0' body='The decider output pin must be for the test body or a node contained by the test body as a structured node.'>
								<annotatedElement xmi:idref='Activities-StructuredActivities-Clause-decider_output'/>
							</ownedComment>
							<specification xmi:type='uml:OpaqueExpression' xmi:id='Activities-StructuredActivities-Clause-decider_output-_specification' visibility='public'>
								<body>true</body>
								<language>OCL</language>
							</specification>
						</ownedRule>
						<generalization xmi:type='uml:Generalization' xmi:id='Activities-StructuredActivities-Clause-_generalization.0' general='Classes-Kernel-Element'/>
						<ownedAttribute xmi:type='uml:Property' xmi:id='Activities-StructuredActivities-Clause-body' name='body' visibility='public' type='Activities-StructuredActivities-ExecutableNode' association='Activities-StructuredActivities-A_body_clause'>
							<ownedComment xmi:type='uml:Comment' xmi:id='Activities-StructuredActivities-Clause-body-_ownedComment.0' body='A nested activity fragment that is executed if the test evaluates to true and the clause is chosen over any concurrent clauses that also evaluate to true.'>
								<annotatedElement xmi:idref='Activities-StructuredActivities-Clause-body'/>
							</ownedComment>
							<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='Activities-StructuredActivities-Clause-body-_upperValue' visibility='public' value='*'/>
							<lowerValue xmi:type='uml:LiteralInteger' xmi:id='Activities-StructuredActivities-Clause-body-_lowerValue' visibility='public'/>
						</ownedAttribute>
						<ownedAttribute xmi:type='uml:Property' xmi:id='Activities-StructuredActivities-Clause-decider' name='decider' visibility='public' type='Activities-StructuredActivities-OutputPin' association='Activities-StructuredActivities-A_decider_clause'>
							<ownedComment xmi:type='uml:Comment' xmi:id='Activities-StructuredActivities-Clause-decider-_ownedComment.0' body='An output pin within the test fragment the value of which is examined after execution of the test to determine whether the body should be executed.'>
								<annotatedElement xmi:idref='Activities-StructuredActivities-Clause-decider'/>
							</ownedComment>
						</ownedAttribute>
						<ownedAttribute xmi:type='uml:Property' xmi:id='Activities-StructuredActivities-Clause-predecessorClause' name='predecessorClause' visibility='public' type='Activities-StructuredActivities-Clause' association='Activities-StructuredActivities-A_predecessorClause_successorClause'>
							<ownedComment xmi:type='uml:Comment' xmi:id='Activities-StructuredActivities-Clause-predecessorClause-_ownedComment.0' body='A set of clauses whose tests must all evaluate false before the current clause can be tested.'>
								<annotatedElement xmi:idref='Activities-StructuredActivities-Clause-predecessorClause'/>
							</ownedComment>
							<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='Activities-StructuredActivities-Clause-predecessorClause-_upperValue' visibility='public' value='*'/>
							<lowerValue xmi:type='uml:LiteralInteger' xmi:id='Activities-StructuredActivities-Clause-predecessorClause-_lowerValue' visibility='public'/>
						</ownedAttribute>
						<ownedAttribute xmi:type='uml:Property' xmi:id='Activities-StructuredActivities-Clause-successorClause' name='successorClause' visibility='public' type='Activities-StructuredActivities-Clause' association='Activities-StructuredActivities-A_predecessorClause_successorClause'>
							<ownedComment xmi:type='uml:Comment' xmi:id='Activities-StructuredActivities-Clause-successorClause-_ownedComment.0' body='A set of clauses which may not be tested unless the current clause tests false.'>
								<annotatedElement xmi:idref='Activities-StructuredActivities-Clause-successorClause'/>
							</ownedComment>
							<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='Activities-StructuredActivities-Clause-successorClause-_upperValue' visibility='public' value='*'/>
