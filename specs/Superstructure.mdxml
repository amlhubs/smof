								<specification xmi:type='uml:OpaqueExpression' xmi:id='Deployments-Nodes-DeploymentTarget-deployedElement.1-spec-_specification' visibility='public'>
									<body>result = ((self.deployment-&gt;collect(deployedArtifact))-&gt;collect(manifestation))-&gt;collect(utilizedElement)</body>
									<language>OCL</language>
								</specification>
							</ownedRule>
							<ownedParameter xmi:type='uml:Parameter' xmi:id='Deployments-Nodes-DeploymentTarget-deployedElement.1-result' name='result' visibility='public' direction='return' effect='create' type='Classes-Kernel-PackageableElement'>
								<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='Deployments-Nodes-DeploymentTarget-deployedElement.1-result-_upperValue' visibility='public' value='*'/>
								<lowerValue xmi:type='uml:LiteralInteger' xmi:id='Deployments-Nodes-DeploymentTarget-deployedElement.1-result-_lowerValue' visibility='public'/>
							</ownedParameter>
