						<ownedComment xmi:type='uml:Comment' xmi:id='Activities-IntermediateActivities-JoinNode-_ownedComment.0' body='A join node is a control node that synchronizes multiple flows.'>
							<annotatedElement xmi:idref='Activities-IntermediateActivities-JoinNode'/>
						</ownedComment>
						<generalization xmi:type='uml:Generalization' xmi:id='Activities-IntermediateActivities-JoinNode-_generalization.0' general='Activities-BasicActivities-ControlNode'/>
					</packagedElement>
					<packagedElement xmi:type='uml:Class' xmi:id='Activities-IntermediateActivities-MergeNode' name='MergeNode' visibility='public'>
						<xmi:Extension extender='MagicDraw UML 16.8'>
							<modelExtension/>
						</xmi:Extension>
						<ownedComment xmi:type='uml:Comment' xmi:id='Activities-IntermediateActivities-MergeNode-_ownedComment.0' body='A merge node is a control node that brings together multiple alternate flows. It is not used to synchronize concurrent flows but to accept one among several alternate flows.'>
							<annotatedElement xmi:idref='Activities-IntermediateActivities-MergeNode'/>
						</ownedComment>
						<ownedRule xmi:type='uml:Constraint' xmi:id='Activities-IntermediateActivities-MergeNode-one_outgoing_edge' name='one_outgoing_edge' visibility='public'>
							<constrainedElement xmi:idref='Activities-IntermediateActivities-MergeNode'/>
							<ownedComment xmi:type='uml:Comment' xmi:id='Activities-IntermediateActivities-MergeNode-one_outgoing_edge-_ownedComment.0' body='A merge node has one outgoing edge.'>
								<annotatedElement xmi:idref='Activities-IntermediateActivities-MergeNode-one_outgoing_edge'/>
							</ownedComment>
							<specification xmi:type='uml:OpaqueExpression' xmi:id='Activities-IntermediateActivities-MergeNode-one_outgoing_edge-_specification' visibility='public'>
								<body>true</body>
								<language>OCL</language>
							</specification>
						</ownedRule>
						<ownedRule xmi:type='uml:Constraint' xmi:id='Activities-IntermediateActivities-MergeNode-edges' name='edges' visibility='public'>
							<constrainedElement xmi:idref='Activities-IntermediateActivities-MergeNode'/>
							<ownedComment xmi:type='uml:Comment' xmi:id='Activities-IntermediateActivities-MergeNode-edges-_ownedComment.0' body='The edges coming into and out of a merge node must be either all object flows or all control flows.'>
								<annotatedElement xmi:idref='Activities-IntermediateActivities-MergeNode-edges'/>
							</ownedComment>
							<specification xmi:type='uml:OpaqueExpression' xmi:id='Activities-IntermediateActivities-MergeNode-edges-_specification' visibility='public'>
								<body>true</body>
								<language>OCL</language>
							</specification>
						</ownedRule>
						<generalization xmi:type='uml:Generalization' xmi:id='Activities-IntermediateActivities-MergeNode-_generalization.0' general='Activities-BasicActivities-ControlNode'/>
