								<annotatedElement xmi:idref='Classes-Kernel-DataType-inherit'/>
							</ownedComment>
							<ownedRule xmi:type='uml:Constraint' xmi:id='Classes-Kernel-DataType-inherit-spec' name='spec' visibility='public'>
