							<subsettedProperty xmi:idref='Interactions-BasicInteractions-Lifeline-coveredBy'/>
							<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='Interactions-BasicInteractions-A_covered_events-events-_upperValue' visibility='public' value='*'/>
							<lowerValue xmi:type='uml:LiteralInteger' xmi:id='Interactions-BasicInteractions-A_covered_events-events-_lowerValue' visibility='public'/>
