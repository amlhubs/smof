						<ownedComment xmi:type='uml:Comment' xmi:id='Deployments-Nodes-DeploymentTarget-_ownedComment.0' body='A deployment target is the location for a deployed artifact.'>
							<annotatedElement xmi:idref='Deployments-Nodes-DeploymentTarget'/>
						</ownedComment>
						<generalization xmi:type='uml:Generalization' xmi:id='Deployments-Nodes-DeploymentTarget-_generalization.0' general='Classes-Dependencies-NamedElement'/>
