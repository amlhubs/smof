					<packagedElement xmi:type='uml:Class' xmi:id='Classes-Kernel-LiteralUnlimitedNatural' name='LiteralUnlimitedNatural' visibility='public'>
						<ownedComment xmi:type='uml:Comment' xmi:id='Classes-Kernel-LiteralUnlimitedNatural-_ownedComment.0' body='A literal unlimited natural is a specification of an unlimited natural number.'>
