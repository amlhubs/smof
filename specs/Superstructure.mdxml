				<packagedElement xmi:type='uml:Package' xmi:id='CompositeStructures-Collaborations' name='Collaborations' visibility='public'>
					<packageMerge xmi:type='uml:PackageMerge' xmi:id='CompositeStructures-Collaborations-_packageMerge.0' mergedPackage='CompositeStructures-InternalStructures'/>
					<packagedElement xmi:type='uml:Class' xmi:id='CompositeStructures-Collaborations-Classifier' name='Classifier' visibility='public' isAbstract='true'>
						<ownedComment xmi:type='uml:Comment' xmi:id='CompositeStructures-Collaborations-Classifier-_ownedComment.0' body='A classifier has the capability to own collaboration uses. These collaboration uses link a collaboration with the classifier to give a description of the workings of the classifier.'>
							<annotatedElement xmi:idref='CompositeStructures-Collaborations-Classifier'/>
						</ownedComment>
						<generalization xmi:type='uml:Generalization' xmi:id='CompositeStructures-Collaborations-Classifier-_generalization.0' general='Classes-Kernel-Namespace'/>
						<ownedAttribute xmi:type='uml:Property' xmi:id='CompositeStructures-Collaborations-Classifier-collaborationUse' name='collaborationUse' visibility='public' aggregation='composite' type='CompositeStructures-Collaborations-CollaborationUse' association='CompositeStructures-Collaborations-A_collaborationUse_classifier'>
							<subsettedProperty xmi:idref='Classes-Kernel-Element-ownedElement'/>
							<ownedComment xmi:type='uml:Comment' xmi:id='CompositeStructures-Collaborations-Classifier-collaborationUse-_ownedComment.0' body='References the collaboration uses owned by the classifier.'>
								<annotatedElement xmi:idref='CompositeStructures-Collaborations-Classifier-collaborationUse'/>
							</ownedComment>
							<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='CompositeStructures-Collaborations-Classifier-collaborationUse-_upperValue' visibility='public' value='*'/>
