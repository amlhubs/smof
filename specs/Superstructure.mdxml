						<ownedRule xmi:type='uml:Constraint' xmi:id='Activities-BasicActivities-ActivityGroup-not_contained' name='not_contained' visibility='public'>
							<constrainedElement xmi:idref='Activities-BasicActivities-ActivityGroup'/>
							<ownedComment xmi:type='uml:Comment' xmi:id='Activities-BasicActivities-ActivityGroup-not_contained-_ownedComment.0' body='No node or edge in a group may be contained by its subgroups or its containing groups, transitively.'>
