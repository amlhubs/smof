								</specification>
							</ownedRule>
							<ownedParameter xmi:type='uml:Parameter' xmi:id='Actions-BasicActions-Action-context.1-result' name='result' visibility='public' direction='return' effect='create' type='Classes-Kernel-Classifier'>
