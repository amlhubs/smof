					<packagedElement xmi:type='uml:Class' xmi:id='Classes-Kernel-ElementImport' name='ElementImport' visibility='public'>
						<xmi:Extension extender='MagicDraw UML 16.8'>
							<modelExtension/>
						</xmi:Extension>
						<ownedComment xmi:type='uml:Comment' xmi:id='Classes-Kernel-ElementImport-_ownedComment.0' body='An element import identifies an element in another package, and allows the element to be referenced using its name without a qualifier.'>
							<annotatedElement xmi:idref='Classes-Kernel-ElementImport'/>
						</ownedComment>
						<ownedRule xmi:type='uml:Constraint' xmi:id='Classes-Kernel-ElementImport-visibility_public_or_private' name='visibility_public_or_private' visibility='public'>
							<constrainedElement xmi:idref='Classes-Kernel-ElementImport'/>
							<ownedComment xmi:type='uml:Comment' xmi:id='Classes-Kernel-ElementImport-visibility_public_or_private-_ownedComment.0' body='The visibility of an ElementImport is either public or private.'>
								<annotatedElement xmi:idref='Classes-Kernel-ElementImport-visibility_public_or_private'/>
							</ownedComment>
							<specification xmi:type='uml:OpaqueExpression' xmi:id='Classes-Kernel-ElementImport-visibility_public_or_private-_specification' visibility='public'>
								<body>self.visibility = #public or self.visibility = #private</body>
								<language>OCL</language>
							</specification>
						</ownedRule>
						<ownedRule xmi:type='uml:Constraint' xmi:id='Classes-Kernel-ElementImport-imported_element_is_public' name='imported_element_is_public' visibility='public'>
							<constrainedElement xmi:idref='Classes-Kernel-ElementImport'/>
							<ownedComment xmi:type='uml:Comment' xmi:id='Classes-Kernel-ElementImport-imported_element_is_public-_ownedComment.0' body='An importedElement has either public visibility or no visibility at all.'>
								<annotatedElement xmi:idref='Classes-Kernel-ElementImport-imported_element_is_public'/>
							</ownedComment>
							<specification xmi:type='uml:OpaqueExpression' xmi:id='Classes-Kernel-ElementImport-imported_element_is_public-_specification' visibility='public'>
								<body>self.importedElement.visibility.notEmpty() implies self.importedElement.visibility = #public</body>
								<language>OCL</language>
							</specification>
						</ownedRule>
						<generalization xmi:type='uml:Generalization' xmi:id='Classes-Kernel-ElementImport-_generalization.0' general='Classes-Kernel-DirectedRelationship'/>
						<ownedAttribute xmi:type='uml:Property' xmi:id='Classes-Kernel-ElementImport-alias' name='alias' visibility='public'>
							<type xmi:type='uml:PrimitiveType' href='http://schema.omg.org/spec/UML/2.3/uml.xml#String'>
								<xmi:Extension extender='MagicDraw UML 16.8'>
									<referenceExtension referentPath='PrimitiveTypes::String' referentType='PrimitiveType'/>
								</xmi:Extension>
							</type>
							<ownedComment xmi:type='uml:Comment' xmi:id='Classes-Kernel-ElementImport-alias-_ownedComment.0' body='Specifies the name that should be added to the namespace of the importing package in lieu of the name of the imported packagable element. The aliased name must not clash with any other member name in the importing package. By default, no alias is used.'>
								<annotatedElement xmi:idref='Classes-Kernel-ElementImport-alias'/>
							</ownedComment>
							<lowerValue xmi:type='uml:LiteralInteger' xmi:id='Classes-Kernel-ElementImport-alias-_lowerValue' visibility='public'/>
						</ownedAttribute>
						<ownedAttribute xmi:type='uml:Property' xmi:id='Classes-Kernel-ElementImport-importedElement' name='importedElement' visibility='public' type='Classes-Kernel-PackageableElement' association='Classes-Kernel-A_importedElement_elementImport'>
							<subsettedProperty xmi:idref='Classes-Kernel-DirectedRelationship-target'/>
							<ownedComment xmi:type='uml:Comment' xmi:id='Classes-Kernel-ElementImport-importedElement-_ownedComment.0' body='Specifies the PackageableElement whose name is to be added to a Namespace.'>
								<annotatedElement xmi:idref='Classes-Kernel-ElementImport-importedElement'/>
							</ownedComment>
						</ownedAttribute>
						<ownedAttribute xmi:type='uml:Property' xmi:id='Classes-Kernel-ElementImport-importingNamespace' name='importingNamespace' visibility='public' type='Classes-Kernel-Namespace' association='Classes-Kernel-A_elementImport_importingNamespace'>
							<subsettedProperty xmi:idref='Classes-Kernel-DirectedRelationship-source'/>
							<subsettedProperty xmi:idref='Classes-Kernel-Element-owner'/>
							<ownedComment xmi:type='uml:Comment' xmi:id='Classes-Kernel-ElementImport-importingNamespace-_ownedComment.0' body='Specifies the Namespace that imports a PackageableElement from another Package.'>
								<annotatedElement xmi:idref='Classes-Kernel-ElementImport-importingNamespace'/>
							</ownedComment>
						</ownedAttribute>
						<ownedAttribute xmi:type='uml:Property' xmi:id='Classes-Kernel-ElementImport-visibility' name='visibility' visibility='public' type='Classes-Kernel-VisibilityKind'>
							<ownedComment xmi:type='uml:Comment' xmi:id='Classes-Kernel-ElementImport-visibility-_ownedComment.0' body='Specifies the visibility of the imported PackageableElement within the importing Package. The default visibility is the same as that of the imported element. If the imported element does not have a visibility, it is possible to add visibility to the element import.'>
								<annotatedElement xmi:idref='Classes-Kernel-ElementImport-visibility'/>
							</ownedComment>
							<defaultValue xmi:type='uml:InstanceValue' xmi:id='Classes-Kernel-ElementImport-visibility-_defaultValue' visibility='public' type='Classes-Kernel-VisibilityKind' instance='Classes-Kernel-VisibilityKind-public'/>
						</ownedAttribute>
						<ownedOperation xmi:type='uml:Operation' xmi:id='Classes-Kernel-ElementImport-getName' name='getName' visibility='public' isQuery='true' bodyCondition='Classes-Kernel-ElementImport-getName-spec'>
							<xmi:Extension extender='MagicDraw UML 16.8'>
								<modelExtension/>
							</xmi:Extension>
							<ownedComment xmi:type='uml:Comment' xmi:id='Classes-Kernel-ElementImport-getName-_ownedComment.0' body='The query getName() returns the name under which the imported PackageableElement will be known in the importing namespace.'>
								<annotatedElement xmi:idref='Classes-Kernel-ElementImport-getName'/>
							</ownedComment>
							<ownedRule xmi:type='uml:Constraint' xmi:id='Classes-Kernel-ElementImport-getName-spec' name='spec' visibility='public'>
								<constrainedElement xmi:idref='Classes-Kernel-ElementImport-getName'/>
								<specification xmi:type='uml:OpaqueExpression' xmi:id='Classes-Kernel-ElementImport-getName-spec-_specification' visibility='public'>
									<body>result = if self.alias-&gt;notEmpty() then
  self.alias
else
  self.importedElement.name
endif</body>
									<language>OCL</language>
								</specification>
							</ownedRule>
							<ownedParameter xmi:type='uml:Parameter' xmi:id='Classes-Kernel-ElementImport-getName-result' name='result' visibility='public' direction='return' effect='create'>
								<type xmi:type='uml:PrimitiveType' href='http://schema.omg.org/spec/UML/2.3/uml.xml#String'>
									<xmi:Extension extender='MagicDraw UML 16.8'>
										<referenceExtension referentPath='PrimitiveTypes::String' referentType='PrimitiveType'/>
									</xmi:Extension>
								</type>
							</ownedParameter>
						</ownedOperation>
					</packagedElement>
