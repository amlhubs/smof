							<ownedComment xmi:type='uml:Comment' xmi:id='Classes-Kernel-MultiplicityElement-isMultivalued-_ownedComment.0' body='The query isMultivalued() checks whether this multiplicity has an upper bound greater than one.'>
								<annotatedElement xmi:idref='Classes-Kernel-MultiplicityElement-isMultivalued'/>
