						</xmi:Extension>
						<ownedRule xmi:type='uml:Constraint' xmi:id='Activities-BasicActivities-ValuePin-no_incoming_edges' name='no_incoming_edges' visibility='public'>
							<constrainedElement xmi:idref='Activities-BasicActivities-ValuePin'/>
							<ownedComment xmi:type='uml:Comment' xmi:id='Activities-BasicActivities-ValuePin-no_incoming_edges-_ownedComment.0' body='Value pins have no incoming edges.'>
								<annotatedElement xmi:idref='Activities-BasicActivities-ValuePin-no_incoming_edges'/>
							</ownedComment>
							<specification xmi:type='uml:OpaqueExpression' xmi:id='Activities-BasicActivities-ValuePin-no_incoming_edges-_specification' visibility='public'>
								<body>true</body>
								<language>OCL</language>
							</specification>
						</ownedRule>
					</packagedElement>
					<packagedElement xmi:type='uml:Class' xmi:id='Activities-BasicActivities-ControlNode' name='ControlNode' visibility='public' isAbstract='true'>
						<ownedComment xmi:type='uml:Comment' xmi:id='Activities-BasicActivities-ControlNode-_ownedComment.0' body='A control node is an abstract activity node that coordinates flows in an activity.'>
							<annotatedElement xmi:idref='Activities-BasicActivities-ControlNode'/>
						</ownedComment>
						<generalization xmi:type='uml:Generalization' xmi:id='Activities-BasicActivities-ControlNode-_generalization.0' general='Activities-BasicActivities-ActivityNode'/>
					</packagedElement>
				</packagedElement>
				<packagedElement xmi:type='uml:Package' xmi:id='Activities-CompleteActivities' name='CompleteActivities' visibility='public'>
					<packageImport xmi:type='uml:PackageImport' xmi:id='Activities-CompleteActivities-_packageImport.0' importedPackage='StateMachines-BehaviorStateMachines'/>
					<packageImport xmi:type='uml:PackageImport' xmi:id='Activities-CompleteActivities-_packageImport.1' importedPackage='CommonBehaviors-BasicBehaviors'/>
					<packageImport xmi:type='uml:PackageImport' xmi:id='Activities-CompleteActivities-_packageImport.2' importedPackage='Classes-Kernel'/>
					<packageMerge xmi:type='uml:PackageMerge' xmi:id='Activities-CompleteActivities-_packageMerge.0' mergedPackage='Activities-IntermediateActivities'/>
					<packagedElement xmi:type='uml:Association' xmi:id='Activities-CompleteActivities-A_localPrecondition_action' name='A_localPrecondition_action' visibility='public'>
						<memberEnd xmi:idref='Activities-CompleteActivities-Action-localPrecondition'/>
						<memberEnd xmi:idref='Activities-CompleteActivities-A_localPrecondition_action-action'/>
						<ownedEnd xmi:type='uml:Property' xmi:id='Activities-CompleteActivities-A_localPrecondition_action-action' name='action' visibility='public' type='Activities-CompleteActivities-Action' association='Activities-CompleteActivities-A_localPrecondition_action'>
							<subsettedProperty xmi:idref='Classes-Kernel-Element-owner'/>
							<lowerValue xmi:type='uml:LiteralInteger' xmi:id='Activities-CompleteActivities-A_localPrecondition_action-action-_lowerValue' visibility='public'/>
						</ownedEnd>
					</packagedElement>
					<packagedElement xmi:type='uml:Association' xmi:id='Activities-CompleteActivities-A_localPostcondition_action' name='A_localPostcondition_action' visibility='public'>
						<memberEnd xmi:idref='Activities-CompleteActivities-A_localPostcondition_action-action'/>
						<memberEnd xmi:idref='Activities-CompleteActivities-Action-localPostcondition'/>
						<ownedEnd xmi:type='uml:Property' xmi:id='Activities-CompleteActivities-A_localPostcondition_action-action' name='action' visibility='public' type='Activities-CompleteActivities-Action' association='Activities-CompleteActivities-A_localPostcondition_action'>
							<subsettedProperty xmi:idref='Classes-Kernel-Element-owner'/>
							<lowerValue xmi:type='uml:LiteralInteger' xmi:id='Activities-CompleteActivities-A_localPostcondition_action-action-_lowerValue' visibility='public'/>
						</ownedEnd>
					</packagedElement>
					<packagedElement xmi:type='uml:Class' xmi:id='Activities-CompleteActivities-Pin' name='Pin' visibility='public' isAbstract='true'>
						<xmi:Extension extender='MagicDraw UML 16.8'>
							<modelExtension/>
						</xmi:Extension>
						<ownedRule xmi:type='uml:Constraint' xmi:id='Activities-CompleteActivities-Pin-control_pins' name='control_pins' visibility='public'>
							<constrainedElement xmi:idref='Activities-CompleteActivities-Pin'/>
							<ownedComment xmi:type='uml:Comment' xmi:id='Activities-CompleteActivities-Pin-control_pins-_ownedComment.0' body='Control pins have a control type'>
								<annotatedElement xmi:idref='Activities-CompleteActivities-Pin-control_pins'/>
							</ownedComment>
							<specification xmi:type='uml:OpaqueExpression' xmi:id='Activities-CompleteActivities-Pin-control_pins-_specification' visibility='public'>
								<body>isControl implies isControlType</body>
								<language>OCL</language>
							</specification>
						</ownedRule>
						<ownedAttribute xmi:type='uml:Property' xmi:id='Activities-CompleteActivities-Pin-isControl' name='isControl' visibility='public'>
							<type xmi:type='uml:PrimitiveType' href='http://schema.omg.org/spec/UML/2.3/uml.xml#Boolean'>
								<xmi:Extension extender='MagicDraw UML 16.8'>
									<referenceExtension referentPath='PrimitiveTypes::Boolean' referentType='PrimitiveType'/>
								</xmi:Extension>
							</type>
							<ownedComment xmi:type='uml:Comment' xmi:id='Activities-CompleteActivities-Pin-isControl-_ownedComment.0' body='Tells whether the pins provide data to the actions, or just controls when it executes it.'>
								<annotatedElement xmi:idref='Activities-CompleteActivities-Pin-isControl'/>
							</ownedComment>
							<defaultValue xmi:type='uml:LiteralBoolean' xmi:id='Activities-CompleteActivities-Pin-isControl-_defaultValue' visibility='public'/>
						</ownedAttribute>
					</packagedElement>
