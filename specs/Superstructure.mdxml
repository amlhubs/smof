						<memberEnd xmi:idref='StateMachines-BehaviorStateMachines-State-exit'/>
						<memberEnd xmi:idref='StateMachines-BehaviorStateMachines-A_exit_state-state'/>
						<ownedEnd xmi:type='uml:Property' xmi:id='StateMachines-BehaviorStateMachines-A_exit_state-state' name='state' visibility='public' type='StateMachines-BehaviorStateMachines-State' association='StateMachines-BehaviorStateMachines-A_exit_state'>
							<subsettedProperty xmi:idref='Classes-Kernel-Element-owner'/>
							<lowerValue xmi:type='uml:LiteralInteger' xmi:id='StateMachines-BehaviorStateMachines-A_exit_state-state-_lowerValue' visibility='public'/>
						</ownedEnd>
					</packagedElement>
					<packagedElement xmi:type='uml:Association' xmi:id='StateMachines-BehaviorStateMachines-A_trigger_transition' name='A_trigger_transition' visibility='public'>
