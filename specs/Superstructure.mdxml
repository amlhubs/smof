								<specification xmi:type='uml:OpaqueExpression' xmi:id='Classes-Kernel-MultiplicityElement-isMultivalued-pre-_specification' visibility='public'>
									<body>upperBound()-&gt;notEmpty()</body>
									<language>OCL</language>
								</specification>
							</ownedRule>
							<ownedRule xmi:type='uml:Constraint' xmi:id='Classes-Kernel-MultiplicityElement-isMultivalued-spec' name='spec' visibility='public'>
								<constrainedElement xmi:idref='Classes-Kernel-MultiplicityElement-isMultivalued'/>
								<specification xmi:type='uml:OpaqueExpression' xmi:id='Classes-Kernel-MultiplicityElement-isMultivalued-spec-_specification' visibility='public'>
									<body>result = upperBound() &gt; 1</body>
									<language>OCL</language>
								</specification>
							</ownedRule>
							<ownedParameter xmi:type='uml:Parameter' xmi:id='Classes-Kernel-MultiplicityElement-isMultivalued-result' name='result' visibility='public' direction='return' effect='create'>
