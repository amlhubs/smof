									<referenceExtension referentPath='PrimitiveTypes::Boolean' referentType='PrimitiveType'/>
								</xmi:Extension>
							</type>
							<ownedComment xmi:type='uml:Comment' xmi:id='CommonBehaviors-SimpleTime-TimeConstraint-firstEvent-_ownedComment.0' body='The value of firstEvent is related to constrainedElement. If firstEvent is true, then the corresponding observation event is the first time instant the execution enters constrainedElement. If firstEvent is false, then the corresponding observation event is the last time instant the execution is within constrainedElement.'>
								<annotatedElement xmi:idref='CommonBehaviors-SimpleTime-TimeConstraint-firstEvent'/>
							</ownedComment>
							<lowerValue xmi:type='uml:LiteralInteger' xmi:id='CommonBehaviors-SimpleTime-TimeConstraint-firstEvent-_lowerValue' visibility='public'/>
							<defaultValue xmi:type='uml:LiteralBoolean' xmi:id='CommonBehaviors-SimpleTime-TimeConstraint-firstEvent-_defaultValue' visibility='public' value='true'/>
						</ownedAttribute>
						<ownedAttribute xmi:type='uml:Property' xmi:id='CommonBehaviors-SimpleTime-TimeConstraint-specification' name='specification' visibility='public' aggregation='composite' type='CommonBehaviors-SimpleTime-TimeInterval' association='CommonBehaviors-SimpleTime-A_specification_timeConstraint'>
							<redefinedProperty xmi:idref='CommonBehaviors-SimpleTime-IntervalConstraint-specification'/>
							<ownedComment xmi:type='uml:Comment' xmi:id='CommonBehaviors-SimpleTime-TimeConstraint-specification-_ownedComment.0' body='A condition that must be true when evaluated in order for the constraint to be satisfied.'>
