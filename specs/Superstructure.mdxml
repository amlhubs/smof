						<ownedOperation xmi:type='uml:Operation' xmi:id='AuxiliaryConstructs-Templates-ParameterableElement-isCompatibleWith' name='isCompatibleWith' visibility='public' isQuery='true' bodyCondition='AuxiliaryConstructs-Templates-ParameterableElement-isCompatibleWith-spec'>
							<xmi:Extension extender='MagicDraw UML 16.8'>
								<modelExtension/>
							</xmi:Extension>
							<ownedComment xmi:type='uml:Comment' xmi:id='AuxiliaryConstructs-Templates-ParameterableElement-isCompatibleWith-_ownedComment.0' body='The query isCompatibleWith() determines if this parameterable element is compatible with the specified parameterable element. By default parameterable element P is compatible with parameterable element Q if the kind of P is the same or a subtype as the kind of Q. Subclasses should override this operation to specify different compatibility constraints.'>
								<annotatedElement xmi:idref='AuxiliaryConstructs-Templates-ParameterableElement-isCompatibleWith'/>
							</ownedComment>
							<ownedRule xmi:type='uml:Constraint' xmi:id='AuxiliaryConstructs-Templates-ParameterableElement-isCompatibleWith-spec' name='spec' visibility='public'>
								<constrainedElement xmi:idref='AuxiliaryConstructs-Templates-ParameterableElement-isCompatibleWith'/>
								<specification xmi:type='uml:OpaqueExpression' xmi:id='AuxiliaryConstructs-Templates-ParameterableElement-isCompatibleWith-spec-_specification' visibility='public'>
									<body>result = p-&gt;oclIsKindOf(self.oclType)</body>
									<language>OCL</language>
								</specification>
							</ownedRule>
							<ownedParameter xmi:type='uml:Parameter' xmi:id='AuxiliaryConstructs-Templates-ParameterableElement-isCompatibleWith-result' name='result' visibility='public' direction='return' effect='create'>
								<type xmi:type='uml:PrimitiveType' href='http://schema.omg.org/spec/UML/2.3/uml.xml#Boolean'>
									<xmi:Extension extender='MagicDraw UML 16.8'>
										<referenceExtension referentPath='PrimitiveTypes::Boolean' referentType='PrimitiveType'/>
									</xmi:Extension>
								</type>
							</ownedParameter>
							<ownedParameter xmi:type='uml:Parameter' xmi:id='AuxiliaryConstructs-Templates-ParameterableElement-isCompatibleWith-p' name='p' visibility='public' effect='create' type='AuxiliaryConstructs-Templates-ParameterableElement'/>
						</ownedOperation>
						<ownedOperation xmi:type='uml:Operation' xmi:id='AuxiliaryConstructs-Templates-ParameterableElement-isTemplateParameter' name='isTemplateParameter' visibility='public' isQuery='true' bodyCondition='AuxiliaryConstructs-Templates-ParameterableElement-isTemplateParameter-spec'>
							<xmi:Extension extender='MagicDraw UML 16.8'>
								<modelExtension/>
							</xmi:Extension>
							<ownedComment xmi:type='uml:Comment' xmi:id='AuxiliaryConstructs-Templates-ParameterableElement-isTemplateParameter-_ownedComment.0' body='The query isTemplateParameter() determines if this parameterable element is exposed as a formal template parameter.'>
								<annotatedElement xmi:idref='AuxiliaryConstructs-Templates-ParameterableElement-isTemplateParameter'/>
							</ownedComment>
							<ownedRule xmi:type='uml:Constraint' xmi:id='AuxiliaryConstructs-Templates-ParameterableElement-isTemplateParameter-spec' name='spec' visibility='public'>
