							<ownedParameter xmi:type='uml:Parameter' xmi:id='StateMachines-BehaviorStateMachines-Vertex-outgoing.1-result' name='result' visibility='public' direction='return' effect='create' type='StateMachines-BehaviorStateMachines-Transition'>
