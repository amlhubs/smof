								<specification xmi:type='uml:OpaqueExpression' xmi:id='Classes-Kernel-MultiplicityElement-lowerBound-spec-_specification' visibility='public'>
									<body>result = if lowerValue-&gt;isEmpty() then 1 else lowerValue.integerValue() endif</body>
									<language>OCL</language>
								</specification>
							</ownedRule>
							<ownedParameter xmi:type='uml:Parameter' xmi:id='Classes-Kernel-MultiplicityElement-lowerBound-result' name='result' visibility='public' direction='return' effect='create'>
