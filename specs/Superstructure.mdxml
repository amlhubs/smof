						<memberEnd xmi:idref='Actions-CompleteActions-LinkEndData-qualifier'/>
						<ownedEnd xmi:type='uml:Property' xmi:id='Actions-CompleteActions-A_qualifier_linkEndData-linkEndData' name='linkEndData' visibility='public' type='Actions-CompleteActions-LinkEndData' association='Actions-CompleteActions-A_qualifier_linkEndData'>
							<subsettedProperty xmi:idref='Classes-Kernel-Element-owner'/>
						</ownedEnd>
					</packagedElement>
					<packagedElement xmi:type='uml:Association' xmi:id='Actions-CompleteActions-A_qualifier_readLinkObjectEndQualifierAction' name='A_qualifier_readLinkObjectEndQualifierAction' visibility='public'>
