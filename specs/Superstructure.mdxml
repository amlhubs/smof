						<ownedComment xmi:type='uml:Comment' xmi:id='Deployments-Nodes-ExecutionEnvironment-_ownedComment.0' body='An execution environment is a node that offers an execution environment for specific types of components that are deployed on it in the form of executable artifacts.'>
							<annotatedElement xmi:idref='Deployments-Nodes-ExecutionEnvironment'/>
						</ownedComment>
						<generalization xmi:type='uml:Generalization' xmi:id='Deployments-Nodes-ExecutionEnvironment-_generalization.0' general='Deployments-Nodes-Node'/>
