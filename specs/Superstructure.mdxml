						<ownedOperation xmi:type='uml:Operation' xmi:id='Classes-Kernel-LiteralUnlimitedNatural-isComputable' name='isComputable' visibility='public' isQuery='true' bodyCondition='Classes-Kernel-LiteralUnlimitedNatural-isComputable-spec'>
							<xmi:Extension extender='MagicDraw UML 16.8'>
								<modelExtension/>
							</xmi:Extension>
							<redefinedOperation xmi:idref='Classes-Kernel-ValueSpecification-isComputable'/>
							<ownedComment xmi:type='uml:Comment' xmi:id='Classes-Kernel-LiteralUnlimitedNatural-isComputable-_ownedComment.0' body='The query isComputable() is redefined to be true.'>
								<annotatedElement xmi:idref='Classes-Kernel-LiteralUnlimitedNatural-isComputable'/>
							</ownedComment>
							<ownedRule xmi:type='uml:Constraint' xmi:id='Classes-Kernel-LiteralUnlimitedNatural-isComputable-spec' name='spec' visibility='public'>
								<constrainedElement xmi:idref='Classes-Kernel-LiteralUnlimitedNatural-isComputable'/>
								<specification xmi:type='uml:OpaqueExpression' xmi:id='Classes-Kernel-LiteralUnlimitedNatural-isComputable-spec-_specification' visibility='public'>
									<body>result = true</body>
									<language>OCL</language>
								</specification>
							</ownedRule>
							<ownedParameter xmi:type='uml:Parameter' xmi:id='Classes-Kernel-LiteralUnlimitedNatural-isComputable-result' name='result' visibility='public' direction='return' effect='create'>
								<type xmi:type='uml:PrimitiveType' href='http://schema.omg.org/spec/UML/2.3/uml.xml#Boolean'>
									<xmi:Extension extender='MagicDraw UML 16.8'>
										<referenceExtension referentPath='PrimitiveTypes::Boolean' referentType='PrimitiveType'/>
									</xmi:Extension>
								</type>
