							<ownedComment xmi:type='uml:Comment' xmi:id='Interactions-BasicInteractions-Message-connector-_ownedComment.0' body='The Connector on which this Message is sent.'>
								<annotatedElement xmi:idref='Interactions-BasicInteractions-Message-connector'/>
							</ownedComment>
							<lowerValue xmi:type='uml:LiteralInteger' xmi:id='Interactions-BasicInteractions-Message-connector-_lowerValue' visibility='public'/>
						</ownedAttribute>
						<ownedAttribute xmi:type='uml:Property' xmi:id='Interactions-BasicInteractions-Message-interaction' name='interaction' visibility='public' type='Interactions-BasicInteractions-Interaction' association='Interactions-BasicInteractions-A_message_interaction'>
							<subsettedProperty xmi:idref='Classes-Kernel-NamedElement-namespace'/>
							<ownedComment xmi:type='uml:Comment' xmi:id='Interactions-BasicInteractions-Message-interaction-_ownedComment.0' body='The enclosing Interaction owning the Message'>
								<annotatedElement xmi:idref='Interactions-BasicInteractions-Message-interaction'/>
							</ownedComment>
						</ownedAttribute>
						<ownedAttribute xmi:type='uml:Property' xmi:id='Interactions-BasicInteractions-Message-messageKind' name='messageKind' visibility='public' isReadOnly='true' isDerived='true' type='Interactions-BasicInteractions-MessageKind'>
							<xmi:Extension extender='MagicDraw UML 16.8'>
								<modelExtension/>
							</xmi:Extension>
							<ownedComment xmi:type='uml:Comment' xmi:id='Interactions-BasicInteractions-Message-messageKind-_ownedComment.0' body='The derived kind of the Message (complete, lost, found or unknown)'>
								<annotatedElement xmi:idref='Interactions-BasicInteractions-Message-messageKind'/>
							</ownedComment>
							<defaultValue xmi:type='uml:InstanceValue' xmi:id='Interactions-BasicInteractions-Message-messageKind-_defaultValue' visibility='public' type='Interactions-BasicInteractions-MessageKind' instance='Interactions-BasicInteractions-MessageKind-unknown'/>
						</ownedAttribute>
						<ownedAttribute xmi:type='uml:Property' xmi:id='Interactions-BasicInteractions-Message-messageSort' name='messageSort' visibility='public' type='Interactions-BasicInteractions-MessageSort'>
							<ownedComment xmi:type='uml:Comment' xmi:id='Interactions-BasicInteractions-Message-messageSort-_ownedComment.0' body='The sort of communication reflected by the Message'>
								<annotatedElement xmi:idref='Interactions-BasicInteractions-Message-messageSort'/>
							</ownedComment>
							<defaultValue xmi:type='uml:InstanceValue' xmi:id='Interactions-BasicInteractions-Message-messageSort-_defaultValue' visibility='public' type='Interactions-BasicInteractions-MessageSort' instance='Interactions-BasicInteractions-MessageSort-synchCall'/>
						</ownedAttribute>
						<ownedAttribute xmi:type='uml:Property' xmi:id='Interactions-BasicInteractions-Message-receiveEvent' name='receiveEvent' visibility='public' type='Interactions-BasicInteractions-MessageEnd' association='Interactions-BasicInteractions-A_receiveEvent_endMessage'>
							<subsettedProperty xmi:idref='Interactions-BasicInteractions-A_message_messageEnd-messageEnd'/>
							<ownedComment xmi:type='uml:Comment' xmi:id='Interactions-BasicInteractions-Message-receiveEvent-_ownedComment.0' body='References the Receiving of the Message'>
								<annotatedElement xmi:idref='Interactions-BasicInteractions-Message-receiveEvent'/>
							</ownedComment>
							<lowerValue xmi:type='uml:LiteralInteger' xmi:id='Interactions-BasicInteractions-Message-receiveEvent-_lowerValue' visibility='public'/>
						</ownedAttribute>
						<ownedAttribute xmi:type='uml:Property' xmi:id='Interactions-BasicInteractions-Message-sendEvent' name='sendEvent' visibility='public' type='Interactions-BasicInteractions-MessageEnd' association='Interactions-BasicInteractions-A_sendEvent_endMessage'>
