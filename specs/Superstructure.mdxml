							<ownedComment xmi:type='uml:Comment' xmi:id='Deployments-Nodes-InstanceSpecification-deployment_target-_ownedComment.0' body='An InstanceSpecification can be a DeploymentTarget if it is the instance specification of a Node and functions as a part in the internal structure of an encompassing Node.'>
								<annotatedElement xmi:idref='Deployments-Nodes-InstanceSpecification-deployment_target'/>
							</ownedComment>
							<specification xmi:type='uml:OpaqueExpression' xmi:id='Deployments-Nodes-InstanceSpecification-deployment_target-_specification' visibility='public'>
								<body>true</body>
