							</type>
							<ownedComment xmi:type='uml:Comment' xmi:id='Deployments-ComponentDeployments-DeploymentSpecification-executionLocation-_ownedComment.0' body='The location where a component Artifact executes. This may be a local or remote location.'>
								<annotatedElement xmi:idref='Deployments-ComponentDeployments-DeploymentSpecification-executionLocation'/>
							</ownedComment>
							<lowerValue xmi:type='uml:LiteralInteger' xmi:id='Deployments-ComponentDeployments-DeploymentSpecification-executionLocation-_lowerValue' visibility='public'/>
						</ownedAttribute>
					</packagedElement>
				</packagedElement>
				<packagedElement xmi:type='uml:Package' xmi:id='Deployments-Nodes' name='Nodes' visibility='public'>
					<packageMerge xmi:type='uml:PackageMerge' xmi:id='Deployments-Nodes-_packageMerge.0' mergedPackage='Deployments-Artifacts'/>
					<packageMerge xmi:type='uml:PackageMerge' xmi:id='Deployments-Nodes-_packageMerge.1' mergedPackage='CompositeStructures-StructuredClasses'/>
