						<ownedComment xmi:type='uml:Comment' xmi:id='Deployments-Nodes-Artifact-_ownedComment.0' body='An artifact is the source of a deployment to a node.'>
							<annotatedElement xmi:idref='Deployments-Nodes-Artifact'/>
						</ownedComment>
						<generalization xmi:type='uml:Generalization' xmi:id='Deployments-Nodes-Artifact-_generalization.0' general='Deployments-Nodes-DeployedArtifact'/>
