							<xmi:Extension extender='MagicDraw UML 16.8'>
								<modelExtension/>
							</xmi:Extension>
							<ownedComment xmi:type='uml:Comment' xmi:id='Classes-Kernel-MultiplicityElement-lowerBound-_ownedComment.0' body='The query lowerBound() returns the lower bound of the multiplicity as an integer.'>
								<annotatedElement xmi:idref='Classes-Kernel-MultiplicityElement-lowerBound'/>
							</ownedComment>
							<ownedRule xmi:type='uml:Constraint' xmi:id='Classes-Kernel-MultiplicityElement-lowerBound-spec' name='spec' visibility='public'>
