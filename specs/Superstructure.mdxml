						</ownedEnd>
					</packagedElement>
					<packagedElement xmi:type='uml:Enumeration' xmi:id='Classes-Kernel-ParameterDirectionKind' name='ParameterDirectionKind' visibility='public'>
						<ownedComment xmi:type='uml:Comment' xmi:id='Classes-Kernel-ParameterDirectionKind-_ownedComment.0' body='Parameter direction kind is an enumeration type that defines literals used to specify direction of parameters.'>
							<annotatedElement xmi:idref='Classes-Kernel-ParameterDirectionKind'/>
						</ownedComment>
						<ownedLiteral xmi:type='uml:EnumerationLiteral' xmi:id='Classes-Kernel-ParameterDirectionKind-in' name='in' visibility='public'>
							<classifier xmi:idref='Classes-Kernel-ParameterDirectionKind'/>
							<ownedComment xmi:type='uml:Comment' xmi:id='Classes-Kernel-ParameterDirectionKind-in-_ownedComment.0' body='Indicates that parameter values are passed into the behavioral element by the caller.'>
								<annotatedElement xmi:idref='Classes-Kernel-ParameterDirectionKind-in'/>
							</ownedComment>
						</ownedLiteral>
						<ownedLiteral xmi:type='uml:EnumerationLiteral' xmi:id='Classes-Kernel-ParameterDirectionKind-inout' name='inout' visibility='public'>
							<classifier xmi:idref='Classes-Kernel-ParameterDirectionKind'/>
							<ownedComment xmi:type='uml:Comment' xmi:id='Classes-Kernel-ParameterDirectionKind-inout-_ownedComment.0' body='Indicates that parameter values are passed into a behavioral element by the caller and then back out to the caller from the behavioral element.'>
								<annotatedElement xmi:idref='Classes-Kernel-ParameterDirectionKind-inout'/>
							</ownedComment>
						</ownedLiteral>
						<ownedLiteral xmi:type='uml:EnumerationLiteral' xmi:id='Classes-Kernel-ParameterDirectionKind-out' name='out' visibility='public'>
							<classifier xmi:idref='Classes-Kernel-ParameterDirectionKind'/>
						</ownedLiteral>
						<ownedLiteral xmi:type='uml:EnumerationLiteral' xmi:id='Classes-Kernel-ParameterDirectionKind-return' name='return' visibility='public'>
							<classifier xmi:idref='Classes-Kernel-ParameterDirectionKind'/>
							<ownedComment xmi:type='uml:Comment' xmi:id='Classes-Kernel-ParameterDirectionKind-return-_ownedComment.0' body='Indicates that parameter values are passed as return values from a behavioral element back to the caller.'>
								<annotatedElement xmi:idref='Classes-Kernel-ParameterDirectionKind-return'/>
							</ownedComment>
						</ownedLiteral>
					</packagedElement>
					<packagedElement xmi:type='uml:Association' xmi:id='Classes-Kernel-A_defaultValue_owningParameter' name='A_defaultValue_owningParameter' visibility='public'>
						<memberEnd xmi:idref='Classes-Kernel-A_defaultValue_owningParameter-owningParameter'/>
						<memberEnd xmi:idref='Classes-Kernel-Parameter-defaultValue'/>
						<ownedEnd xmi:type='uml:Property' xmi:id='Classes-Kernel-A_defaultValue_owningParameter-owningParameter' name='owningParameter' visibility='public' type='Classes-Kernel-Parameter' association='Classes-Kernel-A_defaultValue_owningParameter'>
							<subsettedProperty xmi:idref='Classes-Kernel-Element-owner'/>
							<lowerValue xmi:type='uml:LiteralInteger' xmi:id='Classes-Kernel-A_defaultValue_owningParameter-owningParameter-_lowerValue' visibility='public'/>
						</ownedEnd>
					</packagedElement>
					<packagedElement xmi:type='uml:Association' xmi:id='Classes-Kernel-A_instance_instanceValue' name='A_instance_instanceValue' visibility='public'>
						<memberEnd xmi:idref='Classes-Kernel-InstanceValue-instance'/>
						<memberEnd xmi:idref='Classes-Kernel-A_instance_instanceValue-instanceValue'/>
						<ownedEnd xmi:type='uml:Property' xmi:id='Classes-Kernel-A_instance_instanceValue-instanceValue' name='instanceValue' visibility='public' type='Classes-Kernel-InstanceValue' association='Classes-Kernel-A_instance_instanceValue'>
							<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='Classes-Kernel-A_instance_instanceValue-instanceValue-_upperValue' visibility='public' value='*'/>
							<lowerValue xmi:type='uml:LiteralInteger' xmi:id='Classes-Kernel-A_instance_instanceValue-instanceValue-_lowerValue' visibility='public'/>
						</ownedEnd>
					</packagedElement>
					<packagedElement xmi:type='uml:Class' xmi:id='Classes-Kernel-LiteralString' name='LiteralString' visibility='public'>
						<ownedComment xmi:type='uml:Comment' xmi:id='Classes-Kernel-LiteralString-_ownedComment.0' body='A literal string is a specification of a string value.'>
							<annotatedElement xmi:idref='Classes-Kernel-LiteralString'/>
						</ownedComment>
						<generalization xmi:type='uml:Generalization' xmi:id='Classes-Kernel-LiteralString-_generalization.0' general='Classes-Kernel-LiteralSpecification'/>
						<ownedAttribute xmi:type='uml:Property' xmi:id='Classes-Kernel-LiteralString-value' name='value' visibility='public'>
							<type xmi:type='uml:PrimitiveType' href='http://schema.omg.org/spec/UML/2.3/uml.xml#String'>
								<xmi:Extension extender='MagicDraw UML 16.8'>
									<referenceExtension referentPath='PrimitiveTypes::String' referentType='PrimitiveType'/>
								</xmi:Extension>
							</type>
							<ownedComment xmi:type='uml:Comment' xmi:id='Classes-Kernel-LiteralString-value-_ownedComment.0' body='The specified String value.'>
								<annotatedElement xmi:idref='Classes-Kernel-LiteralString-value'/>
							</ownedComment>
							<lowerValue xmi:type='uml:LiteralInteger' xmi:id='Classes-Kernel-LiteralString-value-_lowerValue' visibility='public'/>
						</ownedAttribute>
						<ownedOperation xmi:type='uml:Operation' xmi:id='Classes-Kernel-LiteralString-isComputable' name='isComputable' visibility='public' isQuery='true' bodyCondition='Classes-Kernel-LiteralString-isComputable-spec'>
							<xmi:Extension extender='MagicDraw UML 16.8'>
								<modelExtension/>
							</xmi:Extension>
							<redefinedOperation xmi:idref='Classes-Kernel-ValueSpecification-isComputable'/>
							<ownedComment xmi:type='uml:Comment' xmi:id='Classes-Kernel-LiteralString-isComputable-_ownedComment.0' body='The query isComputable() is redefined to be true.'>
								<annotatedElement xmi:idref='Classes-Kernel-LiteralString-isComputable'/>
							</ownedComment>
							<ownedRule xmi:type='uml:Constraint' xmi:id='Classes-Kernel-LiteralString-isComputable-spec' name='spec' visibility='public'>
								<constrainedElement xmi:idref='Classes-Kernel-LiteralString-isComputable'/>
								<specification xmi:type='uml:OpaqueExpression' xmi:id='Classes-Kernel-LiteralString-isComputable-spec-_specification' visibility='public'>
									<body>result = true</body>
									<language>OCL</language>
								</specification>
							</ownedRule>
							<ownedParameter xmi:type='uml:Parameter' xmi:id='Classes-Kernel-LiteralString-isComputable-result' name='result' visibility='public' direction='return' effect='create'>
								<type xmi:type='uml:PrimitiveType' href='http://schema.omg.org/spec/UML/2.3/uml.xml#Boolean'>
									<xmi:Extension extender='MagicDraw UML 16.8'>
										<referenceExtension referentPath='PrimitiveTypes::Boolean' referentType='PrimitiveType'/>
									</xmi:Extension>
								</type>
							</ownedParameter>
						</ownedOperation>
						<ownedOperation xmi:type='uml:Operation' xmi:id='Classes-Kernel-LiteralString-stringValue' name='stringValue' visibility='public' isQuery='true' bodyCondition='Classes-Kernel-LiteralString-stringValue-spec'>
							<xmi:Extension extender='MagicDraw UML 16.8'>
								<modelExtension/>
							</xmi:Extension>
							<redefinedOperation xmi:idref='Classes-Kernel-ValueSpecification-stringValue'/>
							<ownedComment xmi:type='uml:Comment' xmi:id='Classes-Kernel-LiteralString-stringValue-_ownedComment.0' body='The query stringValue() gives the value.'>
								<annotatedElement xmi:idref='Classes-Kernel-LiteralString-stringValue'/>
							</ownedComment>
							<ownedRule xmi:type='uml:Constraint' xmi:id='Classes-Kernel-LiteralString-stringValue-spec' name='spec' visibility='public'>
								<constrainedElement xmi:idref='Classes-Kernel-LiteralString-stringValue'/>
								<specification xmi:type='uml:OpaqueExpression' xmi:id='Classes-Kernel-LiteralString-stringValue-spec-_specification' visibility='public'>
									<body>result = value</body>
									<language>OCL</language>
								</specification>
							</ownedRule>
							<ownedParameter xmi:type='uml:Parameter' xmi:id='Classes-Kernel-LiteralString-stringValue-result' name='result' visibility='public' direction='return' effect='create'>
								<type xmi:type='uml:PrimitiveType' href='http://schema.omg.org/spec/UML/2.3/uml.xml#String'>
									<xmi:Extension extender='MagicDraw UML 16.8'>
										<referenceExtension referentPath='PrimitiveTypes::String' referentType='PrimitiveType'/>
									</xmi:Extension>
								</type>
							</ownedParameter>
						</ownedOperation>
					</packagedElement>
					<packagedElement xmi:type='uml:Class' xmi:id='Classes-Kernel-Feature' name='Feature' visibility='public' isAbstract='true'>
						<ownedComment xmi:type='uml:Comment' xmi:id='Classes-Kernel-Feature-_ownedComment.0' body='A feature declares a behavioral or structural characteristic of instances of classifiers.'>
							<annotatedElement xmi:idref='Classes-Kernel-Feature'/>
						</ownedComment>
						<generalization xmi:type='uml:Generalization' xmi:id='Classes-Kernel-Feature-_generalization.0' general='Classes-Kernel-RedefinableElement'/>
						<ownedAttribute xmi:type='uml:Property' xmi:id='Classes-Kernel-Feature-featuringClassifier' name='featuringClassifier' visibility='public' isReadOnly='true' isDerived='true' isDerivedUnion='true' type='Classes-Kernel-Classifier' association='Classes-Kernel-A_feature_featuringClassifier'>
							<subsettedProperty xmi:idref='Classes-Kernel-A_member_memberNamespace-memberNamespace'/>
							<ownedComment xmi:type='uml:Comment' xmi:id='Classes-Kernel-Feature-featuringClassifier-_ownedComment.0' body='The Classifiers that have this Feature as a feature.'>
								<annotatedElement xmi:idref='Classes-Kernel-Feature-featuringClassifier'/>
							</ownedComment>
							<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='Classes-Kernel-Feature-featuringClassifier-_upperValue' visibility='public' value='*'/>
							<lowerValue xmi:type='uml:LiteralInteger' xmi:id='Classes-Kernel-Feature-featuringClassifier-_lowerValue' visibility='public'/>
						</ownedAttribute>
						<ownedAttribute xmi:type='uml:Property' xmi:id='Classes-Kernel-Feature-isStatic' name='isStatic' visibility='public'>
							<type xmi:type='uml:PrimitiveType' href='http://schema.omg.org/spec/UML/2.3/uml.xml#Boolean'>
								<xmi:Extension extender='MagicDraw UML 16.8'>
									<referenceExtension referentPath='PrimitiveTypes::Boolean' referentType='PrimitiveType'/>
								</xmi:Extension>
							</type>
							<ownedComment xmi:type='uml:Comment' xmi:id='Classes-Kernel-Feature-isStatic-_ownedComment.0' body='Specifies whether this feature characterizes individual instances classified by the classifier (false) or the classifier itself (true).'>
								<annotatedElement xmi:idref='Classes-Kernel-Feature-isStatic'/>
							</ownedComment>
							<defaultValue xmi:type='uml:LiteralBoolean' xmi:id='Classes-Kernel-Feature-isStatic-_defaultValue' visibility='public'/>
						</ownedAttribute>
					</packagedElement>
					<packagedElement xmi:type='uml:Class' xmi:id='Classes-Kernel-RedefinableElement' name='RedefinableElement' visibility='public' isAbstract='true'>
						<xmi:Extension extender='MagicDraw UML 16.8'>
							<modelExtension/>
						</xmi:Extension>
						<ownedComment xmi:type='uml:Comment' xmi:id='Classes-Kernel-RedefinableElement-_ownedComment.0' body='A redefinable element is an element that, when defined in the context of a classifier, can be redefined more specifically or differently in the context of another classifier that specializes (directly or indirectly) the context classifier.'>
							<annotatedElement xmi:idref='Classes-Kernel-RedefinableElement'/>
						</ownedComment>
						<ownedRule xmi:type='uml:Constraint' xmi:id='Classes-Kernel-RedefinableElement-non_leaf_redefinition' name='non_leaf_redefinition' visibility='public'>
							<constrainedElement xmi:idref='Classes-Kernel-RedefinableElement'/>
							<ownedComment xmi:type='uml:Comment' xmi:id='Classes-Kernel-RedefinableElement-non_leaf_redefinition-_ownedComment.0' body='A redefinable element can only redefine non-leaf redefinable elements'>
								<annotatedElement xmi:idref='Classes-Kernel-RedefinableElement-non_leaf_redefinition'/>
							</ownedComment>
							<specification xmi:type='uml:OpaqueExpression' xmi:id='Classes-Kernel-RedefinableElement-non_leaf_redefinition-_specification' visibility='public'>
								<body>self.redefinedElement-&gt;forAll(not isLeaf)</body>
								<language>OCL</language>
							</specification>
						</ownedRule>
						<ownedRule xmi:type='uml:Constraint' xmi:id='Classes-Kernel-RedefinableElement-redefinition_context_valid' name='redefinition_context_valid' visibility='public'>
							<constrainedElement xmi:idref='Classes-Kernel-RedefinableElement'/>
							<ownedComment xmi:type='uml:Comment' xmi:id='Classes-Kernel-RedefinableElement-redefinition_context_valid-_ownedComment.0' body='At least one of the redefinition contexts of the redefining element must be a specialization of at least one of the redefinition contexts for each redefined element.'>
								<annotatedElement xmi:idref='Classes-Kernel-RedefinableElement-redefinition_context_valid'/>
							</ownedComment>
							<specification xmi:type='uml:OpaqueExpression' xmi:id='Classes-Kernel-RedefinableElement-redefinition_context_valid-_specification' visibility='public'>
								<body>self.redefinedElement-&gt;forAll(e | self.isRedefinitionContextValid(e))</body>
								<language>OCL</language>
							</specification>
						</ownedRule>
						<ownedRule xmi:type='uml:Constraint' xmi:id='Classes-Kernel-RedefinableElement-redefinition_consistent' name='redefinition_consistent' visibility='public'>
							<constrainedElement xmi:idref='Classes-Kernel-RedefinableElement'/>
							<ownedComment xmi:type='uml:Comment' xmi:id='Classes-Kernel-RedefinableElement-redefinition_consistent-_ownedComment.0' body='A redefining element must be consistent with each redefined element.'>
								<annotatedElement xmi:idref='Classes-Kernel-RedefinableElement-redefinition_consistent'/>
							</ownedComment>
							<specification xmi:type='uml:OpaqueExpression' xmi:id='Classes-Kernel-RedefinableElement-redefinition_consistent-_specification' visibility='public'>
								<body>self.redefinedElement-&gt;forAll(re | re.isConsistentWith(self))</body>
								<language>OCL</language>
							</specification>
						</ownedRule>
						<generalization xmi:type='uml:Generalization' xmi:id='Classes-Kernel-RedefinableElement-_generalization.0' general='Classes-Kernel-NamedElement'/>
						<ownedAttribute xmi:type='uml:Property' xmi:id='Classes-Kernel-RedefinableElement-isLeaf' name='isLeaf' visibility='public'>
							<type xmi:type='uml:PrimitiveType' href='http://schema.omg.org/spec/UML/2.3/uml.xml#Boolean'>
								<xmi:Extension extender='MagicDraw UML 16.8'>
									<referenceExtension referentPath='PrimitiveTypes::Boolean' referentType='PrimitiveType'/>
								</xmi:Extension>
							</type>
							<ownedComment xmi:type='uml:Comment' xmi:id='Classes-Kernel-RedefinableElement-isLeaf-_ownedComment.0' body='Indicates whether it is possible to further redefine a RedefinableElement. If the value is true, then it is not possible to further redefine the RedefinableElement. Note that this property is preserved through package merge operations; that is, the capability to redefine a RedefinableElement (i.e., isLeaf=false) must be preserved in the resulting RedefinableElement of a package merge operation where a RedefinableElement with isLeaf=false is merged with a matching RedefinableElement with isLeaf=true: the resulting RedefinableElement will have isLeaf=false. Default value is false.'>
								<annotatedElement xmi:idref='Classes-Kernel-RedefinableElement-isLeaf'/>
							</ownedComment>
							<defaultValue xmi:type='uml:LiteralBoolean' xmi:id='Classes-Kernel-RedefinableElement-isLeaf-_defaultValue' visibility='public'/>
						</ownedAttribute>
						<ownedAttribute xmi:type='uml:Property' xmi:id='Classes-Kernel-RedefinableElement-redefinedElement' name='redefinedElement' visibility='public' isReadOnly='true' isDerived='true' isDerivedUnion='true' type='Classes-Kernel-RedefinableElement' association='Classes-Kernel-A_redefinedElement_redefinableElement'>
							<ownedComment xmi:type='uml:Comment' xmi:id='Classes-Kernel-RedefinableElement-redefinedElement-_ownedComment.0' body='The redefinable element that is being redefined by this element.'>
								<annotatedElement xmi:idref='Classes-Kernel-RedefinableElement-redefinedElement'/>
							</ownedComment>
							<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='Classes-Kernel-RedefinableElement-redefinedElement-_upperValue' visibility='public' value='*'/>
							<lowerValue xmi:type='uml:LiteralInteger' xmi:id='Classes-Kernel-RedefinableElement-redefinedElement-_lowerValue' visibility='public'/>
						</ownedAttribute>
						<ownedAttribute xmi:type='uml:Property' xmi:id='Classes-Kernel-RedefinableElement-redefinitionContext' name='redefinitionContext' visibility='public' isReadOnly='true' isDerived='true' isDerivedUnion='true' type='Classes-Kernel-Classifier' association='Classes-Kernel-A_redefinitionContext_redefinableElement'>
							<ownedComment xmi:type='uml:Comment' xmi:id='Classes-Kernel-RedefinableElement-redefinitionContext-_ownedComment.0' body='References the contexts that this element may be redefined from.'>
								<annotatedElement xmi:idref='Classes-Kernel-RedefinableElement-redefinitionContext'/>
							</ownedComment>
							<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='Classes-Kernel-RedefinableElement-redefinitionContext-_upperValue' visibility='public' value='*'/>
							<lowerValue xmi:type='uml:LiteralInteger' xmi:id='Classes-Kernel-RedefinableElement-redefinitionContext-_lowerValue' visibility='public'/>
						</ownedAttribute>
						<ownedOperation xmi:type='uml:Operation' xmi:id='Classes-Kernel-RedefinableElement-isConsistentWith' name='isConsistentWith' visibility='public' isQuery='true' bodyCondition='Classes-Kernel-RedefinableElement-isConsistentWith-spec'>
							<xmi:Extension extender='MagicDraw UML 16.8'>
								<modelExtension/>
							</xmi:Extension>
							<precondition xmi:idref='Classes-Kernel-RedefinableElement-isConsistentWith-pre'/>
							<ownedComment xmi:type='uml:Comment' xmi:id='Classes-Kernel-RedefinableElement-isConsistentWith-_ownedComment.0' body='The query isConsistentWith() specifies, for any two RedefinableElements in a context in which redefinition is possible, whether redefinition would be logically consistent. By default, this is false; this operation must be overridden for subclasses of RedefinableElement to define the consistency conditions.'>
								<annotatedElement xmi:idref='Classes-Kernel-RedefinableElement-isConsistentWith'/>
							</ownedComment>
							<ownedRule xmi:type='uml:Constraint' xmi:id='Classes-Kernel-RedefinableElement-isConsistentWith-spec' name='spec' visibility='public'>
								<constrainedElement xmi:idref='Classes-Kernel-RedefinableElement-isConsistentWith'/>
								<specification xmi:type='uml:OpaqueExpression' xmi:id='Classes-Kernel-RedefinableElement-isConsistentWith-spec-_specification' visibility='public'>
									<body>result = false</body>
									<language>OCL</language>
								</specification>
							</ownedRule>
							<ownedRule xmi:type='uml:Constraint' xmi:id='Classes-Kernel-RedefinableElement-isConsistentWith-pre' name='pre' visibility='public'>
								<constrainedElement xmi:idref='Classes-Kernel-RedefinableElement-isConsistentWith'/>
								<specification xmi:type='uml:OpaqueExpression' xmi:id='Classes-Kernel-RedefinableElement-isConsistentWith-pre-_specification' visibility='public'>
									<body>redefinee.isRedefinitionContextValid(self)</body>
									<language>OCL</language>
								</specification>
							</ownedRule>
							<ownedParameter xmi:type='uml:Parameter' xmi:id='Classes-Kernel-RedefinableElement-isConsistentWith-result' name='result' visibility='public' direction='return' effect='create'>
								<type xmi:type='uml:PrimitiveType' href='http://schema.omg.org/spec/UML/2.3/uml.xml#Boolean'>
									<xmi:Extension extender='MagicDraw UML 16.8'>
										<referenceExtension referentPath='PrimitiveTypes::Boolean' referentType='PrimitiveType'/>
									</xmi:Extension>
								</type>
							</ownedParameter>
							<ownedParameter xmi:type='uml:Parameter' xmi:id='Classes-Kernel-RedefinableElement-isConsistentWith-redefinee' name='redefinee' visibility='public' effect='create' type='Classes-Kernel-RedefinableElement'/>
						</ownedOperation>
						<ownedOperation xmi:type='uml:Operation' xmi:id='Classes-Kernel-RedefinableElement-isRedefinitionContextValid' name='isRedefinitionContextValid' visibility='public' isQuery='true' bodyCondition='Classes-Kernel-RedefinableElement-isRedefinitionContextValid-spec'>
							<xmi:Extension extender='MagicDraw UML 16.8'>
								<modelExtension/>
							</xmi:Extension>
							<ownedComment xmi:type='uml:Comment' xmi:id='Classes-Kernel-RedefinableElement-isRedefinitionContextValid-_ownedComment.0' body='The query isRedefinitionContextValid() specifies whether the redefinition contexts of this RedefinableElement are properly related to the redefinition contexts of the specified RedefinableElement to allow this element to redefine the other. By default at least one of the redefinition contexts of this element must be a specialization of at least one of the redefinition contexts of the specified element.'>
								<annotatedElement xmi:idref='Classes-Kernel-RedefinableElement-isRedefinitionContextValid'/>
							</ownedComment>
							<ownedRule xmi:type='uml:Constraint' xmi:id='Classes-Kernel-RedefinableElement-isRedefinitionContextValid-spec' name='spec' visibility='public'>
								<constrainedElement xmi:idref='Classes-Kernel-RedefinableElement-isRedefinitionContextValid'/>
								<specification xmi:type='uml:OpaqueExpression' xmi:id='Classes-Kernel-RedefinableElement-isRedefinitionContextValid-spec-_specification' visibility='public'>
									<body>result = redefinitionContext-&gt;exists(c | c.allParents()-&gt;includes(redefined.redefinitionContext)))</body>
									<language>OCL</language>
								</specification>
							</ownedRule>
							<ownedParameter xmi:type='uml:Parameter' xmi:id='Classes-Kernel-RedefinableElement-isRedefinitionContextValid-result' name='result' visibility='public' direction='return' effect='create'>
								<type xmi:type='uml:PrimitiveType' href='http://schema.omg.org/spec/UML/2.3/uml.xml#Boolean'>
									<xmi:Extension extender='MagicDraw UML 16.8'>
										<referenceExtension referentPath='PrimitiveTypes::Boolean' referentType='PrimitiveType'/>
									</xmi:Extension>
								</type>
							</ownedParameter>
							<ownedParameter xmi:type='uml:Parameter' xmi:id='Classes-Kernel-RedefinableElement-isRedefinitionContextValid-redefined' name='redefined' visibility='public' effect='create' type='Classes-Kernel-RedefinableElement'/>
						</ownedOperation>
					</packagedElement>
					<packagedElement xmi:type='uml:Association' xmi:id='Classes-Kernel-A_source_directedRelationship' name='A_source_directedRelationship' visibility='public' isDerived='true'>
						<memberEnd xmi:idref='Classes-Kernel-A_source_directedRelationship-directedRelationship'/>
						<memberEnd xmi:idref='Classes-Kernel-DirectedRelationship-source'/>
						<ownedEnd xmi:type='uml:Property' xmi:id='Classes-Kernel-A_source_directedRelationship-directedRelationship' name='directedRelationship' visibility='public' type='Classes-Kernel-DirectedRelationship' association='Classes-Kernel-A_source_directedRelationship'>
							<subsettedProperty xmi:idref='Classes-Kernel-A_relatedElement_relationship-relationship'/>
							<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='Classes-Kernel-A_source_directedRelationship-directedRelationship-_upperValue' visibility='public' value='*'/>
							<lowerValue xmi:type='uml:LiteralInteger' xmi:id='Classes-Kernel-A_source_directedRelationship-directedRelationship-_lowerValue' visibility='public'/>
						</ownedEnd>
					</packagedElement>
					<packagedElement xmi:type='uml:Class' xmi:id='Classes-Kernel-OpaqueExpression' name='OpaqueExpression' visibility='public'>
						<xmi:Extension extender='MagicDraw UML 16.8'>
							<modelExtension/>
						</xmi:Extension>
						<ownedComment xmi:type='uml:Comment' xmi:id='Classes-Kernel-OpaqueExpression-_ownedComment.0' body='An opaque expression is an uninterpreted textual statement that denotes a (possibly empty) set of values when evaluated in a context.'>
							<annotatedElement xmi:idref='Classes-Kernel-OpaqueExpression'/>
						</ownedComment>
						<ownedRule xmi:type='uml:Constraint' xmi:id='Classes-Kernel-OpaqueExpression-language_body_size' name='language_body_size' visibility='public'>
							<constrainedElement xmi:idref='Classes-Kernel-OpaqueExpression'/>
							<ownedComment xmi:type='uml:Comment' xmi:id='Classes-Kernel-OpaqueExpression-language_body_size-_ownedComment.0' body='If the language attribute is not empty, then the size of the body and language arrays must be the same.'>
