							<ownedComment xmi:type='uml:Comment' xmi:id='Interactions-BasicInteractions-Message-signature-_ownedComment.0' body='The signature of the Message is the specification of its content. It refers either an Operation or a Signal.'>
								<annotatedElement xmi:idref='Interactions-BasicInteractions-Message-signature'/>
							</ownedComment>
