					<packagedElement xmi:type='uml:Class' xmi:id='Activities-StructuredActivities-ConditionalNode' name='ConditionalNode' visibility='public'>
						<xmi:Extension extender='MagicDraw UML 16.8'>
							<modelExtension/>
						</xmi:Extension>
						<ownedComment xmi:type='uml:Comment' xmi:id='Activities-StructuredActivities-ConditionalNode-_ownedComment.0' body='A conditional node is a structured activity node that represents an exclusive choice among some number of alternatives.'>
