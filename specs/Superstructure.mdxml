							<modelExtension/>
						</xmi:Extension>
						<ownedComment xmi:type='uml:Comment' xmi:id='Classes-Kernel-Package-_ownedComment.0' body='A package is used to group elements, and provides a namespace for the grouped elements.'>
							<annotatedElement xmi:idref='Classes-Kernel-Package'/>
						</ownedComment>
						<ownedRule xmi:type='uml:Constraint' xmi:id='Classes-Kernel-Package-elements_public_or_private' name='elements_public_or_private' visibility='public'>
							<constrainedElement xmi:idref='Classes-Kernel-Package'/>
							<ownedComment xmi:type='uml:Comment' xmi:id='Classes-Kernel-Package-elements_public_or_private-_ownedComment.0' body='If an element that is owned by a package has visibility, it is public or private.'>
								<annotatedElement xmi:idref='Classes-Kernel-Package-elements_public_or_private'/>
							</ownedComment>
							<specification xmi:type='uml:OpaqueExpression' xmi:id='Classes-Kernel-Package-elements_public_or_private-_specification' visibility='public'>
								<body>self.ownedElements-&gt;forAll(e | e.visibility-&gt;notEmpty() implies e.visbility = #public or e.visibility = #private)</body>
								<language>OCL</language>
							</specification>
						</ownedRule>
						<generalization xmi:type='uml:Generalization' xmi:id='Classes-Kernel-Package-_generalization.0' general='Classes-Kernel-Namespace'/>
						<generalization xmi:type='uml:Generalization' xmi:id='Classes-Kernel-Package-_generalization.1' general='Classes-Kernel-PackageableElement'/>
						<ownedAttribute xmi:type='uml:Property' xmi:id='Classes-Kernel-Package-URI' name='URI' visibility='public'>
							<type xmi:type='uml:PrimitiveType' href='http://schema.omg.org/spec/UML/2.3/uml.xml#String'>
								<xmi:Extension extender='MagicDraw UML 16.8'>
									<referenceExtension referentPath='PrimitiveTypes::String' referentType='PrimitiveType'/>
								</xmi:Extension>
							</type>
							<ownedComment xmi:type='uml:Comment' xmi:id='Classes-Kernel-Package-URI-_ownedComment.0' body='Provides an identifier for the package that can be used for many purposes. A URI is the universally unique identification of the package following the IETF URI specification, RFC 2396 http://www.ietf.org/rfc/rfc2396.txt and it must comply with those syntax rules.'>
								<annotatedElement xmi:idref='Classes-Kernel-Package-URI'/>
							</ownedComment>
