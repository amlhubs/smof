							<ownedComment xmi:type='uml:Comment' xmi:id='AuxiliaryConstructs-Templates-TemplateParameterSubstitution-actual-_ownedComment.0' body='The element that is the actual parameter for this substitution.'>
								<annotatedElement xmi:idref='AuxiliaryConstructs-Templates-TemplateParameterSubstitution-actual'/>
							</ownedComment>
