						<memberEnd xmi:idref='Interactions-BasicInteractions-StateInvariant-covered'/>
						<ownedEnd xmi:type='uml:Property' xmi:id='Interactions-BasicInteractions-A_covered_stateInvariant-stateInvariant' name='stateInvariant' visibility='public' type='Interactions-BasicInteractions-StateInvariant' association='Interactions-BasicInteractions-A_covered_stateInvariant'>
