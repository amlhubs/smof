								<specification xmi:type='uml:OpaqueExpression' xmi:id='StateMachines-BehaviorStateMachines-Vertex-outgoing.1-spec-_specification' visibility='public'>
									<body>result = Transition.allInstances()-&gt;select(t | t.source=self)</body>
