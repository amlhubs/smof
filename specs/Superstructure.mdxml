						<ownedOperation xmi:type='uml:Operation' xmi:id='Classes-Kernel-LiteralNull-isComputable' name='isComputable' visibility='public' isQuery='true' bodyCondition='Classes-Kernel-LiteralNull-isComputable-spec'>
