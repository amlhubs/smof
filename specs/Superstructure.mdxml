						<ownedAttribute xmi:type='uml:Property' xmi:id='CommonBehaviors-SimpleTime-Duration-observation' name='observation' visibility='public' type='CommonBehaviors-SimpleTime-Observation' association='CommonBehaviors-SimpleTime-A_observation_duration'>
							<ownedComment xmi:type='uml:Comment' xmi:id='CommonBehaviors-SimpleTime-Duration-observation-_ownedComment.0' body='Refers to the time and duration observations that are involved in expr.'>
								<annotatedElement xmi:idref='CommonBehaviors-SimpleTime-Duration-observation'/>
							</ownedComment>
							<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='CommonBehaviors-SimpleTime-Duration-observation-_upperValue' visibility='public' value='*'/>
							<lowerValue xmi:type='uml:LiteralInteger' xmi:id='CommonBehaviors-SimpleTime-Duration-observation-_lowerValue' visibility='public'/>
